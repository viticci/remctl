# ── Server ───────────────────────────────────────────────────────────────────

class RemctlServer(ThreadingHTTPServer):
    """Threading HTTP server that holds runtime configuration."""

    daemon_threads = True

    def __init__(self, addr, handler, api_token, allow_origin=None, enable_opengraph=False):
        self.api_token = api_token
        self.allow_origin = allow_origin
        self.enable_opengraph = enable_opengraph
        super().__init__(addr, handler)


def run_server(host, port, token, token_source, allow_origin=None, enable_opengraph=False):
    """Start the HTTP server with graceful shutdown."""
    server = RemctlServer(
        (host, port),
        RemctlHandler,
        token,
        allow_origin=allow_origin,
        enable_opengraph=enable_opengraph,
    )

    print(f"""
RemCTL API Server v{VERSION}
Listening on http://{host}:{port}
Auth: Bearer token required
Token: {mask_secret(token)}  (from {token_source})
CORS: {'disabled' if not allow_origin else allow_origin}
OpenGraph: {'enabled' if enable_opengraph else 'disabled'}

Database: {find_main_db() or 'NOT FOUND'}
Bridge:   {BRIDGE_PATH} ({'available' if BRIDGE_PATH.exists() else 'not found, using remctl CLI fallback'})
""", flush=True)

    # Graceful shutdown
    def _shutdown(signum, frame):
        signame = "SIGINT" if signum == signal.SIGINT else "SIGTERM"
        sys.stderr.write(f"\n[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] {signame} received, shutting down...\n")
        server.shutdown()

    signal.signal(signal.SIGINT, _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
        sys.stderr.write(f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] Server stopped.\n")



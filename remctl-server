# ── Server ───────────────────────────────────────────────────────────────────

class RemctlServer(HTTPServer):
    """HTTPServer subclass that holds the API token."""

    def __init__(self, addr, handler, api_token):
        self.api_token = api_token
        super().__init__(addr, handler)


def run_server(port, token, token_source):
    """Start the HTTP server with graceful shutdown."""
    server = RemctlServer(("0.0.0.0", port), RemctlHandler, token)

    # Mask middle of token for display
    if len(token) > 8:
        masked = token[:4] + "..." + token[-4:]
    else:
        masked = "****"

    print(f"""
RemCTL API Server v{VERSION}
Listening on http://0.0.0.0:{port}
Auth: Bearer token required
Token: {masked}  (from {token_source})

Database: {find_main_db() or 'NOT FOUND'}
Bridge:   {BRIDGE_PATH} ({'available' if BRIDGE_PATH.exists() else 'not found, using remctl CLI fallback'})
""", flush=True)

    # Graceful shutdown
    def _shutdown(signum, frame):
        signame = "SIGINT" if signum == signal.SIGINT else "SIGTERM"
        sys.stderr.write(f"\n[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] {signame} received, shutting down...\n")
        server.shutdown()

    signal.signal(signal.SIGINT, _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
        sys.stderr.write(f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] Server stopped.\n")


# ── CLI ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="remctl-server",
        description="REST API server for iCloud Reminders (via remctl)",
    )
    parser.add_argument(
        "--port", type=int, default=DEFAULT_PORT,
        help=f"Server port (default: {DEFAULT_PORT})",
    )
    parser.add_argument(
        "--token",
        help="Override API token (otherwise loaded from env/file)",
    )
    parser.add_argument(
        "--generate-token", action="store_true",
        help="Generate a new token, save it, and start server",
    )

    args = parser.parse_args()

    if args.generate_token:
        token = secrets.token_urlsafe(32)
        TOKEN_DIR.mkdir(parents=True, exist_ok=True)
        TOKEN_FILE.write_text(token + "\n")
        TOKEN_FILE.chmod(0o600)
        print(f"Generated token: {token}")
        print(f"Saved to: {TOKEN_FILE}")
        token_source = f"{TOKEN_FILE} (generated)"
    else:
        token, token_source = load_or_create_token(args.token)

    if args.generate_token:
        run_server(args.port, token, token_source)
    else:
        run_server(args.port, token, token_source)


if __name__ == "__main__":
    main()

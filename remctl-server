# ── Token Management ─────────────────────────────────────────────────────────

def load_or_create_token(cli_token=None):
    """Load API token from CLI arg, env var, or file. Generate if missing."""
    if cli_token:
        return cli_token, "CLI argument"

    env_token = os.environ.get("REMCTL_API_TOKEN")
    if env_token:
        return env_token, "REMCTL_API_TOKEN env"

    if TOKEN_FILE.exists():
        token = TOKEN_FILE.read_text().strip()
        if token:
            return token, str(TOKEN_FILE)

    # Generate new token
    token = secrets.token_urlsafe(32)
    TOKEN_DIR.mkdir(parents=True, exist_ok=True)
    TOKEN_FILE.write_text(token + "\n")
    TOKEN_FILE.chmod(0o600)
    return token, f"{TOKEN_FILE} (generated)"


# ── Database ─────────────────────────────────────────────────────────────────

def find_main_db():
    candidates = sorted(
        STORE_DIR.glob("Data-*.sqlite"),
        key=lambda p: p.stat().st_size,
        reverse=True,
    )
    return candidates[0] if candidates else None


def open_db():
    db_path = find_main_db()
    if not db_path:
        raise RuntimeError("No Reminders database found. Is iCloud Reminders enabled?")
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row
    return conn


def ts(v):
    """CoreData timestamp → Python datetime."""
    if not v:
        return None
    return datetime.fromtimestamp(v + APPLE_EPOCH)


def to_ts(dt):
    """Python datetime → CoreData timestamp."""
    return dt.timestamp() - APPLE_EPOCH


# ── Queries ──────────────────────────────────────────────────────────────────

def q_lists(db):
    return db.execute(
        "SELECT Z_PK, ZNAME, ZBADGEEMBLEM FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 "
        "AND ZNAME IS NOT NULL AND ZNAME != '' ORDER BY ZNAME"
    ).fetchall()


def q_list_pk(db, name):
    r = db.execute(
        "SELECT Z_PK FROM ZREMCDBASELIST "
        "WHERE ZNAME = ? COLLATE NOCASE AND ZMARKEDFORDELETION = 0 LIMIT 1",
        (name,),
    ).fetchone()
    return r[0] if r else None


def q_reminders(db, list_pk=None, completed=False, parent_pk=None,
                top_level=False, limit=500):
    conds, params = ["r.ZMARKEDFORDELETION = 0", "r.ZACCOUNT IS NOT NULL"], []
    if not completed:
        conds.append("r.ZCOMPLETED = 0")
    if list_pk is not None:
        conds.append("r.ZLIST = ?")
        params.append(list_pk)
    if parent_pk is not None:
        conds.append("r.ZPARENTREMINDER = ?")
        params.append(parent_pk)
    elif top_level:
        conds.append("(r.ZPARENTREMINDER IS NULL OR r.ZPARENTREMINDER = 0)")
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE {' AND '.join(conds)} ORDER BY r.Z_PK LIMIT ?",
        params + [limit],
    ).fetchall()


def q_reminder(db, pk):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.Z_PK = ?",
        (pk,),
    ).fetchone()


def q_subtask_count(db, pk):
    return db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER "
        "WHERE ZPARENTREMINDER = ? AND ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0",
        (pk,),
    ).fetchone()[0]


def q_sections(db, list_pk=None):
    if list_pk:
        return db.execute(
            "SELECT Z_PK, ZDISPLAYNAME, ZLIST FROM ZREMCDBASESECTION "
            "WHERE ZMARKEDFORDELETION = 0 AND ZLIST = ? ORDER BY Z_PK",
            (list_pk,),
        ).fetchall()
    return db.execute(
        "SELECT s.Z_PK, s.ZDISPLAYNAME, s.ZLIST, l.ZNAME as list_name "
        "FROM ZREMCDBASESECTION s "
        "LEFT JOIN ZREMCDBASELIST l ON s.ZLIST = l.Z_PK "
        "WHERE s.ZMARKEDFORDELETION = 0 ORDER BY l.ZNAME, s.Z_PK"
    ).fetchall()


def q_section_memberships(db, list_pk):
    row = db.execute(
        "SELECT ZMEMBERSHIPSOFREMINDERSINSECTIONSASDATA "
        "FROM ZREMCDBASELIST WHERE Z_PK = ?",
        (list_pk,),
    ).fetchone()
    if not row or not row[0]:
        return {}
    try:
        data = json.loads(row[0])
    except (json.JSONDecodeError, TypeError):
        return {}
    sections = db.execute(
        "SELECT ZCKIDENTIFIER, ZDISPLAYNAME FROM ZREMCDBASESECTION "
        "WHERE ZLIST = ? AND ZMARKEDFORDELETION = 0",
        (list_pk,),
    ).fetchall()
    g2n = {s["ZCKIDENTIFIER"]: s["ZDISPLAYNAME"] for s in sections}
    return {
        m["memberID"]: g2n[m["groupID"]]
        for m in data.get("memberships", [])
        if m.get("groupID") in g2n and m.get("memberID")
    }


def q_attachments(db, pk):
    return db.execute(
        "SELECT ZFILENAME, ZUTI, ZATTACHMENTTYPERAWVALUE FROM ZREMCDSAVEDATTACHMENT "
        "WHERE ZREMINDER = ? AND ZMARKEDFORDELETION = 0",
        (pk,),
    ).fetchall()


def q_hashtags(db, pk):
    return db.execute(
        "SELECT h.ZNAME FROM ZREMCDOBJECT o "
        "JOIN ZREMCDHASHTAGLABEL h ON o.ZHASHTAGLABEL = h.Z_PK "
        "WHERE o.ZREMINDER3 = ?",
        (pk,),
    ).fetchall()


def q_search(db, query, completed=False):
    # Escape LIKE metacharacters so `%` and `_` in the query match literally
    # instead of acting as wildcards (a search for `%` would otherwise dump
    # the whole store).
    safe = query.replace("\\", "\\\\").replace("%", "\\%").replace("_", "\\_")
    conds = [
        "r.ZMARKEDFORDELETION = 0",
        "r.ZACCOUNT IS NOT NULL",
        "l.Z_PK IS NOT NULL",
        "(r.ZTITLE LIKE ? ESCAPE '\\' OR r.ZNOTES LIKE ? ESCAPE '\\')",
    ]
    if not completed:
        conds.append("r.ZCOMPLETED = 0")
    pat = f"%{safe}%"
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE {' AND '.join(conds)} ORDER BY r.Z_PK DESC LIMIT 100",
        (pat, pat),
    ).fetchall()


def q_due_today(db, include_overdue=True):
    sod, eod = due_today_window()
    if include_overdue:
        where = f"r.ZDUEDATE < {to_ts(eod)} AND r.ZDUEDATE IS NOT NULL"
    else:
        where = (
            f"r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(eod)}"
        )
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND {where} ORDER BY r.ZDUEDATE"
    ).fetchall()


def q_upcoming(db, days=7):
    sod, end = upcoming_window(days)
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(end)} "
        f"ORDER BY r.ZDUEDATE"
    ).fetchall()


def q_overdue(db):
    now = start_of_day()
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE < {to_ts(now)} ORDER BY r.ZDUEDATE"
    ).fetchall()


def q_flagged(db):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZFLAGGED = 1 "
        f"ORDER BY r.ZDUEDATE NULLS LAST"
    ).fetchall()


def q_tags(db):
    return db.execute(
        "SELECT ZNAME FROM ZREMCDHASHTAGLABEL "
        "WHERE ZNAME IS NOT NULL ORDER BY ZNAME"
    ).fetchall()


def q_stats(db):
    total = db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER WHERE ZMARKEDFORDELETION = 0 AND ZACCOUNT IS NOT NULL"
    ).fetchone()[0]
    active = db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER "
        "WHERE ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0 AND ZACCOUNT IS NOT NULL"
    ).fetchone()[0]
    flagged = db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER "
        "WHERE ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0 AND ZFLAGGED = 1 AND ZACCOUNT IS NOT NULL"
    ).fetchone()[0]
    overdue = db.execute(
        f"SELECT COUNT(*) FROM ZREMCDREMINDER r "
        f"LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
        f"WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL "
        f"AND r.ZDUEDATE IS NOT NULL AND r.ZDUEDATE < {to_ts(datetime.now())}"
    ).fetchone()[0]
    lists = len(q_lists(db))
    sections = len(q_sections(db))
    return {
        "total": total,
        "active": active,
        "completed": total - active,
        "overdue": overdue,
        "flagged": flagged,
        "lists": lists,
        "sections": sections,
    }



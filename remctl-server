def q_rich_link(db, pk):
    """Look up a rich link URL from ZREMCDOBJECT for a reminder."""
    try:
        row = db.execute(
            "SELECT ZURL FROM ZREMCDOBJECT "
            "WHERE (ZREMINDER2 = ? OR ZREMINDER = ?) "
            "AND ZUTI = 'public.url' AND ZMARKEDFORDELETION = 0 LIMIT 1",
            (pk, pk)
        ).fetchone()
        return row[0] if row else None
    except Exception:
        return None


def reminder_to_dict(r, db=None, section=None, _sc=None, _ht=None):
    return serialize_reminder(
        r,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        section=section,
        subtask_counts=_sc,
        hashtags=_ht,
        rich_link_resolver=q_rich_link,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
    )


def reminders_to_list(db, rows, with_sections_for_list_pk=None):
    memberships = {}
    if with_sections_for_list_pk is not None:
        memberships = q_section_memberships(db, with_sections_for_list_pk)
    return serialize_reminders(
        rows,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        memberships=memberships,
        rich_link_resolver=q_rich_link,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
    )


# ── Write Operations ─────────────────────────────────────────────────────────

def resolve_ck_id(pk):
    """Resolve a SQLite Z_PK to a calendarItemIdentifier for the bridge.

    The bridge uses EventKit calendarItemIdentifiers, but the API exposes
    integer Z_PK IDs. This function maps between them via ZCKIDENTIFIER.
    """
    try:
        with closing(open_db()) as db:
            # Skip orphan rows (ZACCOUNT IS NULL) that the 2026-04-11 phantom-items
            # bug left in the store — they shouldn't be addressable for writes.
            r = db.execute(
                "SELECT r.ZCKIDENTIFIER, l.ZNAME as list_name FROM ZREMCDREMINDER r "
                "LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
                "WHERE r.Z_PK = ? AND r.ZACCOUNT IS NOT NULL AND r.ZMARKEDFORDELETION = 0",
                (pk,)
            ).fetchone()
        if r and r["ZCKIDENTIFIER"]:
            return r["ZCKIDENTIFIER"], r["list_name"]
    except Exception:
        pass
    return None, None


def applescript_write(pk, action_data):
    """Write via AppleScript (goes through remindd → reliable iCloud sync).

    AppleScript is slow (~30s) but it's the ONLY reliable way to sync
    changes to iCloud. EventKit writes update CoreData locally but
    remindd won't push them to CloudKit.

    Returns dict with status on success, None on failure/timeout.
    """
    try:
        with closing(open_db()) as db:
            r = db.execute(
                "SELECT r.ZCKIDENTIFIER, r.ZTITLE, l.ZNAME as list_name "
                "FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l ON r.ZLIST = l.Z_PK "
                "WHERE r.Z_PK = ?", (pk,)
            ).fetchone()
        if not r or not r["ZCKIDENTIFIER"]:
            return None

        ck_id = r["ZCKIDENTIFIER"]
        list_name = r["list_name"] or "Reminders"
        title = r["ZTITLE"] or ""

        def esc(s):
            # Harden against AppleScript injection. Apply to EVERY user-controlled
            # string before it lands in a script literal. Covers backslash, quote,
            # and every control/line-break character that can terminate an
            # AppleScript string (CR, LF, tab, U+0085, U+2028, U+2029). Also
            # strips remaining ASCII control bytes.
            s = str(s).replace("\\", "\\\\").replace('"', '\\"')
            for ch in ("\r", "\n", "\t", "\u0085", "\u2028", "\u2029"):
                s = s.replace(ch, " ")
            return "".join(c if ord(c) >= 0x20 else " " for c in s)

        def as_date_assign(dt, varname="_rdt", target="due date of r"):
            # Locale-neutral date assignment via numeric field-setting.
            # Using `date "localized string"` breaks on non-English macOS.
            return (
                f"set {varname} to current date\n"
                f"set year of {varname} to {dt.year}\n"
                f"set month of {varname} to {dt.month}\n"
                f"set day of {varname} to {dt.day}\n"
                f"set hours of {varname} to {dt.hour}\n"
                f"set minutes of {varname} to {dt.minute}\n"
                f"set seconds of {varname} to {dt.second}\n"
                f"set {target} to {varname}"
            )

        action = action_data.get("action", "")
        commands = []

        if action == "update":
            if action_data.get("title"):
                commands.append(f'set name of r to "{esc(action_data["title"])}"')
            # URL field is not writable via EventKit/AppleScript (private ReminderKit API).
            # Append URL to notes as a tappable link fallback. Escape BOTH
            # notes and URL before concatenation (previous code concatenated
            # raw url into notes, then esc()-d only notes, letting a crafted
            # URL break out of the AppleScript string literal).
            notes = action_data.get("notes") or ""
            url = action_data.get("url") or ""
            if url and notes:
                notes = notes + "\n\n" + url
            elif url:
                notes = url
            if notes:
                commands.append(f'set body of r to "{esc(notes)}"')
            if "due" in action_data:
                due_str = action_data["due"]
                if due_str in (None, ""):
                    commands.append("set due date of r to missing value")
                else:
                    for fmt in ("%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M", "%Y-%m-%d"):
                        try:
                            dt = datetime.strptime(due_str, fmt)
                            commands.append(as_date_assign(dt))
                            break
                        except ValueError:
                            continue
            pm = {"high": 1, "medium": 5, "low": 9, "none": 0}
            if action_data.get("priority") is not None:
                pri = action_data["priority"]
                if isinstance(pri, str):
                    pri = pm.get(pri, 0)
                try:
                    pri = int(pri)
                    if pri < 0 or pri > 9:
                        pri = 0
                    commands.append(f"set priority of r to {pri}")
                except (TypeError, ValueError):
                    pass  # silently ignore malformed priority
            if action_data.get("flagged") is not None:
                val = "true" if bool(action_data["flagged"]) else "false"
                commands.append(f"set flagged of r to {val}")

        elif action == "complete":
            commands.append("set completed of r to true")

        elif action == "uncomplete":
            commands.append("set completed of r to false")

        elif action == "delete":
            commands.append("delete r")

        if not commands:
            return None

        cmd_str = "\n".join(commands)
        script = (
            f'tell application "Reminders"\n'
            f'tell list "{esc(list_name)}"\n'
            f'set r to (first reminder whose id is "x-apple-reminder://{esc(ck_id)}")\n'
            f'{cmd_str}\n'
            f'end tell\nend tell'
        )

        result = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True, text=True, timeout=45,
        )
        if result.returncode == 0:
            sys.stderr.write(f"[applescript_write] OK for #{pk} ({action})\n")
            return {"status": action_data.get("action", "updated"), "id": str(pk), "title": title}
        else:
            sys.stderr.write(f"[applescript_write] Error for #{pk}: {result.stderr[:100]}\n")
            return None

    except subprocess.TimeoutExpired:
        sys.stderr.write(f"[applescript_write] Timeout for #{pk}\n")
        return None
    except Exception as e:
        sys.stderr.write(f"[applescript_write] Exception for #{pk}: {e}\n")
        return None


def bridge_call(action_data, original_pk=None):
    """Write to Reminders.

    Strategy:
    1. update/complete/uncomplete/delete: AppleScript first (reliable iCloud sync)
    2. create/list ops: EventKit bridge (AppleScript can't create well)
    3. AppleScript failure or no bridge: remctl CLI fallback
    """
    resolved_pk = None

    # Resolve integer IDs
    if "id" in action_data and isinstance(action_data["id"], int):
        resolved_pk = action_data["id"]

    pk = original_pk or resolved_pk
    action = action_data.get("action", "")

    # AppleScript-first for operations that need iCloud sync
    if pk and action in ("update", "complete", "uncomplete", "delete"):
        result = applescript_write(pk, action_data)
        if result:
            return result
        sys.stderr.write(f"[bridge_call] AppleScript failed for #{pk}, falling back to bridge\n")

    # Bridge path (for creates, list ops, or AppleScript fallback)
    if "id" in action_data and isinstance(action_data["id"], int):
        ck_id, list_name = resolve_ck_id(action_data["id"])
        if ck_id:
            action_data = dict(action_data)
            action_data["id"] = ck_id
        else:
            return {"ok": False, "error": f"Could not resolve reminder #{action_data['id']}"}

    if BRIDGE_PATH.exists():
        try:
            result = subprocess.run(
                [str(BRIDGE_PATH)],
                input=json.dumps(action_data),
                capture_output=True, text=True, timeout=8,
            )
            if result.returncode == 0 and result.stdout.strip():
                bridge_result = json.loads(result.stdout)
                if action == "create":
                    created_id = None
                    if isinstance(bridge_result, dict):
                        created_id = bridge_result.get("id")
                        if created_id is None and isinstance(bridge_result.get("data"), dict):
                            created_id = bridge_result["data"].get("id")
                    if created_id:
                        time.sleep(0.5)  # give remindd a moment to finalize
                        try:
                            with closing(open_db()) as vdb:
                                if isinstance(created_id, int) or (
                                    isinstance(created_id, str) and created_id.isdigit()
                                ):
                                    row = vdb.execute(
                                        "SELECT ZACCOUNT FROM ZREMCDREMINDER WHERE Z_PK = ?",
                                        (int(created_id),),
                                    ).fetchone()
                                else:
                                    row = vdb.execute(
                                        "SELECT ZACCOUNT FROM ZREMCDREMINDER WHERE ZCKIDENTIFIER = ?",
                                        (created_id,),
                                    ).fetchone()
                            if row and row[0] is None and isinstance(bridge_result, dict):
                                sys.stderr.write(
                                    f"[bridge_call] WARNING: Reminder {created_id} created with ZACCOUNT=NULL "
                                    f"(remindd may be unhealthy). Item will be invisible to Reminders.app.\n"
                                )
                                bridge_result["warning"] = "Reminder created but may not sync — remindd appears unhealthy"
                        except Exception as ve:
                            sys.stderr.write(f"[bridge_call] Verification check failed: {ve}\n")
                return bridge_result
        except (subprocess.TimeoutExpired, json.JSONDecodeError):
            sys.stderr.write("[bridge_call] Bridge timed out or bad JSON, trying fallbacks\n")

    # Last resort: remctl CLI fallback
    return remctl_cli_fallback(action_data)


def remctl_cli_fallback(action_data):
    """Fall back to calling remctl CLI for write operations."""
    action = action_data.get("action", "")
    args = [str(REMCTL_PATH), "--format", "json"]

    if action == "create":
        args.append("add")
        args.append(action_data.get("title", "Untitled"))
        if action_data.get("list"):
            args.extend(["-l", action_data["list"]])
        if action_data.get("notes"):
            args.extend(["-n", action_data["notes"]])
        if action_data.get("due"):
            args.extend(["-d", action_data["due"]])
        if action_data.get("priority"):
            pri = PRI_NAME.get(action_data["priority"], "") if isinstance(
                action_data["priority"], int
            ) else action_data["priority"]
            if pri and pri != "none":
                args.extend(["-p", pri])
        if action_data.get("flagged"):
            args.append("-f")
        if action_data.get("url"):
            args.extend(["--url", action_data["url"]])

    elif action == "complete":
        args.extend(["done", str(action_data["id"])])

    elif action == "uncomplete":
        args.extend(["undone", str(action_data["id"])])

    elif action == "update":
        args.extend(["edit", str(action_data["id"])])
        if action_data.get("title"):
            args.extend(["--title", action_data["title"]])
        if action_data.get("notes"):
            args.extend(["-n", action_data["notes"]])
        if "due" in action_data:
            args.extend(["-d", "clear" if action_data["due"] in (None, "") else action_data["due"]])
        if action_data.get("priority") is not None:
            pri = action_data["priority"]
            if isinstance(pri, int):
                pri = PRI_NAME.get(pri, "none")
            args.extend(["-p", pri])
        if action_data.get("url"):
            args.extend(["--url", action_data["url"]])

    elif action == "delete":
        args.extend(["delete", str(action_data["id"]), "--force"])

    elif action == "flag":
        # No direct flag command in remctl CLI — use bridge or skip
        return {"ok": False, "error": "Flag operation requires remctl-bridge"}

    elif action == "unflag":
        return {"ok": False, "error": "Unflag operation requires remctl-bridge"}

    elif action == "create_list":
        # remctl CLI doesn't support list creation
        return {"ok": False, "error": "List creation requires remctl-bridge"}

    elif action == "rename_list":
        return {"ok": False, "error": "List rename requires remctl-bridge"}

    elif action == "delete_list":
        return {"ok": False, "error": "List deletion requires remctl-bridge"}

    else:
        return {"ok": False, "error": f"Unknown action: {action}"}

    try:
        result = subprocess.run(args, capture_output=True, text=True, timeout=30)
        if result.returncode == 0:
            try:
                return {"ok": True, "data": json.loads(result.stdout)}
            except json.JSONDecodeError:
                return {"ok": True, "data": {"message": result.stdout.strip()}}
        return {"ok": False, "error": result.stderr.strip() or "Command failed"}
    except subprocess.TimeoutExpired:
        return {"ok": False, "error": "Command timed out"}
    except FileNotFoundError:
        return {"ok": False, "error": "remctl not found"}


# ── OpenGraph Metadata ───────────────────────────────────────────────────────

import threading as _threading
_og_cache = {}          # url -> (data_dict, expiry_time)
_og_cache_lock = _threading.Lock()
_OG_CACHE_TTL = 3600    # 1 hour
_OG_FETCH_SEM = _threading.BoundedSemaphore(3)  # bound concurrent fetches

class _NoRedirectHandler(HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


def fetch_og_metadata(url):
    """Fetch OpenGraph metadata from a URL. Returns dict or None."""
    now = time.monotonic()

    # Check cache (read under lock — ThreadingHTTPServer calls this from
    # multiple threads; plain dict read-check-write is not atomic and the
    # previous iterate-and-delete path would crash on concurrent mutation).
    with _og_cache_lock:
        cached = _og_cache.get(url)
        if cached and cached[1] > now:
            return cached[0]

    if not is_safe_remote_url(url):
        return None

    # Cap concurrent outbound fetches so a single authenticated client can't
    # exhaust server sockets or memory.
    acquired = _OG_FETCH_SEM.acquire(timeout=10)
    if not acquired:
        return None
    try:
        try:
            req = Request(url, headers={
                "User-Agent": "RemCTL/1.0 (OpenGraph Preview)",
                "Accept": "text/html,application/xhtml+xml",
            })
            opener = build_opener(_NoRedirectHandler)
            with opener.open(req, timeout=5) as resp:
                if not is_safe_remote_url(resp.geturl()):
                    return None
                content_type = resp.headers.get("Content-Type", "")
                if "html" not in content_type.lower() and "xml" not in content_type.lower():
                    return None
                html = resp.read(65536).decode("utf-8", errors="ignore")
        except Exception:
            return None
    finally:
        _OG_FETCH_SEM.release()

    def og(prop):
        # Match both property="og:X" and name="og:X", content before or after
        for pattern in [
            rf'<meta[^>]+(?:property|name)=["\']og:{prop}["\'][^>]+content=["\']([^"\']+)',
            rf'<meta[^>]+content=["\']([^"\']+)["\'][^>]+(?:property|name)=["\']og:{prop}["\']',
        ]:
            m = re.search(pattern, html, re.I)
            if m:
                return m.group(1).strip()
        return None

    title = og("title")
    if not title:
        m = re.search(r"<title[^>]*>([^<]+)</title>", html, re.I)
        title = m.group(1).strip() if m else None

    description = og("description")
    if not description:
        m = re.search(
            r'<meta[^>]+name=["\']description["\'][^>]+content=["\']([^"\']+)',
            html, re.I,
        )
        if not m:
            m = re.search(
                r'<meta[^>]+content=["\']([^"\']+)["\'][^>]+name=["\']description["\']',
                html, re.I,
            )
        description = m.group(1).strip() if m else None

    image = og("image")
    site_name = og("site_name")

    parsed = urlparse(url)
    domain = parsed.netloc
    if domain.startswith("www."):
        domain = domain[4:]

    if not title and not description:
        return None

    data = {
        "title": title,
        "description": description,
        "image": image,
        "siteName": site_name,
        "domain": domain,
    }

    # Cache write + eviction must be atomic — previous version's
    # iterate-and-delete on a shared dict would crash under threaded load.
    with _og_cache_lock:
        _og_cache[url] = (data, now + _OG_CACHE_TTL)
        if len(_og_cache) > 500:
            stale = [k for k, (_, exp) in _og_cache.items() if exp <= now]
            for k in stale:
                _og_cache.pop(k, None)
            # If still oversized (all fresh), drop the oldest by expiry so
            # we don't grow unbounded on sustained unique-URL pressure.
            if len(_og_cache) > 500:
                oldest = sorted(_og_cache.items(), key=lambda kv: kv[1][1])[:len(_og_cache) - 500]
                for k, _ in oldest:
                    _og_cache.pop(k, None)

    return data


# ── HTTP Handler ─────────────────────────────────────────────────────────────

class RemctlHandler(BaseHTTPRequestHandler):
    """HTTP request handler for the remctl API."""

    server_version = f"RemCTL/{VERSION}"

    def log_message(self, format, *args):
        """Override default logging with timestamped format."""
        ts_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        client = self.client_address[0]
        sys.stderr.write(f"[{ts_str}] {client} {format % args}\n")

    # ── Response helpers ─────────────────────────────────────────────────

    def _cors_headers(self):
        if not self.server.allow_origin:
            return
        self.send_header("Access-Control-Allow-Origin", self.server.allow_origin)
        self.send_header(
            "Access-Control-Allow-Methods", "GET, POST, PATCH, DELETE, OPTIONS"
        )
        self.send_header(
            "Access-Control-Allow-Headers", "Authorization, Content-Type"
        )

    def _send_json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self._cors_headers()
        self.end_headers()
        self.wfile.write(body)

    def _ok(self, data):
        self._send_json({"ok": True, "data": data})

    def _error(self, message, status=400):
        self._send_json({"ok": False, "error": message}, status)

    def _internal_error(self, exc, method, path, t0):
        sys.stderr.write(
            f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] "
            f"{method} {path} 500 internal error: {exc}\n"
        )
        self._error("Internal server error", 500)
        self._log_timing(method, path, 500, t0)

    def _read_body(self):
        try:
            length = int(self.headers.get("Content-Length", 0))
        except ValueError:
            return None, 400, "Invalid Content-Length header"
        if length < 0:
            return None, 400, "Invalid Content-Length header"
        if length > MAX_REQUEST_BODY_BYTES:
            return None, 413, f"Request body too large (max {MAX_REQUEST_BODY_BYTES} bytes)"
        if length == 0:
            return {}, None, None
        raw = self.rfile.read(length)
        try:
            return json.loads(raw), None, None
        except json.JSONDecodeError:
            return None, 400, "Invalid JSON body"

    # ── Auth ─────────────────────────────────────────────────────────────

    def _check_auth(self):
        """Validate Bearer token. Returns True if authorized."""
        auth = self.headers.get("Authorization", "")
        if not auth.startswith("Bearer "):
            self._error("Missing Authorization: Bearer <token> header", 401)
            return False
        token = auth[7:].strip()
        if not secrets.compare_digest(token, self.server.api_token):
            self._error("Invalid token", 401)
            return False
        return True

    # ── Route matching ───────────────────────────────────────────────────

    def _parse_path(self):
        """Parse URL path and query string."""
        parsed = urlparse(self.path)
        path = unquote(parsed.path).rstrip("/") or "/"
        qs = parse_qs(parsed.query)
        return path, qs

    def _match(self, path, pattern):
        """Simple pattern matching. Returns dict of captures or None.

        Pattern examples:
          /api/v1/lists             → {}
          /api/v1/lists/:name       → {"name": "Shopping"}
          /api/v1/reminders/:id     → {"id": "42"}
        """
        p_parts = pattern.rstrip("/").split("/")
        u_parts = path.split("/")
        if len(p_parts) != len(u_parts):
            return None
        captures = {}
        for pp, up in zip(p_parts, u_parts):
            if pp.startswith(":"):
                captures[pp[1:]] = up
            elif pp != up:
                return None
        return captures

    # ── HTTP methods ─────────────────────────────────────────────────────

    def do_OPTIONS(self):
        self.send_response(204)
        self._cors_headers()
        self.end_headers()

    def do_GET(self):
        t0 = time.monotonic()
        path, qs = self._parse_path()

        # Health check — no auth required
        if path == "/health":
            db_ok = find_main_db() is not None
            self._ok({
                "status": "healthy" if db_ok else "degraded",
                "version": VERSION,
                "database": "connected" if db_ok else "not found",
                "timestamp": datetime.now().isoformat(),
            })
            self._log_timing("GET", path, 200, t0)
            return

        if not self._check_auth():
            self._log_timing("GET", path, 401, t0)
            return

        try:
            self._route_get(path, qs, t0)
        except RuntimeError as e:
            self._error(str(e), 503)
            self._log_timing("GET", path, 503, t0)
        except Exception as e:
            self._internal_error(e, "GET", path, t0)

    def do_POST(self):
        t0 = time.monotonic()
        path, qs = self._parse_path()

        if not self._check_auth():
            self._log_timing("POST", path, 401, t0)
            return

        body, error_status, error_message = self._read_body()
        if error_status is not None:
            self._error(error_message, error_status)
            self._log_timing("POST", path, error_status, t0)
            return

        try:
            self._route_post(path, qs, body, t0)
        except RuntimeError as e:
            self._error(str(e), 503)
            self._log_timing("POST", path, 503, t0)
        except Exception as e:
            self._internal_error(e, "POST", path, t0)

    def do_PATCH(self):
        t0 = time.monotonic()
        path, qs = self._parse_path()

        if not self._check_auth():
            self._log_timing("PATCH", path, 401, t0)
            return

        body, error_status, error_message = self._read_body()
        if error_status is not None:
            self._error(error_message, error_status)
            self._log_timing("PATCH", path, error_status, t0)
            return

        try:
            self._route_patch(path, qs, body, t0)
        except RuntimeError as e:
            self._error(str(e), 503)
            self._log_timing("PATCH", path, 503, t0)
        except Exception as e:
            self._internal_error(e, "PATCH", path, t0)

    def do_DELETE(self):
        t0 = time.monotonic()
        path, qs = self._parse_path()

        if not self._check_auth():
            self._log_timing("DELETE", path, 401, t0)
            return

        try:
            self._route_delete(path, qs, t0)
        except RuntimeError as e:
            self._error(str(e), 503)
            self._log_timing("DELETE", path, 503, t0)
        except Exception as e:
            self._internal_error(e, "DELETE", path, t0)

    def _log_timing(self, method, path, status, t0):
        ms = (time.monotonic() - t0) * 1000
        ts_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        sys.stderr.write(f"[{ts_str}] {method} {path} {status} ({ms:.0f}ms)\n")

    # ── GET routes ───────────────────────────────────────────────────────

    def _route_get(self, path, qs, t0):
        with closing(open_db()) as db:
            # GET /api/v1/lists
            if path == "/api/v1/lists":
                rows = q_lists(db)
                counts = {
                    row["ZLIST"]: row["active_count"]
                    for row in db.execute(
                        "SELECT ZLIST, COUNT(*) AS active_count "
                        "FROM ZREMCDREMINDER "
                        "WHERE ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0 AND ZACCOUNT IS NOT NULL "
                        "GROUP BY ZLIST"
                    ).fetchall()
                }
                section_counts = {
                    row["ZLIST"]: row["section_count"]
                    for row in db.execute(
                        "SELECT ZLIST, COUNT(*) AS section_count "
                        "FROM ZREMCDBASESECTION "
                        "WHERE ZMARKEDFORDELETION = 0 GROUP BY ZLIST"
                    ).fetchall()
                }
                data = []
                for r in rows:
                    entry = {
                        "id": r["Z_PK"],
                        "name": r["ZNAME"],
                        "activeCount": counts.get(r["Z_PK"], 0),
                        "sectionCount": section_counts.get(r["Z_PK"], 0),
                    }
                    emblem = r["ZBADGEEMBLEM"]
                    if emblem:
                        try:
                            emblem_data = json.loads(emblem)
                            if "Emoji" in emblem_data:
                                entry["icon"] = emblem_data["Emoji"]
                        except (json.JSONDecodeError, TypeError):
                            pass
                    data.append(entry)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            m = self._match(path, "/api/v1/lists/:name/sections")
            if m:
                name = unquote(m["name"])
                pk = q_list_pk(db, name)
                if pk is None:
                    self._error(f"List '{name}' not found", 404)
                    self._log_timing("GET", path, 404, t0)
                    return
                secs = q_sections(db, pk)
                data = [{"id": s["Z_PK"], "name": s["ZDISPLAYNAME"]} for s in secs]
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            m = self._match(path, "/api/v1/lists/:name")
            if m:
                name = unquote(m["name"])
                pk = q_list_pk(db, name)
                if pk is None:
                    self._error(f"List '{name}' not found", 404)
                    self._log_timing("GET", path, 404, t0)
                    return
                include_completed = qs.get("completed", ["0"])[0].lower() in {"1", "true", "yes", "on"}
                items = q_reminders(db, list_pk=pk, completed=include_completed, top_level=True)
                data = reminders_to_list(db, items, with_sections_for_list_pk=pk)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            m = self._match(path, "/api/v1/reminders/:id/subtasks")
            if m:
                try:
                    rid = int(m["id"])
                except ValueError:
                    self._error("Invalid reminder ID", 400)
                    self._log_timing("GET", path, 400, t0)
                    return
                parent = q_reminder(db, rid)
                if not parent:
                    self._error(f"Reminder #{rid} not found", 404)
                    self._log_timing("GET", path, 404, t0)
                    return
                subs = q_reminders(db, parent_pk=rid, completed=True)
                data = reminders_to_list(db, subs)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            m = self._match(path, "/api/v1/reminders/:id")
            if m:
                try:
                    rid = int(m["id"])
                except ValueError:
                    self._error("Invalid reminder ID", 400)
                    self._log_timing("GET", path, 400, t0)
                    return
                r = q_reminder(db, rid)
                if not r:
                    self._error(f"Reminder #{rid} not found", 404)
                    self._log_timing("GET", path, 404, t0)
                    return
                sec = None
                if r["ZLIST"]:
                    memberships = q_section_memberships(db, r["ZLIST"])
                    sec = memberships.get(r["ZCKIDENTIFIER"])
                d = reminder_to_dict(r, db, section=sec)
                attachments = q_attachments(db, rid)
                if attachments:
                    d["attachments"] = [
                        {
                            "filename": attachment["ZFILENAME"],
                            "type": attachment["ZATTACHMENTTYPERAWVALUE"],
                            "uti": attachment["ZUTI"],
                        }
                        for attachment in attachments
                    ]
                subs = q_reminders(db, parent_pk=rid, completed=True)
                if subs:
                    d["subtasks"] = reminders_to_list(db, subs)
                if r["ZPARENTREMINDER"]:
                    parent = q_reminder(db, r["ZPARENTREMINDER"])
                    if parent:
                        d["parentTitle"] = parent["ZTITLE"]
                self._ok(d)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/today":
                items = q_due_today(db, include_overdue=True)
                sod = start_of_day()
                data = reminders_to_list(db, items)
                for d, r in zip(data, items):
                    due_dt = ts(r["ZDUEDATE"])
                    if due_dt and due_dt < sod:
                        d["overdue"] = True
                        d["overdueDays"] = (sod - due_dt).days
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/upcoming":
                try:
                    days = int(qs.get("days", ["7"])[0])
                except ValueError:
                    self._error("Invalid 'days' query parameter", 400)
                    self._log_timing("GET", path, 400, t0)
                    return
                days = max(1, min(days, 90))
                items = q_upcoming(db, days=days)
                data = reminders_to_list(db, items)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/overdue":
                items = q_overdue(db)
                data = reminders_to_list(db, items)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/flagged":
                items = q_flagged(db)
                data = reminders_to_list(db, items)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/search":
                query = qs.get("q", [""])[0]
                if not query:
                    self._error("Missing 'q' query parameter", 400)
                    self._log_timing("GET", path, 400, t0)
                    return
                include_completed = qs.get("completed", ["0"])[0].lower() in {"1", "true", "yes", "on"}
                items = q_search(db, query, completed=include_completed)
                data = reminders_to_list(db, items)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/tags":
                rows = q_tags(db)
                data = [{"name": r["ZNAME"]} for r in rows]
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/sections":
                rows = q_sections(db)
                grouped = {}
                for r in rows:
                    ln = r["list_name"] or "?"
                    grouped.setdefault(ln, []).append({
                        "id": r["Z_PK"],
                        "name": r["ZDISPLAYNAME"],
                    })
                self._ok(grouped)
                self._log_timing("GET", path, 200, t0)
                return

            if path == "/api/v1/stats":
                data = q_stats(db)
                self._ok(data)
                self._log_timing("GET", path, 200, t0)
                return

        # GET /api/v1/og?url=... — OpenGraph metadata (no DB needed)
        if path == "/api/v1/og":
            if not self.server.enable_opengraph:
                self._error("OpenGraph endpoint disabled", 403)
                self._log_timing("GET", path, 403, t0)
                return
            target_url = qs.get("url", [""])[0]
            if not target_url:
                self._error("Missing 'url' query parameter", 400)
                self._log_timing("GET", path, 400, t0)
                return
            if not is_safe_remote_url(target_url):
                self._error("Refusing to fetch non-public or unsupported URL", 400)
                self._log_timing("GET", path, 400, t0)
                return
            data = fetch_og_metadata(target_url)
            if data is None:
                self._ok({"title": None, "description": None, "image": None,
                          "siteName": None, "domain": urlparse(target_url).netloc})
            else:
                self._ok(data)
            self._log_timing("GET", path, 200, t0)
            return

        self._error(f"Not found: {path}", 404)
        self._log_timing("GET", path, 404, t0)

    # ── POST routes ──────────────────────────────────────────────────────

    def _route_post(self, path, qs, body, t0):

        # POST /api/v1/reminders/:id/complete
        m = self._match(path, "/api/v1/reminders/:id/complete")
        if m:
            try:
                rid = int(m["id"])
            except ValueError:
                self._error("Invalid reminder ID", 400)
                self._log_timing("POST", path, 400, t0)
                return
            result = bridge_call({"action": "complete", "id": rid})
            if isinstance(result, dict) and result.get("ok") is False:
                self._error(result.get("error", "Failed"), 500)
                self._log_timing("POST", path, 500, t0)
            else:
                self._ok(result.get("data", result) if isinstance(result, dict) else result)
                self._log_timing("POST", path, 200, t0)
            return

        # POST /api/v1/reminders/:id/uncomplete
        m = self._match(path, "/api/v1/reminders/:id/uncomplete")
        if m:
            try:
                rid = int(m["id"])
            except ValueError:
                self._error("Invalid reminder ID", 400)
                self._log_timing("POST", path, 400, t0)
                return
            result = bridge_call({"action": "uncomplete", "id": rid})
            if isinstance(result, dict) and result.get("ok") is False:
                self._error(result.get("error", "Failed"), 500)
                self._log_timing("POST", path, 500, t0)
            else:
                self._ok(result.get("data", result) if isinstance(result, dict) else result)
                self._log_timing("POST", path, 200, t0)
            return

        # POST /api/v1/reminders/:id/flag
        m = self._match(path, "/api/v1/reminders/:id/flag")
        if m:
            try:
                rid = int(m["id"])
            except ValueError:
                self._error("Invalid reminder ID", 400)
                self._log_timing("POST", path, 400, t0)
                return
            result = bridge_call({"action": "flag", "id": rid, "flagged": True})
            if isinstance(result, dict) and result.get("ok") is False:
                self._error(result.get("error", "Failed"), 500)
                self._log_timing("POST", path, 500, t0)
            else:
                self._ok(result.get("data", result) if isinstance(result, dict) else result)
                self._log_timing("POST", path, 200, t0)
            return


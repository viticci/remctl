def main():
    parser = argparse.ArgumentParser(
        prog="remctl-server",
        description="REST API server for iCloud Reminders (via remctl)",
    )
    parser.add_argument(
        "--host",
        default=os.environ.get("REMCTL_HOST", DEFAULT_HOST),
        help=f"Bind host (default: {DEFAULT_HOST})",
    )
    parser.add_argument(
        "--port", type=int, default=DEFAULT_PORT,
        help=f"Server port (default: {DEFAULT_PORT})",
    )
    parser.add_argument(
        "--token",
        help="Override API token (otherwise loaded from env/file)",
    )
    parser.add_argument(
        "--generate-token", action="store_true",
        help="Generate a new token, save it, and start server",
    )
    parser.add_argument(
        "--allow-origin",
        default=os.environ.get("REMCTL_ALLOW_ORIGIN"),
        help="Set Access-Control-Allow-Origin. Disabled by default.",
    )
    parser.add_argument(
        "--enable-opengraph",
        action="store_true",
        default=env_bool("REMCTL_ENABLE_OPENGRAPH", False),
        help="Enable the /api/v1/og endpoint. Disabled by default for safety.",
    )
    parser.add_argument(
        "--allow-unsafe-sqlite-writes",
        action="store_true",
        help=argparse.SUPPRESS,
    )

    args = parser.parse_args()

    if args.generate_token:
        token = secrets.token_urlsafe(32)
        TOKEN_DIR.mkdir(parents=True, exist_ok=True)
        TOKEN_FILE.write_text(token + "\n")
        TOKEN_FILE.chmod(0o600)
        print(f"Generated token: {token}")
        print(f"Saved to: {TOKEN_FILE}")
        token_source = f"{TOKEN_FILE} (generated)"
    else:
        token, token_source = load_or_create_token(args.token)

    run_server(
        args.host,
        args.port,
        token,
        token_source,
        allow_origin=args.allow_origin,
        enable_opengraph=args.enable_opengraph,
    )


if __name__ == "__main__":
    main()

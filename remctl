def check_result(name, status, detail, fix=None):
    return {"name": name, "status": status, "detail": detail, "fix": fix}


def print_check_report(title, checks):
    fail_count = sum(1 for check in checks if check["status"] == "fail")
    warn_count = sum(1 for check in checks if check["status"] == "warn")
    status_labels = {
        "ok": C.green("OK"),
        "warn": C.yellow("WARN"),
        "fail": C.red("FAIL"),
    }
    if title:
        print(C.bold(title))
    for check in checks:
        print(f"[{status_labels[check['status']]}] {check['name']}: {check['detail']}")
        if check.get("fix"):
            for line in str(check["fix"]).splitlines():
                print(f"      {C.dim(line)}")
    summary = (
        f"{len(checks)} checks, {warn_count} warning{'s' if warn_count != 1 else ''}, "
        f"{fail_count} failure{'s' if fail_count != 1 else ''}"
    )
    if fail_count:
        print(C.red(summary))
    elif warn_count:
        print(C.yellow(summary))
    else:
        print(C.green(summary))
    return warn_count, fail_count


def _normalize_terminal_app_name(value):
    if not value:
        return None
    return KNOWN_TERMINAL_APPS.get(value.strip().lower())


def app_bundle_from_path_hint(value):
    if not value:
        return None
    match = re.search(r"(/.*?\.app)(?:/|\s|$)", str(value))
    if not match:
        return None
    path = Path(match.group(1)).expanduser().resolve(strict=False)
    return path if path.name.endswith(".app") and path.exists() else None


def find_app_bundle_by_identifier(bundle_id):
    if not bundle_id:
        return None
    if not re.match(r"^[A-Za-z0-9_.-]+$", str(bundle_id)):
        return None
    try:
        proc = subprocess.run(
            ["mdfind", f"kMDItemCFBundleIdentifier == '{bundle_id}'"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    for line in proc.stdout.splitlines():
        path = Path(line.strip()).expanduser()
        if path.name.endswith(".app") and path.exists():
            return path.resolve()
    return None


def bundle_context_from_environment():
    bundle_id = os.environ.get("__CFBundleIdentifier")
    bundle_path = find_app_bundle_by_identifier(bundle_id) if bundle_id else None
    if bundle_path:
        return {
            "app": bundle_path.name,
            "path": str(bundle_path),
            "bundle_id": bundle_id,
            "source": "__CFBundleIdentifier",
        }
    for env_name in ("GHOSTTY_RESOURCES_DIR", "GHOSTTY_BIN_DIR"):
        bundle_path = app_bundle_from_path_hint(os.environ.get(env_name))
        if bundle_path:
            return {
                "app": bundle_path.name,
                "path": str(bundle_path),
                "bundle_id": bundle_id,
                "source": env_name,
            }
    return None


def detect_terminal_app_name():
    env_name = _normalize_terminal_app_name(os.environ.get("TERM_PROGRAM"))
    if env_name:
        return env_name

    pid = os.getppid()
    for _ in range(6):
        if not pid or pid <= 1:
            break
        try:
            proc = subprocess.run(
                ["ps", "-o", "ppid=", "-o", "comm=", "-p", str(pid)],
                capture_output=True,
                text=True,
                timeout=5,
            )
        except (OSError, subprocess.TimeoutExpired):
            break
        if proc.returncode != 0:
            break
        line = proc.stdout.strip()
        if not line:
            break
        parts = line.split(None, 1)
        if len(parts) != 2:
            break
        next_pid, command = parts
        label = _normalize_terminal_app_name(Path(command).name)
        if label:
            return label
        try:
            pid = int(next_pid)
        except ValueError:
            break
    return None


def process_info(pid):
    try:
        proc = subprocess.run(
            ["ps", "-p", str(pid), "-o", "ppid=", "-o", "ucomm=", "-o", "command="],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    line = proc.stdout.strip()
    if not line:
        return None
    parts = line.split(None, 2)
    if len(parts) < 2:
        return None
    try:
        parent_pid = int(parts[0])
    except ValueError:
        parent_pid = None
    name = parts[1]
    command = parts[2] if len(parts) > 2 else name
    return {"pid": int(pid), "ppid": parent_pid, "name": name, "command": command}


def process_ancestry(limit=8):
    ancestry = []
    pid = os.getppid()
    for _ in range(limit):
        if not pid or pid <= 1:
            break
        info = process_info(pid)
        if not info:
            break
        ancestry.append(info)
        pid = info.get("ppid")
    return ancestry


def _app_name_from_process_name(name):
    if not name:
        return None
    lower = name.lower()
    if "codex" in lower:
        return "Codex.app"
    return _normalize_terminal_app_name(name)


def doctor_execution_context():
    ancestry = process_ancestry()
    parent = ancestry[0] if ancestry else None
    terminal_app = detect_terminal_app_name()
    bundle_context = bundle_context_from_environment()
    host_app = bundle_context["app"] if bundle_context else terminal_app
    host_app_path = bundle_context["path"] if bundle_context else None
    host_bundle_id = bundle_context["bundle_id"] if bundle_context else None
    host_app_source = bundle_context["source"] if bundle_context else ("terminal" if terminal_app else None)
    effective_context = "Terminal" if terminal_app else "unknown"

    for proc in ancestry:
        app_name = _app_name_from_process_name(proc.get("name"))
        if app_name:
            if bundle_context and app_name == "Ghostty.app" and bundle_context["app"] != "Ghostty.app":
                continue
            host_app = app_name
            resolved = find_app_bundle(app_name) if app_name.endswith(".app") else None
            host_app_path = str(resolved) if resolved else host_app_path
            host_app_source = "process"
            if "codex" in app_name.lower():
                effective_context = "Codex"
            elif app_name.endswith(".app"):
                effective_context = app_name.removesuffix(".app")
            break
        bundle_path = app_bundle_from_path_hint(proc.get("command"))
        if bundle_path:
            host_app = bundle_path.name
            host_app_path = str(bundle_path)
            host_app_source = "process_command"
            effective_context = host_app.removesuffix(".app")
            break
    if bundle_context and host_app == bundle_context["app"]:
        effective_context = host_app.removesuffix(".app")

    return {
        "python": sys.executable,
        "pid": os.getpid(),
        "parent_process": parent,
        "terminal_app": terminal_app,
        "host_app": host_app,
        "host_app_path": host_app_path,
        "host_bundle_id": host_bundle_id,
        "host_app_source": host_app_source,
        "effective_context": effective_context,
    }


def find_app_bundle(app_name):
    if not app_name:
        return None
    candidates = [
        Path.home() / "Applications" / app_name,
        Path("/Applications") / app_name,
        Path("/System/Applications") / app_name,
        Path("/System/Applications/Utilities") / app_name,
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate.resolve()
    try:
        proc = subprocess.run(
            ["mdfind", f"kMDItemFSName == '{app_name}'c"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    for line in proc.stdout.splitlines():
        path = Path(line.strip())
        if path.name == app_name and path.exists():
            return path.resolve()
    return None


def _add_permission_target(targets, seen, title, path, subtitle):
    if not path:
        return
    path = str(Path(path).expanduser().resolve(strict=False))
    key = path.lower()
    if key in seen:
        return
    seen.add(key)
    targets.append({"title": title, "path": path, "subtitle": subtitle})


def full_disk_access_target_specs(*, include_cli=True):
    targets = []
    seen = set()
    if include_cli:
        context = doctor_execution_context()
        _add_permission_target(
            targets,
            seen,
            "Current Python interpreter",
            sys.executable,
            "Required when direct CLI reads cannot see the Reminders database.",
        )
        host_app = context.get("host_app")
        host_path_value = context.get("host_app_path")
        host_path = Path(host_path_value) if host_path_value else (
            find_app_bundle(host_app) if host_app and host_app.endswith(".app") else None
        )
        if host_path:
            _add_permission_target(
                targets,
                seen,
                host_app,
                host_path,
                "Required when this host app launches remctl or an agent runner.",
            )
        terminal_name = detect_terminal_app_name()
        skip_terminal = (
            terminal_name == "Ghostty.app"
            and host_path is not None
            and host_app
            and host_app != terminal_name
        )
        terminal_path = None if skip_terminal else (find_app_bundle(terminal_name) if terminal_name else None)
        if terminal_path:
            _add_permission_target(
                targets,
                seen,
                terminal_name,
                terminal_path,
                "Alternative target for direct CLI reads from this terminal app.",
            )
    return targets


def full_disk_access_targets():
    specs = full_disk_access_target_specs(include_cli=True)
    targets = [f"{spec['title']}: {spec['path']}" for spec in specs]
    if not any(spec["title"].endswith(".app") for spec in specs):
        terminal_name = detect_terminal_app_name()
        if terminal_name:
            targets.append(f"{terminal_name} (recommended for CLI use)")
        else:
            targets.append("the terminal app that is running remctl (recommended for CLI use)")
    return targets



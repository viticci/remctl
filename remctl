        }, partial_context=partial_context))

    if getattr(a, "assign", None):
        if db is None:
            db = open_db()
        if list_pk is None:
            print("Error: --assign requires a target shared list via -l/--list or --list-id.", file=sys.stderr)
            sys.exit(1)
        assignee = resolve_sharee_or_die(db, list_pk, a.assign)
        originator = resolve_assignment_originator_or_die(db, list_pk)
        results.append(private_action({

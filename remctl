    if getattr(a, "unassign", False):
        results.append(private_action({
            "action": "clear_assignment",
            "id": reminder_ckid,
        }, partial_context=partial_context))

    if getattr(a, "grocery", False):
        if db is None:
            db = open_db()
        if list_pk is None:
            print("Error: --grocery requires a target list.", file=sys.stderr)
            sys.exit(1)
        results.append(apply_private_grocery_categorization(
            db, list_pk, [reminder_ckid], partial_context=partial_context,
        ))

    return results


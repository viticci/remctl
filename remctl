def cmd_add(a):
    title = a.title
    if a.tags:
        for t in a.tags.split(","):
            t = t.strip()
            h = t if t.startswith("#") else f"#{t}"
            if h not in title:
                title += f" {h}"
    pm = {"high": 1, "h": 1, "medium": 5, "med": 5, "m": 5, "low": 9, "l": 9}
    dt = parse_due(a.due)
    if a.due and not dt:
        print(f"Warning: Could not parse due date '{a.due}'. Creating reminder without due date.", file=sys.stderr)

    # Try bridge first
    if bridge_available():
        data = {"action": "create", "title": title}
        if a.list: data["list"] = a.list
        if a.notes: data["notes"] = a.notes
        if dt: data["due"] = dt.isoformat()
        if a.priority and a.priority.lower() in pm:
            data["priority"] = pm[a.priority.lower()]
        if a.flag: data["flagged"] = True
        if hasattr(a, 'url') and a.url: data["url"] = a.url
        if hasattr(a, 'recurrence') and a.recurrence:
            data["recurrence"] = parse_recurrence(a.recurrence)
        if hasattr(a, 'alarm') and a.alarm:
            data["alarm"] = parse_alarm(a.alarm)
        result = bridge_call(data)
        if result and result.get("status") == "created":
            if a.json:
                print(json.dumps({"status": "created", "id": result.get("id", ""), "title": title}))
            else:
                print(f"Created: {title}")
            return

    # Fall back to AppleScript. Warn about fields AppleScript can't express,
    # so users don't silently lose url/recurrence/alarm when the bridge is
    # unavailable.
    dropped = []
    if hasattr(a, 'url') and a.url: dropped.append("url")
    if hasattr(a, 'recurrence') and a.recurrence: dropped.append("recurrence")
    if hasattr(a, 'alarm') and a.alarm: dropped.append("alarm")
    if dropped:
        print(
            f"Warning: bridge unavailable; {', '.join(dropped)} "
            "cannot be set via AppleScript and will be dropped.",
            file=sys.stderr,
        )
    lst = f'tell list "{esc(a.list)}"' if a.list else "tell default list"
    s = f'tell application "Reminders"\n{lst}\nset r to make new reminder with properties {{name:"{esc(title)}"}}\n'
    if a.notes: s += f'set body of r to "{esc(a.notes)}"\n'
    if a.priority and a.priority.lower() in pm:
        s += f"set priority of r to {pm[a.priority.lower()]}\n"
    if a.flag: s += "set flagged of r to true\n"
    if dt: s += as_date_assign(dt) + "\n"
    s += "return id of r\nend tell\nend tell"
    rid = osa(s)
    if a.json:
        print(json.dumps({"status": "created", "id": rid, "title": title}))
    else:
        print(f"Created: {title}")

def _rem_id(r):
    """Build the x-apple-reminder:// ID that AppleScript uses for matching."""
    return f"x-apple-reminder://{r['ZCKIDENTIFIER']}" if r["ZCKIDENTIFIER"] else None

def _bridge_write(action, pk, db, extra=None):
    """Attempt a bridge write operation. Returns True on success."""
    if not bridge_available():
        return False
    r = q_reminder(db, pk)
    if not r or not r["ZCKIDENTIFIER"]:
        return False
    data = {"action": action, "id": r["ZCKIDENTIFIER"]}
    if extra:
        data.update(extra)
    result = bridge_call(data)
    return result is not None and result.get("status") in ("completed", "uncompleted", "deleted", "updated", "flagged", "unflagged")


def _refuse_unsafe_title_fallback(reminder, operation, reason):
    title = reminder["ZTITLE"] or "(untitled)"
    try:
        reminder_id = reminder["Z_PK"]
    except Exception:
        reminder_id = "?"
    print(
        f"Error: {reason}. Refusing unsafe title-based fallback for "
        f"#{reminder_id} ('{title}') while trying to {operation}.",
        file=sys.stderr,
    )
    sys.exit(1)

def cmd_done(a):
    db = open_db()
    r = q_reminder(db, a.id)
    if not r:
        print(f"Error: #{a.id} not found", file=sys.stderr)
        sys.exit(1)

    # Bridge-first for speed (post-2026-04-17 bridge fix: dueDateComponents
    # now reach CloudKit correctly). AppleScript stays as a fallback.
    if bridge_available() and r["ZCKIDENTIFIER"]:
        data = {"action": "complete", "id": r["ZCKIDENTIFIER"]}
        result = bridge_call(data)
        if result and result.get("status") == "completed":
            if a.json:
                print(json.dumps({"status": "completed", "id": a.id, "title": r["ZTITLE"]}))
            else:
                print(f"Completed: {r['ZTITLE']}")
            return

    # AppleScript fallback
    rid = _rem_id(r)
    if rid and osa_by_id_try(r["list_name"], rid, "set completed of r to true"):
        if a.json:
            print(json.dumps({"status": "completed", "id": a.id, "title": r["ZTITLE"]}))
        else:
            print(f"Completed: {r['ZTITLE']}")
        return
    if not rid:
        _refuse_unsafe_title_fallback(r, "complete it", "The reminder has no stable identifier")
    _refuse_unsafe_title_fallback(
        r,
        "complete it",
        "Identifier-based writes failed",
    )


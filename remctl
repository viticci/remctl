def cmd_show(a):
    db = open_db()
    pk = q_list_pk(db, a.list)
    if pk is None:
        print(f"Error: List '{a.list}' not found", file=sys.stderr)
        sys.exit(1)
    items = q_reminders(db, list_pk=pk, completed=a.completed, top_level=True)
    pks = [i["Z_PK"] for i in items]
    sc, ht = preload_extras(db, pks)
    secs = q_sections(db, pk)
    memberships = q_section_memberships(db, pk) if secs else {}
    if a.json:
        print(json.dumps(
            [to_dict(i, db, section=memberships.get(i["ZCKIDENTIFIER"]), _sc=sc, _ht=ht) for i in items],
            indent=2
        ))
        return
    if getattr(a, 'format', None) == 'table':
        print(fmt_table(reminders_to_table_data(items, db)))
        return
    if not items:
        print(f"No {'active ' if not a.completed else ''}reminders in '{a.list}'")
        return
    print(f"{C.bold(color_list_name(a.list, db))}:")
    if secs:
        sec_items, unsectioned = {}, []
        for item in items:
            sn = memberships.get(item["ZCKIDENTIFIER"])
            if sn:
                sec_items.setdefault(sn, []).append(item)
            else:
                unsectioned.append(item)
        for item in unsectioned:
            print(fmt(item, db, verbose=a.verbose, _sc=sc, _ht=ht))
        for sn in [s["ZDISPLAYNAME"] for s in secs]:
            if sn in sec_items:
                print(f"\n  {C.bold(f'[{sn}]')}")
                for item in sec_items[sn]:
                    print(fmt(item, db, verbose=a.verbose, indent="  ", _sc=sc, _ht=ht))
    else:
        for item in items:
            print(fmt(item, db, verbose=a.verbose, _sc=sc, _ht=ht))
    print(f"\n{len(items)} reminder{'s' if len(items) != 1 else ''}")

def cmd_add(a):
    title = a.title
    if a.tags:
        for t in a.tags.split(","):
            t = t.strip()
            h = t if t.startswith("#") else f"#{t}"
            if h not in title:
                title += f" {h}"
    pm = {"high": 1, "h": 1, "medium": 5, "med": 5, "m": 5, "low": 9, "l": 9}
    dt = parse_due(a.due)
    if a.due and not dt:
        print(f"Warning: Could not parse due date '{a.due}'. Creating reminder without due date.", file=sys.stderr)

    # Try bridge first
    if bridge_available():
        data = {"action": "create", "title": title}
        if a.list: data["list"] = a.list
        if a.notes: data["notes"] = a.notes
        if dt: data["due"] = dt.isoformat()
        if a.priority and a.priority.lower() in pm:
            data["priority"] = pm[a.priority.lower()]
        if a.flag: data["flagged"] = True
        if hasattr(a, 'url') and a.url: data["url"] = a.url
        if hasattr(a, 'recurrence') and a.recurrence:
            data["recurrence"] = parse_recurrence(a.recurrence)
        if hasattr(a, 'alarm') and a.alarm:
            data["alarm"] = parse_alarm(a.alarm)
        result = bridge_call(data)
        if result and result.get("status") == "created":
            if a.json:
                print(json.dumps({"status": "created", "id": result.get("id", ""), "title": title}))
            else:
                print(f"Created: {title}")
            return

    # Fall back to AppleScript
    lst = f'tell list "{esc(a.list)}"' if a.list else "tell default list"
    s = f'tell application "Reminders"\n{lst}\nset r to make new reminder with properties {{name:"{esc(title)}"}}\n'
    if a.notes: s += f'set body of r to "{esc(a.notes)}"\n'
    if a.priority and a.priority.lower() in pm:
        s += f"set priority of r to {pm[a.priority.lower()]}\n"
    if a.flag: s += "set flagged of r to true\n"
    if dt: s += f'set due date of r to date "{as_date(dt)}"\n'
    s += "return id of r\nend tell\nend tell"
    rid = osa(s)
    if a.json:
        print(json.dumps({"status": "created", "id": rid, "title": title}))
    else:
        print(f"Created: {title}")

def _rem_id(r):
    """Build the x-apple-reminder:// ID that AppleScript uses for matching."""
    return f"x-apple-reminder://{r['ZCKIDENTIFIER']}" if r["ZCKIDENTIFIER"] else None

def _bridge_write(action, pk, db, extra=None):
    """Attempt a bridge write operation. Returns True on success."""
    if not bridge_available():
        return False
    r = q_reminder(db, pk)
    if not r or not r["ZCKIDENTIFIER"]:
        return False
    data = {"action": action, "id": r["ZCKIDENTIFIER"]}
    if extra:
        data.update(extra)
    result = bridge_call(data)
    return result is not None and result.get("status") in ("completed", "uncompleted", "deleted", "updated", "flagged", "unflagged")

def cmd_done(a):
    db = open_db()
    r = q_reminder(db, a.id)
    if not r:
        print(f"Error: #{a.id} not found", file=sys.stderr)
        sys.exit(1)

    # Try bridge first
    if bridge_available() and r["ZCKIDENTIFIER"]:
        data = {"action": "complete", "id": r["ZCKIDENTIFIER"]}
        result = bridge_call(data)
        if result and result.get("status") == "completed":
            if a.json:
                print(json.dumps({"status": "completed", "id": a.id, "title": r["ZTITLE"]}))
            else:
                print(f"Completed: {r['ZTITLE']}")
            return

    # Fall back to AppleScript
    rid = _rem_id(r)
    if rid:
        osa_by_id(r["list_name"], rid, "set completed of r to true")
    else:
        osa(
            f'tell application "Reminders"\n'
            f'tell list "{esc(r["list_name"])}"\n'
            f'set rs to (every reminder whose name is "{esc(r["ZTITLE"])}" and completed is false)\n'
            f'if (count of rs) > 0 then\n'
            f'set completed of item 1 of rs to true\n'
            f'end if\nend tell\nend tell'
        )
    if a.json:
        print(json.dumps({"status": "completed", "id": a.id, "title": r["ZTITLE"]}))
    else:
        print(f"Completed: {r['ZTITLE']}")


def main():
    p = argparse.ArgumentParser(
        prog="remctl",
        description="Power-user Reminders CLI — reads sections/subtasks/tags/attachments/colors, "
                    "writes via remctl-bridge (EventKit) with AppleScript fallback."
    )
    p.add_argument("--version", action="version", version=VERSION)
    p.add_argument("--no-color", action="store_true", help="Disable color output")
    p.add_argument("--format", choices=["plain", "table", "json"], default="plain",
                   help="Output format (default: plain)")

    sub = p.add_subparsers(dest="cmd")

    def js(c): c.add_argument("--json", action="store_true")
    def vb(c): c.add_argument("-v", "--verbose", action="store_true")

    # --- Existing commands ---
    c = sub.add_parser("lists", help="List all iCloud reminder lists"); js(c)

    c = sub.add_parser("show", help="Show reminders in a list (grouped by section)")
    c.add_argument("list"); c.add_argument("--completed", action="store_true", help="Include completed")
    vb(c); js(c)

    c = sub.add_parser("add", help="Add a reminder (syncs via bridge/AppleScript)")
    c.add_argument("title"); c.add_argument("-l", "--list")
    c.add_argument("-n", "--notes"); c.add_argument("-d", "--due", help="YYYY-MM-DD, today, tomorrow, +3d, eod, eow, 'next friday at 3pm'")
    c.add_argument("-p", "--priority", help="high, medium, low")
    c.add_argument("-f", "--flag", action="store_true")
    c.add_argument("-t", "--tags", help="Comma-separated (inline #hashtags)")
    c.add_argument("--url", help="Set URL field")
    c.add_argument("--recurrence", help="Recurrence: daily, weekly, 'weekly mon,wed,fri', 'monthly 1,15', yearly (bridge only)")
    c.add_argument("--alarm", help="Alarm: 15m, 1h, 1d, or ISO datetime (bridge only)")
    js(c)

    c = sub.add_parser("done", help="Complete a reminder"); c.add_argument("id", type=int); js(c)
    c = sub.add_parser("undone", help="Uncomplete a reminder"); c.add_argument("id", type=int); js(c)

    c = sub.add_parser("edit", help="Edit a reminder")
    c.add_argument("id", type=int); c.add_argument("--title")
    c.add_argument("-n", "--notes"); c.add_argument("-d", "--due", help="YYYY-MM-DD or 'clear'")
    c.add_argument("-p", "--priority")
    c.add_argument("--url", help="Set URL field")
    c.add_argument("--recurrence", help="Recurrence (bridge only)")
    c.add_argument("--alarm", help="Alarm (bridge only)")
    js(c)

    c = sub.add_parser("delete", help="Delete a reminder")
    c.add_argument("id", type=int); c.add_argument("--force", action="store_true"); js(c)

    c = sub.add_parser("search", help="Search reminders")
    c.add_argument("query"); c.add_argument("--completed", action="store_true"); vb(c); js(c)

    c = sub.add_parser("today", help="Due today + overdue")
    c.add_argument("--no-overdue", action="store_true"); vb(c); js(c)

    c = sub.add_parser("flagged", help="Flagged reminders"); vb(c); js(c)

    c = sub.add_parser("tags", help="List all hashtag labels"); js(c)

    c = sub.add_parser("subtasks", help="Show subtasks of a reminder")
    c.add_argument("id", type=int); vb(c); js(c)

    c = sub.add_parser("info", help="Full detail view"); c.add_argument("id", type=int); js(c)

    c = sub.add_parser("sections", help="Show sections across lists"); js(c)

    c = sub.add_parser("stats", help="Statistics"); js(c)

    c = sub.add_parser("link", help="Get deep link(s) for reminders")
    c.add_argument("ids", type=int, nargs="*", help="Reminder IDs")
    c.add_argument("-l", "--list", help="Get links for all active reminders in a list")
    c.add_argument("--completed", action="store_true"); js(c)

    c = sub.add_parser("open", help="Open reminder in Reminders.app (or just open the app)")
    c.add_argument("id", type=int, nargs="?", default=None, help="Reminder ID (opens specific reminder via deep link)")

    # --- New commands ---
    c = sub.add_parser("flag", help="Flag a reminder"); c.add_argument("id", type=int); js(c)
    c = sub.add_parser("unflag", help="Unflag a reminder"); c.add_argument("id", type=int); js(c)

    c = sub.add_parser("upcoming", help="Show reminders due in next N days (default 7)")
    c.add_argument("days", type=int, nargs="?", default=7, help="Number of days to look ahead")
    vb(c); js(c)

    c = sub.add_parser("overdue", help="Show all overdue reminders"); vb(c); js(c)

    c = sub.add_parser("list-create", help="Create a new list (bridge only)")
    c.add_argument("name"); c.add_argument("--color", help="List color name"); js(c)

    c = sub.add_parser("list-rename", help="Rename a list (bridge only)")
    c.add_argument("name"); c.add_argument("new_name"); js(c)

    c = sub.add_parser("list-delete", help="Delete a list (bridge only)")
    c.add_argument("name"); c.add_argument("--force", action="store_true"); js(c)

    c = sub.add_parser("export", help="Export reminders")
    c.add_argument("-l", "--list", help="Export only this list")
    c.add_argument("--format", dest="export_format", choices=["json", "csv"], default="json", help="Export format")
    js(c)

    c = sub.add_parser("import", help="Import reminders from JSON file")
    c.add_argument("file", help="Path to JSON file"); js(c)

    c = sub.add_parser("completion", help="Generate shell completion script")
    c.add_argument("shell", nargs="?", default="zsh", choices=["bash", "zsh", "fish"], help="Shell type")

    # --- Parse ---
    a = p.parse_args()

    # Set up color
    if a.no_color or os.environ.get("NO_COLOR") or not sys.stdout.isatty():
        C.enabled = False

    # Propagate global --format to json flag where needed
    if a.format == "json" and not hasattr(a, 'json'):
        a.json = True
    elif a.format == "json" and hasattr(a, 'json'):
        a.json = True

    # No command: splash screen + today
    if not a.cmd:
        a.no_overdue = False
        a.verbose = False
        if a.format == "json":
            a.json = True
            cmd_today(a)
        else:
            a.json = False
            show_splash()
            cmd_today(a)
        return

    # Propagate --format table to subcommand
    if a.format == "table" and not hasattr(a, 'format_override'):
        pass  # format is already on the namespace

    # Route to command handler
    cmds = {
        "lists": cmd_lists,
        "show": cmd_show,
        "add": cmd_add,
        "done": cmd_done,
        "undone": cmd_undone,
        "edit": cmd_edit,
        "delete": cmd_delete,
        "search": cmd_search,
        "today": cmd_today,
        "flagged": cmd_flagged,
        "tags": cmd_tags,
        "subtasks": cmd_subtasks,
        "info": cmd_info,
        "sections": cmd_sections,
        "stats": cmd_stats,
        "link": cmd_link,
        "open": cmd_open,
        "flag": cmd_flag,
        "unflag": cmd_unflag,
        "upcoming": cmd_upcoming,
        "overdue": cmd_overdue,
        "list-create": cmd_list_create,
        "list-rename": cmd_list_rename,
        "list-delete": cmd_list_delete,
        "export": cmd_export,
        "import": cmd_import,
        "completion": cmd_completion,
    }

    handler = cmds.get(a.cmd)
    if handler:
        handler(a)
    else:
        p.print_help()



def resolve_smart_list_ref(db, name=None, smart_list_id=None):
    rows = q_smart_lists(db)
    if smart_list_id is not None:
        matches = [row for row in rows if row["Z_PK"] == smart_list_id]
        return smart_list_ref_payload(matches[0], requested=str(smart_list_id), method="id") if matches else None

    if not name:
        return None

    exact = [row for row in rows if smart_list_display_name(row) == name]
    if len(exact) == 1:
        return smart_list_ref_payload(exact[0], requested=name, method="exact")
    if len(exact) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [smart_list_ref_payload(row) for row in exact]}

    folded = str(name).casefold()
    ci = [row for row in rows if smart_list_display_name(row).casefold() == folded]
    if len(ci) == 1:
        return smart_list_ref_payload(ci[0], requested=name, method="case_insensitive")
    if len(ci) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [smart_list_ref_payload(row) for row in ci]}

    normalized = normalize_list_lookup_name(name)
    if not normalized:
        return None
    normalized_matches = [
        row for row in rows
        if normalize_list_lookup_name(smart_list_display_name(row)) == normalized
    ]
    if len(normalized_matches) == 1:
        return smart_list_ref_payload(normalized_matches[0], requested=name, method="normalized")
    if len(normalized_matches) > 1:
        return {
            "error": "ambiguous",
            "requested": name,
            "candidates": [smart_list_ref_payload(row) for row in normalized_matches],
        }
    return None



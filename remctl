    print(json.dumps(items, indent=2))


def _print_list_payload(rows, json_mode=False, table_mode=False):
    if json_mode:
        print(json.dumps([{"id": row["id"], "title": row["name"]} for row in rows], indent=2))
        return
    if table_mode:
        data = [{"id": row["id"], "title": row["name"], "list": "", "due": "", "pri": ""} for row in rows]
        print(fmt_table(data))
        return
    print(C.bold("Reminder Lists:"))
    for row in rows:
        list_name = color_list_name(row["name"])
        sec_count = row.get("sectionCount", 0) or 0
        sec_info = C.dim(f" [{sec_count} sections]") if sec_count else ""
        id_dim = C.dim(f"(id: {row['id']})")
        print(f"  {list_name} {id_dim}{sec_info}")
    print(f"\n{len(rows)} list{'s' if len(rows) != 1 else ''}")


def _print_show_payload(list_name, items, args):
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(f"No {'active ' if not args.completed else ''}reminders in '{list_name}'")
        return
    print(f"{C.bold(color_list_name(list_name))}:")
    section_names = [item["section"] for item in items if item.get("section")]
    if section_names:
        sec_items, unsectioned = {}, []
        for item in items:
            section = item.get("section")
            if section:
                sec_items.setdefault(section, []).append(item)
            else:
                unsectioned.append(item)
        for item in unsectioned:
            print(fmt(item, verbose=args.verbose))
        seen = []
        for section in section_names:
            if section not in seen:
                seen.append(section)
        for section in seen:
            print(f"\n  {C.bold(f'[{section}]')}")
            for item in sec_items[section]:
                print(fmt(item, verbose=args.verbose, indent="  "))
    else:
        for item in items:
            print(fmt(item, verbose=args.verbose))
    print(f"\n{len(items)} reminder{'s' if len(items) != 1 else ''}")



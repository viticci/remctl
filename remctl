def zero_reminder_counts():
    return {"active": 0, "completed": 0, "total": 0}


def q_list_reminder_counts(db, list_pks):
    if not list_pks or not table_exists(db, "ZREMCDREMINDER"):
        return {}
    columns = table_column_names(db, "ZREMCDREMINDER")
    if "ZLIST" not in columns:
        return {}
    placeholders = ", ".join("?" for _ in list_pks)
    where = [f"ZLIST IN ({placeholders})"]
    if "ZMARKEDFORDELETION" in columns:
        where.append("ZMARKEDFORDELETION = 0")
    if "ZACCOUNT" in columns:
        where.append("ZACCOUNT IS NOT NULL")
    if "ZPARENTREMINDER" in columns:
        where.append("(ZPARENTREMINDER IS NULL OR ZPARENTREMINDER = 0)")
    completed_expr = "ZCOMPLETED" if "ZCOMPLETED" in columns else "0"
    rows = db.execute(
        "SELECT ZLIST AS list_id, "
        f"SUM(CASE WHEN {completed_expr} = 0 THEN 1 ELSE 0 END) AS active_count, "
        f"SUM(CASE WHEN {completed_expr} = 1 THEN 1 ELSE 0 END) AS completed_count, "
        "COUNT(*) AS total_count "
        "FROM ZREMCDREMINDER "
        f"WHERE {' AND '.join(where)} "
        "GROUP BY ZLIST",
        list(list_pks),
    ).fetchall()
    counts = {}
    for row in rows:
        active = int(_row_get(row, "active_count", 0) or 0)
        completed = int(_row_get(row, "completed_count", 0) or 0)
        total = int(_row_get(row, "total_count", active + completed) or 0)
        counts[_row_get(row, "list_id")] = {
            "active": active,
            "completed": completed,
            "total": total,
        }
    return counts


def attach_group_counts(db, group_payload, child_payloads):
    child_ids = [child["id"] for child in child_payloads]
    counts_by_list = q_list_reminder_counts(db, child_ids)
    totals = zero_reminder_counts()
    for child in child_payloads:
        counts = counts_by_list.get(child["id"], zero_reminder_counts())
        child["counts"] = dict(counts)
        totals["active"] += counts["active"]
        totals["completed"] += counts["completed"]
        totals["total"] += counts["total"]
    group_payload["counts"] = totals
    return group_payload


def list_resolution_from_rows(rows, name, payload_factory):
    exact = [row for row in rows if _row_value(row, "ZNAME") == name]
    if len(exact) == 1:
        return payload_factory(exact[0], requested=name, method="exact")
    if len(exact) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [payload_factory(row) for row in exact]}

    folded = str(name).casefold()
    ci = [row for row in rows if str(_row_value(row, "ZNAME")).casefold() == folded]
    if len(ci) == 1:
        return payload_factory(ci[0], requested=name, method="case_insensitive")
    if len(ci) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [payload_factory(row) for row in ci]}

    normalized = normalize_list_lookup_name(name)
    if not normalized:
        return None
    normalized_matches = [
        row for row in rows
        if normalize_list_lookup_name(_row_value(row, "ZNAME")) == normalized
    ]
    if len(normalized_matches) == 1:
        return payload_factory(normalized_matches[0], requested=name, method="normalized")
    if len(normalized_matches) > 1:
        return {
            "error": "ambiguous",
            "requested": name,
            "candidates": [payload_factory(row) for row in normalized_matches],
        }
    return None


def ckid_eq(a, b):
    if not a or not b:
        return False
    return str(a).casefold() == str(b).casefold()


def sharee_to_dict(row, *, current_user_ckid=None):
    payload = {
        "id": _row_get(row, "Z_PK"),
        "objectUUID": _row_get(row, "ZCKIDENTIFIER"),
        "name": _sharee_display_name(row),
    }
    for source_key, output_key in (
        ("ZDISPLAYNAME", "displayName"),
        ("ZFIRSTNAME", "firstName"),
        ("ZLASTNAME", "lastName"),
        ("ZADDRESS1", "address"),
    ):
        value = _row_get(row, source_key)
        if value:
            payload[output_key] = value
    if _row_get(row, "ZSTATUS") is not None:
        payload["status"] = _row_get(row, "ZSTATUS")
    if _row_get(row, "ZACCESSLEVEL") is not None:
        payload["accessLevel"] = _row_get(row, "ZACCESSLEVEL")
    if ckid_eq(payload.get("objectUUID"), current_user_ckid):
        payload["currentUser"] = True
    return payload


def _sharee_match_terms(row):
    terms = [
        _row_get(row, "ZCKIDENTIFIER"),
        _row_get(row, "ZDISPLAYNAME"),
        _row_get(row, "ZFIRSTNAME"),
        _row_get(row, "ZLASTNAME"),
        _sharee_display_name(row),
        _row_get(row, "ZADDRESS1"),
    ]
    address = _row_get(row, "ZADDRESS1")
    if address and ":" in address:
        terms.append(address.split(":", 1)[1])
    return [term for term in terms if term]


def resolve_sharee_or_die(db, list_pk, value, *, allow_me=True):
    sharees = q_sharees(db, list_pk)
    if not sharees:
        print("Error: target list has no sharees; assignment requires a shared list.", file=sys.stderr)
        sys.exit(1)
    current_user_ckid = q_list_shared_owner_ckid(db, list_pk)
    raw = str(value or "").strip()
    if not raw:
        print("Error: --assign requires a name, email, phone number, or sharee ID.", file=sys.stderr)
        sys.exit(1)
    if allow_me and raw.casefold() in {"me", "myself"}:
        if not current_user_ckid:
            print("Error: could not identify the current-user sharee for this list.", file=sys.stderr)
            sys.exit(1)
        for sharee in sharees:
            if ckid_eq(_row_get(sharee, "ZCKIDENTIFIER"), current_user_ckid):
                return sharee
        print("Error: current-user sharee is not present in this list.", file=sys.stderr)
        sys.exit(1)

    needle = normalize_list_lookup_name(raw)
    exact = []
    contains = []
    for sharee in sharees:
        if str(_row_get(sharee, "Z_PK")) == raw:
            exact.append(sharee)
            continue
        for term in _sharee_match_terms(sharee):
            normalized = normalize_list_lookup_name(term)
            if normalized == needle:
                exact.append(sharee)
                break
            if needle and needle in normalized:
                contains.append(sharee)
                break
    matches = exact or contains
    unique = []
    seen = set()
    for sharee in matches:
        pk = _row_get(sharee, "Z_PK")
        if pk not in seen:
            unique.append(sharee)
            seen.add(pk)
    if len(unique) == 1:
        return unique[0]

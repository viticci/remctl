RECURRENCE_DAY_NAMES = {
    1: "Sun",
    2: "Mon",
    3: "Tue",
    4: "Wed",
    5: "Thu",
    6: "Fri",
    7: "Sat",
}


def _recurrence_from_item(item):
    if _item_has(item, "recurrence"):
        return _item_get(item, "recurrence")
    return recurrence_from_row(item, ts=ts)


def recurrence_summary(recurrence):
    if not recurrence:
        return ""
    frequency = recurrence.get("frequency")
    interval = int(recurrence.get("interval") or 1)
    units = {
        "daily": ("day", "days"),
        "weekly": ("week", "weeks"),
        "monthly": ("month", "months"),
        "yearly": ("year", "years"),
    }
    if frequency not in units:
        return ""
    singular, plural = units[frequency]
    if interval == 1:
        label = frequency
    else:
        label = f"every {interval} {plural}"

    days = recurrence.get("daysOfWeek") or []
    if frequency == "weekly" and days:
        names = [RECURRENCE_DAY_NAMES.get(int(day), str(day)) for day in days]
        label += " " + ", ".join(names)

    days_of_month = recurrence.get("daysOfMonth") or []
    if frequency == "monthly" and days_of_month:
        label += " on " + ", ".join(str(day) for day in days_of_month)

    count = recurrence.get("count")
    if count:
        label += f" x{count}"
    elif recurrence.get("endDate"):
        label += f" until {str(recurrence['endDate'])[:10]}"

    return label


def recurrence_badge(item):
    summary = recurrence_summary(_recurrence_from_item(item))
    return C.magenta(f"↻ {summary}") if summary else ""


def fmt(r, db=None, verbose=False, indent="", _sc=None, _ht=None):
    completed = r["ZCOMPLETED"] if _item_has(r, "ZCOMPLETED") else bool(_item_get(r, "completed"))
    if completed:
        status = C.green("[x]")
    else:
        status = C.dim("[ ]")
    markers = _state_markers(r)
    marker_str = f" {markers}" if markers else ""
    pri_val = _priority_value_from_item(r)
    sc = _subtask_count_from_item(r, db=db, _sc=_sc)
    tags = _tags_from_item(r, db=db, _ht=_ht)
    tag_str = " " + " ".join(f"#{t}" for t in tags) if tags else ""
    sub_str = f" [{sc} subtask{'s' if sc != 1 else ''}]" if sc > 0 else ""
    pri_str = f" {_color_priority(pri_val)}" if PRI.get(pri_val, "") else ""
    id_str = reminder_id_from_item(r, db)
    title = (r["ZTITLE"] if _item_has(r, "ZTITLE") else _item_get(r, "title")) or "(untitled)"
    due_str = fmt_due(r["ZDUEDATE"] if _item_has(r, "ZDUEDATE") else _item_get(r, "dueDate"))
    repeat_badge = recurrence_badge(r)
    recur_str = f" {repeat_badge}" if repeat_badge else ""
    if completed:
        title = C.dim(C.strikethrough(title))
        due_str = C.dim(due_str)
        recur_str = C.dim(recur_str)
        tag_str = C.dim(tag_str)
        sub_str = C.dim(sub_str)
    parts = [f"{indent}{status} {id_str}{pri_str}{marker_str} {title}{due_str}{recur_str}{tag_str}{sub_str}"]
    if verbose:
        list_name = _list_name_from_item(r)
        if list_name:
            parts.append(f"{indent}    List: {color_list_name(list_name, db)}")
        notes = r["ZNOTES"] if _item_has(r, "ZNOTES") else _item_get(r, "notes")
        if notes:
            parts.append(f"{indent}    Notes: {C.dim(str(notes)[:200])}")
        url = _url_from_item(r)
        if url:
            parts.append(f"{indent}    URL: {C.dim(url)}")
        recurrence = recurrence_summary(_recurrence_from_item(r))
        if recurrence:
            parts.append(f"{indent}    Repeats: {C.magenta(recurrence)}")
        if _item_is_flagged(r):
            parts.append(f"{indent}    Flagged: {C.yellow('Yes')}")
        if _item_is_urgent(r):
            parts.append(f"{indent}    Urgent: {C.red('Yes')}")
    return "\n".join(parts)


def _smart_list_csv_values(*values):
    result = []
    for value in values:
        if value is None:
            continue
        if isinstance(value, list):
            for item in value:
                result.extend(split_csv(item))
        else:
            result.extend(split_csv(value))
    return result

def _load_smart_list_filter_json(value):
    if not value:
        return None
    source = str(value)
    if source.startswith("@"):
        try:
            source = Path(source[1:]).read_text()
        except OSError as exc:
            raise SmartListFilterError(f"Could not read filter JSON file: {exc}") from exc
    try:
        payload = json.loads(source)
    except json.JSONDecodeError as exc:
        raise SmartListFilterError(f"Invalid filter JSON: {exc}") from exc
    if not isinstance(payload, dict):
        raise SmartListFilterError("Smart list filter JSON must be an object.")
    return payload

def _resolve_smart_list_filter_list_ids(db, names, ids):
    resolved = []
    for list_id in ids or []:
        ref = resolve_list_or_die(db, list_id=list_id)
        if not ref.get("objectUUID"):
            print(f"Error: list id {list_id} has no object UUID.", file=sys.stderr)
            sys.exit(1)
        resolved.append(ref["objectUUID"])
    for name in names or []:
        ref = resolve_list_or_die(db, name=name)
        if not ref.get("objectUUID"):
            print(f"Error: list {name!r} has no object UUID.", file=sys.stderr)
            sys.exit(1)
        resolved.append(ref["objectUUID"])
    return resolved


def validate_materializing_smart_list_args(a):
    if getattr(a, "filter_json", None):
        return
    if bool(getattr(a, "untagged", False)):
        raise SmartListFilterError("Untagged smart-list writes do not materialize reliably in Reminders.app.")
    if getattr(a, "date", None) == "no-date":
        raise SmartListFilterError("No-date smart-list writes do not materialize reliably in Reminders.app.")
    if getattr(a, "date_relative", None):
        raise SmartListFilterError("Relative-date smart-list writes do not materialize reliably in Reminders.app.")
    if getattr(a, "time", None) == "no-time":
        raise SmartListFilterError("No-time smart-list writes do not materialize reliably in Reminders.app.")
    if getattr(a, "vehicle", None) == "disconnected":
        raise SmartListFilterError("Vehicle-disconnected smart-list writes do not materialize reliably in Reminders.app.")

    include_count = len(_smart_list_csv_values(getattr(a, "include_list", None))) + len(getattr(a, "include_list_id", None) or [])
    exclude_count = len(_smart_list_csv_values(getattr(a, "exclude_list", None))) + len(getattr(a, "exclude_list_id", None) or [])
    if exclude_count:
        raise SmartListFilterError("List exclusion filters do not materialize reliably in Reminders.app.")
    if include_count > 1:
        raise SmartListFilterError("Reminders.app only materializes one included-list filter at a time.")
    if include_count and getattr(a, "list_match", None):
        raise SmartListFilterError("Do not pass --list-match with a single included list.")


def smart_list_filter_payload_from_args(a, db):
    raw_payload = _load_smart_list_filter_json(getattr(a, "filter_json", None))
    if raw_payload is not None:
        return raw_payload
    validate_materializing_smart_list_args(a)
    location = None
    if getattr(a, "location_title", None) or getattr(a, "latitude", None) is not None or getattr(a, "longitude", None) is not None:
        location = {
            "title": a.location_title,
            "latitude": a.latitude,
            "longitude": a.longitude,
            "radius": getattr(a, "radius", 100.0),
            "proximity": getattr(a, "proximity", "enter"),
        }
    return build_supported_filter_payload(
        match=getattr(a, "match", None) or "all",
        flagged=bool(getattr(a, "flagged", False)),
        priorities=_smart_list_csv_values(getattr(a, "priority", None)),
        tags=_smart_list_csv_values(getattr(a, "tags", None)),
        tag_match=getattr(a, "tag_match", None) or "any",
        any_tag=bool(getattr(a, "any_tag", False)),
        untagged=bool(getattr(a, "untagged", False)),
        date_any=getattr(a, "date", None) == "any",
        date_today=getattr(a, "date", None) == "today",
        date_today_include_past_due=bool(getattr(a, "date_today_include_past_due", False)),
        date_no_date=getattr(a, "date", None) == "no-date",
        date_on=getattr(a, "date_on", None),
        date_before=getattr(a, "date_before", None),
        date_after=getattr(a, "date_after", None),
        date_range=getattr(a, "date_range", None),
        date_relative=getattr(a, "date_relative", None),
        time_filter=getattr(a, "time", None),
        include_list_ids=_resolve_smart_list_filter_list_ids(
            db,
            _smart_list_csv_values(getattr(a, "include_list", None)),
            getattr(a, "include_list_id", None),
        ),
        exclude_list_ids=_resolve_smart_list_filter_list_ids(
            db,
            _smart_list_csv_values(getattr(a, "exclude_list", None)),
            getattr(a, "exclude_list_id", None),
        ),
        list_match=getattr(a, "list_match", None),
        vehicle=getattr(a, "vehicle", None),
        location=location,
    )

def smart_list_filter_changes_from_args(a):
    if getattr(a, "filter_json", None):
        return True
    if bool(getattr(a, "flagged", False)):
        return True
    if bool(getattr(a, "any_tag", False)) or bool(getattr(a, "untagged", False)):
        return True
    if bool(getattr(a, "date_today_include_past_due", False)):
        return True
    for name in (
        "priority",
        "tags",
        "date",
        "date_on",
        "date_before",
        "date_after",
        "date_range",
        "date_relative",
        "time",
        "include_list",
        "exclude_list",
        "include_list_id",
        "exclude_list_id",
        "vehicle",
        "location_title",
        "latitude",
        "longitude",
    ):
        value = getattr(a, name, None)
        if value not in (None, "", []):
            return True
    return False


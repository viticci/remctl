def resolve_list_ref(db, name=None, list_id=None, *, allow_groups=False):
    if list_id is not None:
        columns = list_select_columns(db)
        row = db.execute(
            f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
            "WHERE Z_PK = ? AND ZMARKEDFORDELETION = 0 AND Z_ENT = 3 "
            "AND ZNAME IS NOT NULL AND ZNAME != ''",
            (list_id,),
        ).fetchone()
        if not row:
            return None
        if is_group_list_row(row):
            if allow_groups:
                return list_group_ref_payload(db, row, requested=str(list_id), method="id")
            return {
                "error": "group",
                "requested": str(list_id),
                "group": list_group_ref_payload(db, row, requested=str(list_id), method="id"),
            }
        return list_ref_payload(row, requested=str(list_id), method="id")

    if not name:
        return None

    result = list_resolution_from_rows(q_lists(db), name, list_ref_payload)
    if result:
        return result
    group_result = list_resolution_from_rows(
        q_list_groups(db),
        name,
        lambda row, **kwargs: list_group_ref_payload(db, row, **kwargs),
    )
    if group_result:
        if allow_groups or group_result.get("error"):
            return group_result
        return {
            "error": "group",
            "requested": name,
            "group": group_result,
        }
    return None

def _print_list_resolution_error(requested, result=None):
    if result and result.get("error") == "ambiguous":
        options = ", ".join(
            f"{candidate['id']} ({candidate['title']})"
            for candidate in result.get("candidates", [])
        )
        print(
            f"Error: multiple lists match {requested!r}. Use the exact list name or --list-id with one of: {options}",
            file=sys.stderr,
        )
    elif result and result.get("error") == "group":
        group = result.get("group", {})
        title = group.get("title") or requested
        children = group.get("children") or []
        if children:
            options = ", ".join(f"{child['title']} (id {child['id']})" for child in children)
            print(
                f"Error: {title!r} is a Reminders list group, not a writable list. Use one of its child lists: {options}",
                file=sys.stderr,
            )
        else:
            print(
                f"Error: {title!r} is a Reminders list group, not a writable list.",
                file=sys.stderr,
            )
    else:
        print(f"Error: list not found: {requested}", file=sys.stderr)


def database_access_check_for_onboarding(api_check=None):
    access_error = reminders_store_access_error()
    db_path = find_main_db_path()
    api_healthy = bool(api_check and api_check["status"] == "ok")
    if access_error:
        if api_healthy:
            return check_result(
                "database",
                "warn",
                (
                    f"{access_error} Direct SQLite reads are blocked in this shell, "
                    "but the local remctl service fallback is healthy."
                ),
                full_disk_access_fix_text(api_healthy=True, rerun_command="remctl doctor"),
            )
        return check_result(
            "database",
            "fail",
            access_error,
            full_disk_access_fix_text(api_healthy=False, rerun_command="remctl doctor"),

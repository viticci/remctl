                details.append(f"color={normalize_list_color(a.color)}")
            if getattr(a, "symbol", None):
                details.append(f"symbol={a.symbol}")
            if getattr(a, "emoji", None):
                details.append(f"emoji={a.emoji}")
            if getattr(a, "groceries", False):
                details.append(f"groceries locale={normalize_grocery_locale(getattr(a, 'grocery_locale', None)) or DEFAULT_GROCERY_LOCALE_ID}")
            if details:
                print(f"Applied private metadata: {', '.join(details)}")
        return
    data = {"action": "create_list", "title": a.name}
    if hasattr(a, 'color') and a.color and is_supported_public_list_color(a.color):
        data["color"] = a.color
    result = bridge_call(data) if bridge_available() else None
    if not result or result.get("status") != "created":

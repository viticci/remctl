def cmd_import(a):
    filepath = Path(a.file)
    if not filepath.exists():
        print(f"Error: File '{a.file}' not found", file=sys.stderr)
        sys.exit(1)
    try:
        with open(filepath) as f:
            data = json.load(f)
    except (json.JSONDecodeError, IOError) as e:
        print(f"Error: Failed to read JSON: {e}", file=sys.stderr)
        sys.exit(1)

    if not isinstance(data, list):
        print("Error: JSON must be an array of reminder objects", file=sys.stderr)
        sys.exit(1)

    created = 0
    errors = 0
    for item in data:
        title = item.get("title")
        if not title:
            print("Warning: Skipping item without title", file=sys.stderr)
            errors += 1
            continue

        # Build a namespace that looks like cmd_add's args
        class AddArgs:
            pass
        aa = AddArgs()
        aa.title = title
        aa.list = item.get("list")
        aa.notes = item.get("notes")
        aa.due = item.get("due") or item.get("dueDate")
        aa.priority = item.get("priority")
        aa.flag = item.get("flagged", False)
        aa.tags = None
        aa.url = item.get("url")
        aa.recurrence = item.get("recurrence")
        aa.alarm = item.get("alarm")
        aa.json = False

        try:
            cmd_add(aa)
            created += 1
        except SystemExit:
            errors += 1

    summary = {"created": created, "errors": errors, "total": len(data)}
    if getattr(a, 'json', False):
        print(json.dumps(summary))
    else:
        print(f"\nImported {created}/{len(data)} reminders ({errors} errors)")


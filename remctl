def q_template_matches(db, name=None, template_id=None):
    columns = template_select_columns(db)
    base_select = (
        f"SELECT {', '.join(columns)}, "
        "(SELECT COUNT(*) FROM ZREMCDSAVEDREMINDER sr WHERE sr.ZTEMPLATE = ZREMCDTEMPLATE.Z_PK AND sr.ZMARKEDFORDELETION = 0) AS item_count, "
        "(SELECT COUNT(*) FROM ZREMCDBASESECTION s WHERE s.ZTEMPLATE = ZREMCDTEMPLATE.Z_PK AND s.ZMARKEDFORDELETION = 0) AS section_count "
        "FROM ZREMCDTEMPLATE "
    )
    if template_id is not None:
        return db.execute(
            base_select + "WHERE ZMARKEDFORDELETION = 0 AND Z_PK = ?",
            (template_id,),
        ).fetchall()
    return db.execute(
        base_select + "WHERE ZMARKEDFORDELETION = 0 AND ZNAME = ? ORDER BY Z_PK",
        (name,),
    ).fetchall()



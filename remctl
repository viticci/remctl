def cmd_show(a):
    db = open_db()
    list_ref = resolve_required_list_target_or_die(
        db,
        name=getattr(a, "list", None),
        list_id=getattr(a, "list_id", None),
    )
    pk = list_ref["id"]
    list_name = list_ref["title"]
    items = q_reminders(db, list_pk=pk, completed=a.completed, top_level=True)
    pks = [i["Z_PK"] for i in items]
    sc, ht = preload_extras(db, pks)
    secs = q_sections(db, pk)
    memberships = q_section_memberships(db, pk) if secs else {}
    if a.json:
        print(json.dumps(
            [to_dict(i, db, section=memberships.get(i["ZCKIDENTIFIER"]), _sc=sc, _ht=ht) for i in items],
            indent=2
        ))
        return
    if getattr(a, 'format', None) == 'table':
        print(fmt_table(reminders_to_table_data(items, db)))
        return
    if not items:
        print(f"No {'active ' if not a.completed else ''}reminders in '{list_name}'")
        return
    list_heading = color_list_name(list_name, db)
    if list_ref.get("isGroceries"):
        list_heading = f"{list_heading} {GROCERY_LIST_MARKER}"
    print(f"{C.bold(list_heading)}:")
    if secs:
        sec_items, unsectioned = {}, []
        for item in items:
            sn = memberships.get(item["ZCKIDENTIFIER"])
            if sn:
                sec_items.setdefault(sn, []).append(item)
            else:
                unsectioned.append(item)
        for item in unsectioned:
            print(fmt(item, db, verbose=a.verbose, _sc=sc, _ht=ht))
        for sn in [s["ZDISPLAYNAME"] for s in secs]:
            if sn in sec_items:
                print(f"\n  {C.bold(f'[{sn}]')}")
                for item in sec_items[sn]:
                    print(fmt(item, db, verbose=a.verbose, indent="  ", _sc=sc, _ht=ht))

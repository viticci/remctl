def _eventkit_read_error(message, a=None, *, code="eventkit_read_unsupported", exit_code=2):
    json_mode = bool(getattr(a, "json", False)) if a is not None else False
    if json_mode:
        print(json.dumps({
            "status": "error",
            "code": code,
            "message": message,
            "source": "eventkit",
            "fidelity": "limited",
            "idWarning": EVENTKIT_READ_ID_WARNING,
        }), file=sys.stderr)
    else:
        print(f"Error: {message}", file=sys.stderr)
        print(f"EventKit fallback note: {EVENTKIT_READ_ID_WARNING}", file=sys.stderr)
    sys.exit(exit_code)


def validate_eventkit_read_args(a, *, allow_list=False):
    if getattr(a, "list_id", None) is not None:
        _eventkit_read_error(
            "--via-eventkit cannot use RemCTL numeric list ids. Pass a list name instead.",
            a,
        )
    if getattr(a, "format", None) == "table":
        _eventkit_read_error(
            "--via-eventkit does not support table output because EventKit ids are long and non-chainable. Use plain or JSON output.",
            a,
        )
    if allow_list and not getattr(a, "list", None):
        _eventkit_read_error("--via-eventkit show requires a list name.", a)


def limited_eventkit_read(mode, a, **extra):
    if not bridge_available():
        _eventkit_read_error("remctl-bridge is required for --via-eventkit reads.", a, code="bridge_unavailable", exit_code=1)
    data = {
        "action": "read",
        "readMode": mode,
        "limit": 500,
    }
    data.update(extra)
    result = bridge_call(data)
    if not result or result.get("status") != "ok":
        message = (result or {}).get("message") if isinstance(result, dict) else None
        _eventkit_read_error(message or "EventKit read failed.", a, code="eventkit_read_failed", exit_code=1)
    items = []
    for item in result.get("items") or []:
        if not isinstance(item, dict):
            continue
        sanitized = {key: item[key] for key in EVENTKIT_ITEM_KEYS if key in item}
        sanitized.pop("id", None)
        items.append(sanitized)
    return {
        "source": "eventkit",
        "fidelity": "limited",
        "mode": mode,
        "idWarning": EVENTKIT_READ_ID_WARNING,
        "limitations": EVENTKIT_READ_LIMITATIONS,
        "items": items,
    }



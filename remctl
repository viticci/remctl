def cmd_edit(a):
    db = open_db()
    r = q_reminder(db, a.id)
    if not r:
        print(f"Error: #{a.id} not found", file=sys.stderr)
        sys.exit(1)

    # Try bridge first
    if bridge_available() and r["ZCKIDENTIFIER"]:
        data = {"action": "update", "id": r["ZCKIDENTIFIER"]}
        has_changes = False
        if a.title: data["title"] = a.title; has_changes = True
        if a.notes: data["notes"] = a.notes; has_changes = True
        pm = {"high": 1, "medium": 5, "low": 9, "none": 0}
        if a.priority and a.priority.lower() in pm:
            data["priority"] = pm[a.priority.lower()]; has_changes = True
        if a.due == "clear":
            data["due"] = None; has_changes = True
        elif a.due:
            dt = parse_due(a.due)
            if dt: data["due"] = dt.isoformat(); has_changes = True
        if hasattr(a, 'url') and a.url:
            data["url"] = a.url; has_changes = True
        if hasattr(a, 'recurrence') and a.recurrence:
            data["recurrence"] = parse_recurrence(a.recurrence); has_changes = True
        if hasattr(a, 'alarm') and a.alarm:
            data["alarm"] = parse_alarm(a.alarm); has_changes = True
        if has_changes:
            result = bridge_call(data)
            if result and result.get("status") == "updated":
                if a.json:
                    print(json.dumps({"status": "updated", "id": a.id}))
                else:
                    print(f"Updated #{a.id}")
                return

    # Fall back to AppleScript
    parts = []
    if a.title: parts.append(f'set name of r to "{esc(a.title)}"')
    if a.notes: parts.append(f'set body of r to "{esc(a.notes)}"')
    pm = {"high": 1, "medium": 5, "low": 9, "none": 0}
    if a.priority and a.priority.lower() in pm:
        parts.append(f"set priority of r to {pm[a.priority.lower()]}")
    if a.due == "clear":
        parts.append("set due date of r to missing value")
    elif a.due:
        dt = parse_due(a.due)
        if dt: parts.append(f'set due date of r to date "{as_date(dt)}"')
    if not parts:
        print("Nothing to update.")
        return
    rid = _rem_id(r)
    if rid:
        osa_by_id(r["list_name"], rid, chr(10).join(parts))
    else:
        osa(
            f'tell application "Reminders"\n'
            f'tell list "{esc(r["list_name"])}"\n'
            f'set rs to (every reminder whose name is "{esc(r["ZTITLE"])}")\n'
            f'if (count of rs) > 0 then\n'
            f'set r to item 1 of rs\n'
            f'{chr(10).join(parts)}\n'
            f'end if\nend tell\nend tell'
        )
    if a.json:
        print(json.dumps({"status": "updated", "id": a.id}))
    else:
        print(f"Updated #{a.id}")


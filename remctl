def load_onboard_state():
    if not ONBOARD_STATE_FILE.exists():
        return None
    try:
        data = json.loads(ONBOARD_STATE_FILE.read_text())
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def write_onboard_state(result, *, auto=False):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    ONBOARD_STATE_FILE.write_text(json.dumps({
        "version": VERSION,
        "seenAt": datetime.now().isoformat(timespec="seconds"),

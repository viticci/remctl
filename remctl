# ── Database ─────────────────────────────────────────────────────────────────

def find_main_db():
    candidates = sorted(STORE_DIR.glob("Data-*.sqlite"), key=lambda p: p.stat().st_size, reverse=True)
    if not candidates:
        print("Error: No Reminders database found. Is iCloud Reminders enabled?", file=sys.stderr)
        sys.exit(1)
    return candidates[0]

def open_db():
    conn = sqlite3.connect(f"file:{find_main_db()}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row
    return conn

def ts(v):
    if not v: return None
    return datetime.fromtimestamp(v + APPLE_EPOCH)

def to_ts(dt):
    return dt.timestamp() - APPLE_EPOCH

PRI = {0: "", 1: "!!!", 5: "!!", 9: "!"}
PRI_NAME = {0: "none", 1: "high", 5: "medium", 9: "low"}

# ── List Color Parsing ───────────────────────────────────────────────────────

LIST_COLOR_MAP = {
    "red": (255, 41, 104),
    "orange": (255, 149, 0),
    "yellow": (255, 204, 0),
    "green": (99, 218, 56),
    "blue": (0, 122, 255),
    "purple": (204, 115, 225),
    "brown": (162, 132, 94),
    "cyan": (90, 200, 250),
    "teal": (48, 176, 199),
}

def parse_list_color(blob):
    """Extract color info from ZCOLOR binary plist (NSKeyedArchiver)."""
    if not blob:
        return {"name": "blue", "hex": "#007AFF"}
    try:
        data = plistlib.loads(bytes(blob))
        objects = data.get("$objects", [])
        for obj in objects:
            if isinstance(obj, dict) and "ckSymbolicColorName" in obj:
                name_uid = obj["ckSymbolicColorName"]
                hex_uid = obj.get("daHexString")
                name = objects[name_uid.data] if hasattr(name_uid, 'data') else str(name_uid)
                hex_str = objects[hex_uid.data] if hex_uid and hasattr(hex_uid, 'data') else ""
                return {"name": name, "hex": hex_str}
    except Exception:
        pass
    return {"name": "blue", "hex": "#007AFF"}

def load_list_colors(db):
    """Load all list colors into a dict {list_name: (r, g, b)}."""
    colors = {}
    try:
        rows = db.execute(
            "SELECT ZNAME, ZCOLOR FROM ZREMCDBASELIST "
            "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL"
        ).fetchall()
        for r in rows:
            info = parse_list_color(r["ZCOLOR"])
            rgb = LIST_COLOR_MAP.get(info["name"], (0, 122, 255))
            colors[r["ZNAME"]] = rgb
    except Exception:
        pass
    return colors

# Global list color cache — populated on demand
_list_colors = None

def get_list_colors(db):
    global _list_colors
    if _list_colors is None:
        _list_colors = load_list_colors(db)
    return _list_colors

def color_list_name(name, db=None):
    """Return the list name colored by its Reminders color."""
    if not name or not C.enabled:
        return name or "(none)"
    if db:
        colors = get_list_colors(db)
        if name in colors:
            r, g, b = colors[name]
            return C.rgb(r, g, b, name)
    return C.cyan(name)

# ── Queries ──────────────────────────────────────────────────────────────────

def q_lists(db):
    return db.execute(
        "SELECT Z_PK, ZNAME FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL AND ZNAME != '' "
        "ORDER BY ZNAME"
    ).fetchall()

def q_list_pk(db, name):
    r = db.execute(
        "SELECT Z_PK FROM ZREMCDBASELIST WHERE ZNAME = ? COLLATE NOCASE AND ZMARKEDFORDELETION = 0 LIMIT 1", (name,)
    ).fetchone()
    return r[0] if r else None

_REM_COLS = """r.Z_PK, r.ZTITLE, r.ZNOTES, r.ZCOMPLETED, r.ZFLAGGED, r.ZPRIORITY,
    r.ZDUEDATE, r.ZALLDAY, r.ZCOMPLETIONDATE, r.ZCREATIONDATE,
    r.ZPARENTREMINDER, r.ZLIST, r.ZICSURL, r.ZCKIDENTIFIER, l.ZNAME as list_name"""

def q_reminders(db, list_pk=None, completed=False, parent_pk=None, top_level=False, limit=500):
    c, params = ["r.ZMARKEDFORDELETION = 0"], []
    if not completed: c.append("r.ZCOMPLETED = 0")
    if list_pk is not None: c.append("r.ZLIST = ?"); params.append(list_pk)
    if parent_pk is not None: c.append("r.ZPARENTREMINDER = ?"); params.append(parent_pk)
    elif top_level: c.append("(r.ZPARENTREMINDER IS NULL OR r.ZPARENTREMINDER = 0)")
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK LIMIT ?",
        params + [limit]
    ).fetchall()

def q_reminder(db, pk):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.Z_PK = ?", (pk,)
    ).fetchone()

def q_subtask_count(db, pk):
    return db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER WHERE ZPARENTREMINDER = ? "
        "AND ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0", (pk,)
    ).fetchone()[0]

def q_sections(db, list_pk=None):
    if list_pk:
        return db.execute(
            "SELECT Z_PK, ZDISPLAYNAME, ZLIST FROM ZREMCDBASESECTION "
            "WHERE ZMARKEDFORDELETION = 0 AND ZLIST = ? ORDER BY Z_PK", (list_pk,)
        ).fetchall()
    return db.execute(
        "SELECT s.Z_PK, s.ZDISPLAYNAME, s.ZLIST, l.ZNAME as list_name FROM ZREMCDBASESECTION s "
        "LEFT JOIN ZREMCDBASELIST l ON s.ZLIST = l.Z_PK "
        "WHERE s.ZMARKEDFORDELETION = 0 ORDER BY l.ZNAME, s.Z_PK"
    ).fetchall()

def q_section_memberships(db, list_pk):
    row = db.execute(
        "SELECT ZMEMBERSHIPSOFREMINDERSINSECTIONSASDATA FROM ZREMCDBASELIST WHERE Z_PK = ?",
        (list_pk,)
    ).fetchone()
    if not row or not row[0]: return {}
    try:
        data = json.loads(row[0])
    except (json.JSONDecodeError, TypeError):
        return {}
    sections = db.execute(
        "SELECT ZCKIDENTIFIER, ZDISPLAYNAME FROM ZREMCDBASESECTION "
        "WHERE ZLIST = ? AND ZMARKEDFORDELETION = 0", (list_pk,)
    ).fetchall()
    g2n = {s["ZCKIDENTIFIER"]: s["ZDISPLAYNAME"] for s in sections}
    return {
        m["memberID"]: g2n[m["groupID"]]
        for m in data.get("memberships", [])
        if m.get("groupID") in g2n and m.get("memberID")
    }

def q_attachments(db, pk):
    return db.execute(
        "SELECT ZFILENAME, ZUTI, ZATTACHMENTTYPERAWVALUE FROM ZREMCDSAVEDATTACHMENT "
        "WHERE ZREMINDER = ? AND ZMARKEDFORDELETION = 0", (pk,)
    ).fetchall()

def q_hashtags(db, pk):
    return db.execute(
        "SELECT h.ZNAME FROM ZREMCDOBJECT o JOIN ZREMCDHASHTAGLABEL h "
        "ON o.ZHASHTAGLABEL = h.Z_PK WHERE o.ZREMINDER3 = ?", (pk,)
    ).fetchall()

def q_search(db, query, completed=False):
    c = ["r.ZMARKEDFORDELETION = 0", "l.Z_PK IS NOT NULL", "(r.ZTITLE LIKE ? OR r.ZNOTES LIKE ?)"]
    if not completed: c.append("r.ZCOMPLETED = 0")
    pat = f"%{query}%"
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK DESC LIMIT 100",
        (pat, pat)
    ).fetchall()

def q_due_today(db, include_overdue=True):
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    eod = sod + timedelta(days=1)
    if include_overdue:
        w = f"r.ZDUEDATE < {to_ts(eod)} AND r.ZDUEDATE IS NOT NULL"
    else:
        w = f"r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(eod)}"
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 "
        f"AND l.Z_PK IS NOT NULL AND {w} ORDER BY r.ZDUEDATE"
    ).fetchall()

def q_flagged(db):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 "
        f"AND l.Z_PK IS NOT NULL AND r.ZFLAGGED = 1 ORDER BY r.ZDUEDATE NULLS LAST"
    ).fetchall()

def q_upcoming(db, days=7):
    """Reminders due within the next N days (not overdue)."""
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    future = sod + timedelta(days=days + 1)
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(future)} "
        f"ORDER BY r.ZDUEDATE"
    ).fetchall()

def q_overdue(db):
    """All overdue incomplete reminders."""
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE < {to_ts(sod)} ORDER BY r.ZDUEDATE"
    ).fetchall()

# ── Format ───────────────────────────────────────────────────────────────────

def fmt_due(v, colored=True):
    if not v: return ""
    dt, now = ts(v), datetime.now()
    today = now.replace(hour=0, minute=0, second=0, microsecond=0)
    if dt.date() == today.date():
        label = f" (today {dt.strftime('%H:%M')})" if dt.hour or dt.minute else " (today)"
        return label
    if dt.date() == (today + timedelta(days=1)).date():
        return " (tomorrow)"
    if dt < now:
        label = f" (overdue {(now - dt).days}d)"
        return C.red(label) if colored else label
    return f" ({dt.strftime('%Y-%m-%d')})"

def preload_extras(db, pks):
    """Batch-load subtask counts and hashtags to avoid N+1 queries."""
    if not pks: return {}, {}
    ph = ",".join("?" * len(pks))
    sc_rows = db.execute(
        f"SELECT ZPARENTREMINDER, COUNT(*) FROM ZREMCDREMINDER "
        f"WHERE ZPARENTREMINDER IN ({ph}) AND ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0 "
        f"GROUP BY ZPARENTREMINDER", pks
    ).fetchall()
    sc = {r[0]: r[1] for r in sc_rows}
    ht_rows = db.execute(
        f"SELECT o.ZREMINDER3, h.ZNAME FROM ZREMCDOBJECT o JOIN ZREMCDHASHTAGLABEL h "
        f"ON o.ZHASHTAGLABEL = h.Z_PK WHERE o.ZREMINDER3 IN ({ph})", pks
    ).fetchall()
    ht = {}
    for r in ht_rows:
        ht.setdefault(r[0], []).append(r[1])
    return sc, ht

def _color_priority(pri_val):
    """Color a priority marker based on level."""
    p = PRI.get(pri_val or 0, "")
    if not p: return ""
    if pri_val == 1: return C.red(p)
    if pri_val == 5: return C.yellow(p)
    if pri_val == 9: return C.green(p)
    return p

def fmt(r, db=None, verbose=False, indent="", _sc=None, _ht=None):
    completed = r["ZCOMPLETED"]
    if completed:
        status = C.green("[x]")
    else:
        status = C.dim("[ ]")
    flag = C.yellow(" *") if r["ZFLAGGED"] else ""
    pri_val = r["ZPRIORITY"] or 0
    sc = (_sc or {}).get(r["Z_PK"], q_subtask_count(db, r["Z_PK"]) if db else 0)
    tags = (_ht or {}).get(r["Z_PK"], [t["ZNAME"] for t in q_hashtags(db, r["Z_PK"])] if db else [])
    tag_str = " " + " ".join(f"#{t}" for t in tags) if tags else ""
    sub_str = f" [{sc} subtask{'s' if sc != 1 else ''}]" if sc > 0 else ""
    pri_str = f" {_color_priority(pri_val)}" if PRI.get(pri_val, "") else ""
    id_str = C.dim(f"#{r['Z_PK']}")
    title = r["ZTITLE"] or "(untitled)"
    due_str = fmt_due(r["ZDUEDATE"])
    if completed:
        title = C.dim(C.strikethrough(title))
        due_str = C.dim(due_str)
        tag_str = C.dim(tag_str)
        sub_str = C.dim(sub_str)
    parts = [f"{indent}{status} {id_str}{pri_str}{flag} {title}{due_str}{tag_str}{sub_str}"]
    if verbose:
        if r["list_name"]:
            parts.append(f"{indent}    List: {color_list_name(r['list_name'], db)}")
        if r["ZNOTES"]:
            parts.append(f"{indent}    Notes: {C.dim(str(r['ZNOTES'])[:200])}")
        if r["ZICSURL"]:
            parts.append(f"{indent}    URL: {C.dim(r['ZICSURL'])}")
    return "\n".join(parts)

def to_dict(r, db=None, section=None, _sc=None, _ht=None):
    sc = (_sc or {}).get(r["Z_PK"], q_subtask_count(db, r["Z_PK"]) if db else 0)
    tags = (_ht or {}).get(r["Z_PK"], [t["ZNAME"] for t in q_hashtags(db, r["Z_PK"])] if db else [])
    d = {
        "id": r["Z_PK"], "title": r["ZTITLE"], "list": r["list_name"],
        "completed": bool(r["ZCOMPLETED"]), "flagged": bool(r["ZFLAGGED"]),
        "priority": PRI_NAME.get(r["ZPRIORITY"] or 0, "none"),
        "subtaskCount": sc, "isSubtask": bool(r["ZPARENTREMINDER"])
    }
    if section: d["section"] = section
    if r["ZNOTES"]: d["notes"] = r["ZNOTES"]
    if r["ZICSURL"]: d["url"] = r["ZICSURL"]
    if r["ZDUEDATE"]: d["dueDate"] = ts(r["ZDUEDATE"]).isoformat()
    if r["ZCREATIONDATE"]: d["createdDate"] = ts(r["ZCREATIONDATE"]).isoformat()
    if r["ZCOMPLETIONDATE"]: d["completionDate"] = ts(r["ZCOMPLETIONDATE"]).isoformat()
    if r["ZPARENTREMINDER"]: d["parentID"] = r["ZPARENTREMINDER"]
    if tags: d["tags"] = tags
    if r["ZCKIDENTIFIER"]:
        d["deepLink"] = f"x-apple-reminderkit://REMCDReminder/{r['ZCKIDENTIFIER']}"
    return d

# ── Table Format ─────────────────────────────────────────────────────────────

def _strip_ansi(s):
    """Remove ANSI escape codes for width calculation."""
    return re.sub(r'\033\[[0-9;]*m', '', s)

def _visible_len(s):
    """Length of string as displayed (without ANSI codes)."""
    return len(_strip_ansi(s))

def _pad(s, width):
    """Pad string to width, accounting for ANSI codes."""
    visible = _visible_len(s)
    return s + " " * max(0, width - visible)

def fmt_table(rows_data, max_width=None):
    """Format data as a Unicode box-drawing table.

    rows_data: list of dicts with keys: id, title, list, due, pri
    """
    if not rows_data:
        return ""
    if max_width is None:
        try:
            max_width = os.get_terminal_size().columns
        except (ValueError, OSError):
            max_width = 80

    headers = ["ID", "Title", "List", "Due", "Pri"]
    # Calculate column widths
    col_widths = [len(h) for h in headers]
    for row in rows_data:
        vals = [str(row.get("id", "")), row.get("title", ""), row.get("list", ""),
                row.get("due", ""), row.get("pri", "")]
        for i, v in enumerate(vals):
            col_widths[i] = max(col_widths[i], _visible_len(str(v)))

    # Cap title column so table fits terminal
    fixed = col_widths[0] + col_widths[2] + col_widths[3] + col_widths[4] + 16  # borders + padding
    max_title = max(10, max_width - fixed)
    col_widths[1] = min(col_widths[1], max_title)

    def hline(left, mid, right, fill="─"):
        parts = [left]
        for i, w in enumerate(col_widths):
            parts.append(fill * (w + 2))
            parts.append(mid if i < len(col_widths) - 1 else "")
        parts.append(right)
        return "".join(parts)

    def row_line(vals):
        cells = []
        for i, v in enumerate(vals):
            s = str(v)
            # Truncate if needed (by visible length)
            if _visible_len(s) > col_widths[i]:
                plain = _strip_ansi(s)
                s = plain[:col_widths[i] - 1] + "…"
            cells.append(f" {_pad(s, col_widths[i])} ")
        return "│" + "│".join(cells) + "│"

    lines = []
    lines.append(hline("┌", "┬", "┐"))
    lines.append(row_line([C.bold(h) for h in headers]))
    lines.append(hline("├", "┼", "┤"))
    for row in rows_data:
        vals = [
            C.dim(str(row.get("id", ""))),
            row.get("title", ""),
            row.get("list", ""),
            row.get("due", ""),
            row.get("pri", "")
        ]
        lines.append(row_line(vals))
    lines.append(hline("└", "┴", "┘"))
    return "\n".join(lines)

def reminders_to_table_data(items, db=None):
    """Convert reminder rows to table-friendly dicts."""
    data = []
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    for r in items:
        due_str = ""
        if r["ZDUEDATE"]:
            dt = ts(r["ZDUEDATE"])
            if dt.date() == sod.date():
                due_str = "Today"
                if dt.hour or dt.minute:
                    due_str += f" {dt.strftime('%H:%M')}"
            elif dt.date() == (sod + timedelta(days=1)).date():
                due_str = "Tomorrow"
            elif dt < now:
                due_str = C.red(f"Overdue {(now - dt).days}d")
            else:
                due_str = dt.strftime("%Y-%m-%d")
        pri_val = r["ZPRIORITY"] or 0
        pri_str = _color_priority(pri_val) if PRI.get(pri_val, "") else ""
        title = r["ZTITLE"] or "(untitled)"
        if r["ZFLAGGED"]:
            title = C.yellow("* ") + title
        list_name = r["list_name"] or ""
        if db and C.enabled:
            list_name = color_list_name(list_name, db)
        data.append({
            "id": r["Z_PK"],
            "title": title,
            "list": list_name,
            "due": due_str,
            "pri": pri_str,
        })
    return data

# ── Bridge Integration ───────────────────────────────────────────────────────

def bridge_available():
    """Check if remctl-bridge (Swift EventKit binary) is available."""
    return BRIDGE_PATH.exists() and BRIDGE_PATH.stat().st_mode & 0o111

def bridge_call(data):
    """Call remctl-bridge with JSON data. Returns parsed JSON response."""
    try:
        r = subprocess.run(
            [str(BRIDGE_PATH)], input=json.dumps(data),
            capture_output=True, text=True, timeout=30
        )
        if r.returncode == 0:
            return json.loads(r.stdout)
        return None
    except (subprocess.TimeoutExpired, json.JSONDecodeError, FileNotFoundError):
        return None

# ── AppleScript ──────────────────────────────────────────────────────────────

def osa(script):
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        print("Error: AppleScript timed out (Reminders.app may be unresponsive)", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        print(f"AppleScript error: {r.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return r.stdout.strip()

def osa_by_id(list_name, rem_id, action):
    """Run AppleScript action on a reminder matched by its x-apple-reminder ID."""
    return osa(
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )

def esc(s):
    return s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", " ").replace("\r", "")

def as_date(dt):
    return dt.strftime("%A, %B %d, %Y at %I:%M:%S %p")

# ── Natural Language Date Parser ─────────────────────────────────────────────

def parse_due(s):
    """Parse due date. Accepts:
      - ISO: 2026-04-15, 2026-04-15 14:00, 2026-04-15T14:00
      - Shortcuts: today, tomorrow, eod, eow, +3d, +1w, +2h, +1m
      - Relative: "in 3 days", "in 2 weeks"
      - Named days: "next monday", "next friday at 3pm"
      - Natural language (if parsedatetime installed): "march 30 2pm"
    """
    if not s: return None
    sl = s.lower().strip()
    today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    now = datetime.now()

    # Exact shortcuts
    if sl == "today": return today
    if sl == "tomorrow": return today + timedelta(days=1)
    if sl == "eod": return today.replace(hour=17, minute=0)
    if sl == "eow":
        days_ahead = 4 - today.weekday()  # Friday = 4
        if days_ahead <= 0: days_ahead += 7
        return today + timedelta(days=days_ahead)

    # Relative: +3d, +1w, +2m, +2h
    m = re.match(r'^[+]?(\d+)([dwmh])$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit == 'd': return today + timedelta(days=n)
        if unit == 'w': return today + timedelta(weeks=n)
        if unit == 'h': return now + timedelta(hours=n)
        if unit == 'm': return today + timedelta(days=n * 30)

    # "next monday", "next friday at 3pm"
    days_map = {
        "monday": 0, "tuesday": 1, "wednesday": 2, "thursday": 3,
        "friday": 4, "saturday": 5, "sunday": 6,
        "mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6
    }
    m = re.match(r'^next\s+(\w+)(?:\s+at\s+(\d{1,2})(?::(\d{2}))?\s*(am|pm)?)?$', sl)
    if m:
        day_name, hour, minute, ampm = m.groups()
        if day_name in days_map:
            target = days_map[day_name]
            days_ahead = (target - today.weekday()) % 7
            if days_ahead == 0: days_ahead = 7
            dt = today + timedelta(days=days_ahead)
            if hour:
                h = int(hour)
                if ampm == "pm" and h < 12: h += 12
                if ampm == "am" and h == 12: h = 0
                dt = dt.replace(hour=h, minute=int(minute or 0))
            return dt

    # "in N days/weeks/hours/months"
    m = re.match(r'^in\s+(\d+)\s+(day|days|week|weeks|hour|hours|month|months)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if "day" in unit: return today + timedelta(days=n)
        if "week" in unit: return today + timedelta(weeks=n)
        if "hour" in unit: return now + timedelta(hours=n)
        if "month" in unit: return today + timedelta(days=n * 30)

    # ISO formats
    for f in ("%Y-%m-%d", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            return datetime.strptime(s.strip(), f)
        except ValueError:
            pass

    # Fallback to parsedatetime if available
    if _cal:
        result, status = _cal.parseDT(s)
        if status > 0: return result

    return None

# ── Recurrence / Alarm Parsing ───────────────────────────────────────────────

def parse_recurrence(spec):
    """Parse recurrence spec like 'daily', 'weekly mon,wed,fri', 'monthly 1,15'."""
    parts = spec.lower().split()
    freq = parts[0]
    result = {"frequency": freq, "interval": 1}
    if freq == "weekly" and len(parts) > 1:
        day_map = {"sun": 1, "mon": 2, "tue": 3, "wed": 4, "thu": 5, "fri": 6, "sat": 7}
        days = [day_map[d.strip()] for d in parts[1].split(",") if d.strip() in day_map]
        if days: result["daysOfWeek"] = days
    elif freq == "monthly" and len(parts) > 1:
        days = [int(d) for d in parts[1].split(",") if d.strip().isdigit()]
        if days: result["daysOfMonth"] = days
    return result

def parse_alarm(spec):
    """Parse alarm spec like '15m', '1h', '1d', or ISO datetime."""
    if not spec: return None
    sl = spec.lower().strip()
    m = re.match(r'^(\d+)(m|min|h|hr|d)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit in ("m", "min"): return {"minutes_before": n}
        if unit in ("h", "hr"): return {"minutes_before": n * 60}
        if unit == "d": return {"minutes_before": n * 1440}
    # Try ISO datetime
    for f in ("%Y-%m-%dT%H:%M", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            dt = datetime.strptime(spec.strip(), f)
            return {"absolute": dt.isoformat()}
        except ValueError:
            pass
    return None


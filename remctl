WEEKDAY_MAP = {
    "monday": 0, "tuesday": 1, "wednesday": 2, "thursday": 3,
    "friday": 4, "saturday": 5, "sunday": 6,
    "mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6
}


def parse_due(s):
    """Parse due date. Accepts:
      - ISO: 2026-04-15, 2026-04-15 14:00, 2026-04-15T14:00
      - Shortcuts: today, today at 3pm, tomorrow 15:00, tonight at 11, eod, eow, +3d, +1w, +2h, +1m
      - Relative: "in 3 days", "in 2 weeks"
      - Named days: "friday at 15:00", "next friday at 3pm"
      - Natural language (if parsedatetime installed): "march 30 2pm"
    """
    if not s: return None
    sl = s.lower().strip()
    today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    now = datetime.now()
    days_map = WEEKDAY_MAP

    # Exact shortcuts
    if sl == "today": return today
    if sl == "tomorrow": return today + timedelta(days=1)
    if sl == "eod": return today.replace(hour=17, minute=0)
    if sl == "eow":
        days_ahead = 4 - today.weekday()  # Friday = 4
        if days_ahead <= 0: days_ahead += 7
        return today + timedelta(days=days_ahead)

    # Deterministic same/next-day times: "today at 3pm", "tomorrow 15:00".
    m = re.match(r'^(today|tomorrow)(?:\s+at)?\s+(.+)$', sl)
    if m:
        day_name, time_text = m.groups()
        parsed_time = parse_clock_time(time_text)
        if not parsed_time:
            return None
        hour, minute = parsed_time
        base = today if day_name == "today" else today + timedelta(days=1)
        return base.replace(hour=hour, minute=minute)

    # "tonight at 11" means the next occurrence of that time, preferring today.
    m = re.match(r'^tonight(?:\s+at)?\s+(.+)$', sl)
    if m:
        time_text = m.group(1)
        parsed_time = parse_clock_time(time_text)
        if not parsed_time:
            return None
        hour, minute = parsed_time
        if not re.search(r'\b(?:am|pm)\b', time_text) and 1 <= hour <= 11:
            hour += 12
        dt = today.replace(hour=hour, minute=minute)
        if dt <= now:
            dt += timedelta(days=1)
        return dt

    # Relative: +3d, +1w, +2m, +2h
    m = re.match(r'^[+]?(\d+)([dwmh])$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit == 'd': return today + timedelta(days=n)
        if unit == 'w': return today + timedelta(weeks=n)
        if unit == 'h': return now + timedelta(hours=n)
        if unit == 'm': return today + timedelta(days=n * 30)

    # "friday at 15:00", "fri 3pm", "this friday", "next friday at 3pm".
    m = re.match(r'^(?:(next|this)\s+)?(\w+)(?:\s+(?:at\s+)?(.+))?$', sl)
    if m:
        qualifier, day_name, time_text = m.groups()
        if day_name in days_map:
            target = days_map[day_name]
            days_ahead = (target - today.weekday()) % 7
            if qualifier == "next" and days_ahead == 0:
                days_ahead = 7
            dt = today + timedelta(days=days_ahead)
            if time_text:
                parsed_time = parse_clock_time(time_text)
                if not parsed_time:
                    return None
                hour, minute = parsed_time
                dt = dt.replace(hour=hour, minute=minute)
                if qualifier != "next" and dt <= now:
                    dt += timedelta(days=7)
            return dt

    # "in N days/weeks/hours/months"
    m = re.match(r'^in\s+(\d+)\s+(day|days|week|weeks|hour|hours|month|months)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if "day" in unit: return today + timedelta(days=n)
        if "week" in unit: return today + timedelta(weeks=n)
        if "hour" in unit: return now + timedelta(hours=n)
        if "month" in unit: return today + timedelta(days=n * 30)

    # ISO formats
    for f in ("%Y-%m-%d", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            return datetime.strptime(s.strip(), f)
        except ValueError:
            pass

    # Fallback to parsedatetime if available
    if _cal:
        result, status = _cal.parseDT(s)
        if status > 0: return result

    return None


def due_spec_is_all_day(s):
    """Return True when the due-date text names a day without a clock time."""
    if not s:
        return False
    sl = s.lower().strip()
    if sl in {"today", "tomorrow", "eow"}:
        return True
    if sl == "eod":
        return False
    if re.match(r"^\d{4}-\d{2}-\d{2}$", s.strip()):
        return True

    m = re.match(r"^[+]?(\d+)([dwmh])$", sl)
    if m:
        return m.group(2) in {"d", "w", "m"}

    m = re.match(r"^in\s+(\d+)\s+(day|days|week|weeks|hour|hours|month|months)$", sl)
    if m:
        return m.group(2) not in {"hour", "hours"}

    m = re.match(r"^(?:(next|this)\s+)?(\w+)(?:\s+(?:at\s+)?(.+))?$", sl)
    if m:
        _, day_name, time_text = m.groups()
        if day_name in WEEKDAY_MAP and not time_text:
            return True

    if _cal:
        _, status = _cal.parseDT(s)
        if status > 0:
            return status == 1

    return False

# ── Recurrence / Alarm Parsing ───────────────────────────────────────────────

RECURRENCE_DAY_MAP = {"sun": 1, "mon": 2, "tue": 3, "wed": 4, "thu": 5, "fri": 6, "sat": 7}
# digit runs are length-bounded so int() can never trip CPython's int/str conversion limit
NTH_WEEKDAY_RE = re.compile(r"^(-?\d{1,2})(?:st|nd|rd|th)?-(sun|mon|tue|wed|thu|fri|sat)$")


def parse_recurrence(spec):
    """Parse recurrence spec like 'daily', 'weekly mon,wed,fri', 'monthly 1,15', 'monthly 4th-fri', 'yearly x2'."""
    if not spec:
        return None
    parts = spec.lower().split()
    if not parts:
        return None
    freq = parts[0]
    if freq not in {"daily", "weekly", "monthly", "yearly"}:
        return None
    interval = 1
    # optional 'xN' interval token, e.g. 'yearly x2' = every 2 years
    if len(parts) > 1 and parts[1].startswith("x") and parts[1][1:].isdecimal():
        token = parts[1][1:]
        if len(token) > 3:
            return None
        interval = int(token)
        if interval < 1:
            return None
        parts = [freq] + parts[2:]
    result = {"frequency": freq, "interval": interval}
    if freq == "weekly" and len(parts) > 1:
        if len(parts) != 2:
            return None
        tokens = [d.strip() for d in parts[1].split(",") if d.strip()]
        if not tokens or any(token not in RECURRENCE_DAY_MAP for token in tokens):
            return None
        days = [RECURRENCE_DAY_MAP[token] for token in tokens]
        if days: result["daysOfWeek"] = days
    elif freq == "monthly" and len(parts) > 1:
        if len(parts) != 2:
            return None
        tokens = [d.strip() for d in parts[1].split(",") if d.strip()]
        if not tokens:
            return None
        if all(token.isdecimal() and len(token) <= 2 for token in tokens):
            days = [int(token) for token in tokens]
            if any(day < 1 or day > 31 for day in days):
                return None
            if days: result["daysOfMonth"] = days
        elif all(NTH_WEEKDAY_RE.match(token) for token in tokens):
            # 'monthly 4th-fri' = the 4th Friday of every month; '-1-fri' = last
            days, weeks = [], []
            for token in tokens:
                m = NTH_WEEKDAY_RE.match(token)
                week = int(m.group(1))
                if week == 0 or week > 5 or week < -5:
                    return None
                days.append(RECURRENCE_DAY_MAP[m.group(2)])
                weeks.append(week)
            result["daysOfWeek"] = days
            result["weekNumbers"] = weeks
        else:
            return None
    elif len(parts) > 1:
        return None
    return result


def fail_invalid_recurrence(value):
    print(
        f"Error: could not parse recurrence {value!r}. Use daily, weekly, "
        "'weekly mon,wed,fri', 'monthly 1,15', 'monthly 4th-fri' ('-1-fri' = "
        "last Friday), monthly, yearly, or add an 'xN' interval like "
        "'yearly x2'.",
        file=sys.stderr,
    )
    sys.exit(1)


def recurrence_or_die(value):
    recurrence = parse_recurrence(value)
    if recurrence is None:
        fail_invalid_recurrence(value)
    return recurrence

def parse_alarm(spec):
    """Normalize alarm spec for the Swift bridge.

    Relative alarms are converted to the bridge format (`-15m`, `-1h`, `-1d`).
    Absolute alarms are returned as ISO-like strings the bridge already accepts.
    """
    if not spec: return None
    sl = spec.lower().strip()
    m = re.match(r'^(\d+)(m|min|h|hr|d)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit in ("m", "min"): return f"-{n}m"
        if unit in ("h", "hr"): return f"-{n}h"
        if unit == "d": return f"-{n}d"
    # Try ISO datetime
    for f in ("%Y-%m-%dT%H:%M", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            dt = datetime.strptime(spec.strip(), f)
            return dt.isoformat()
        except ValueError:
            pass
    return None

def alarm_clear_requested(value):

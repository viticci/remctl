            "Opening Reminders.app timed out.",
            "Open Reminders.app manually, then rerun `remctl onboard`.",
        )
    except OSError as exc:
        return check_result(
            "open_reminders",
            "warn",
            f"Could not open Reminders.app: {exc}",
            "Open Reminders.app manually, then rerun `remctl onboard`.",
        )
    if proc.returncode != 0:
        detail = (proc.stderr or proc.stdout).strip() or "open -a Reminders failed."
        return check_result(
            "open_reminders",
            "warn",
            detail,
            "Open Reminders.app manually, then rerun `remctl onboard`.",
        )
    time.sleep(1)
    return check_result("open_reminders", "ok", "Opened Reminders.app.")


def bridge_access_check_for_onboarding():
    bridge_path = current_bridge_path()
    if not bridge_path.exists() or not os.access(bridge_path, os.X_OK):
        return check_result(
            "eventkit",
            "warn",
            f"{bridge_path} is unavailable.",
            "Run ./install.sh to install remctl-bridge, then rerun `remctl onboard`.",
        )

    result = bridge_call_result({"action": "authorize"})
    if not result or not isinstance(result.get("payload"), dict):
        return check_result(
            "eventkit",
            "warn",
            f"{bridge_path} did not return a valid authorization response.",
            "Rebuild remctl-bridge with ./install.sh, then rerun `remctl onboard`.",
        )

    payload = result["payload"]
    if result["returncode"] == 0 and payload.get("status") == "authorized":
        calendar_count = payload.get("calendarCount")
        default_list = payload.get("defaultList") or "unknown"
        detail = f"Reminders access granted to {bridge_path}"
        if isinstance(calendar_count, int):
            detail += f" ({calendar_count} list{'s' if calendar_count != 1 else ''}, default: {default_list})"
        detail += "."
        return check_result("eventkit", "ok", detail)

    message = (
        payload.get("message")
        or result.get("stderr", "").strip()
        or "Reminders authorization failed."
    )
    return check_result(
        "eventkit",
        "fail",
        message,
        "Re-run `remctl onboard` from the same terminal and click Allow when macOS asks for Reminders access.",
    )


def applescript_access_check_for_onboarding():
    script = 'tell application "Reminders" to get name of default list'
    try:
        proc = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True,
            text=True,
            timeout=30,
        )
    except subprocess.TimeoutExpired:
        return check_result(
            "automation",
            "warn",
            "AppleScript automation probe timed out while talking to Reminders.app.",
            "Re-run `remctl onboard` from the same terminal and approve the Automation prompt if macOS asks.",
        )
    except OSError as exc:
        return check_result(
            "automation",
            "warn",
            f"Could not run osascript: {exc}",
            "Re-run `remctl onboard` from Terminal after opening Reminders.app.",
        )

    if proc.returncode == 0:
        default_list = proc.stdout.strip()
        detail = "AppleScript automation access confirmed."
        if default_list:
            detail = f"AppleScript automation access confirmed (default list: {default_list})."
        return check_result("automation", "ok", detail)

    message = proc.stderr.strip() or proc.stdout.strip() or "AppleScript automation probe failed."
    return check_result(
        "automation",
        "warn",
        message,
        "Re-run `remctl onboard` from the same terminal and approve the Automation prompt if macOS asks. Flagged operations and AppleScript fallback writes rely on this access.",
    )


def database_access_check_for_onboarding():
    access_error = reminders_store_access_error()
    db_path = find_main_db_path()
    if access_error:
        return check_result(
            "database",
            "fail",
            access_error,
            full_disk_access_fix_text(rerun_command="remctl doctor --for-agent"),
        )
    if db_path:
        return check_result("database", "ok", str(db_path))
    return check_result(
        "database",
        "fail",
        "No Reminders database found.",
        "Enable iCloud Reminders and open Reminders.app once, then rerun `remctl onboard`.",
    )


def gather_onboarding_checks():
    checks = [
        open_reminders_app_for_onboarding(),
        bridge_access_check_for_onboarding(),
        applescript_access_check_for_onboarding(),
    ]
    db_check = database_access_check_for_onboarding()
    checks.append(db_check)
    return checks


def run_onboarding(*, auto=False):
    checks = gather_onboarding_checks()
    fail_count = sum(1 for check in checks if check["status"] == "fail")
    warn_count = sum(1 for check in checks if check["status"] == "warn")
    result = {
        "ok": fail_count == 0,
        "warnings": warn_count,
        "failures": fail_count,
        "checks": checks,
    }
    write_onboard_state(result, auto=auto)
    return result


def should_auto_onboard(args):
    if sys.platform != "darwin":
        return False
    if os.environ.get(AUTO_ONBOARD_SKIP_ENV):
        return False
    if getattr(args, "cmd", None) in AUTO_ONBOARD_SKIP_COMMANDS:
        return False
    if getattr(args, "json", False) or getattr(args, "format", None) == "json":
        return False
    if not sys.stdout.isatty():
        return False
    return load_onboard_state() is None


def maybe_run_first_launch_onboarding(args):
    if not should_auto_onboard(args):
        return None
    print(C.bold("First launch detected. Running remctl onboard."))
    print(C.dim("Approve any macOS prompts for Reminders or Automation access, then the original command will continue."))
    print()
    result = run_onboarding(auto=True)
    print_check_report("RemCTL onboard", result["checks"])
    database_check = next((check for check in result["checks"] if check["name"] == "database"), None)
    if needs_full_disk_access_guidance(database_check):
        if launch_full_disk_access_helper(include_cli=True):
            print_permission_helper_opened()
        else:
            print_full_disk_access_guidance(
                settings_opened=False,
                rerun_command="remctl doctor",
            )
    print()
    return result

# ── AppleScript ──────────────────────────────────────────────────────────────

def osa(script):
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        print("Error: AppleScript timed out (Reminders.app may be unresponsive)", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        print(f"AppleScript error: {r.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return r.stdout.strip()


def create_list_with_applescript(name):
    rid = osa(
        f'tell application "Reminders"\n'
        f'set newList to make new list with properties {{name:"{esc(name)}"}}\n'
        f'return id of newList\n'
        f'end tell'
    )
    return {"status": "created", "id": rid, "fallback": "applescript"}


def delete_list_with_applescript(name):
    osa(
        f'tell application "Reminders"\n'
        f'delete list "{esc(name)}"\n'
        f'end tell'
    )
    return {"status": "deleted", "fallback": "applescript"}

def osa_by_id(list_name, rem_id, action):
    """Run AppleScript action on a reminder matched by its x-apple-reminder ID."""
    return osa(
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )

def osa_by_id_try(list_name, rem_id, action, timeout=120):
    """Non-fatal variant: returns True on success, False on failure.
    Used for AppleScript-first write paths that want to fall back to bridge.

    Reminders.app AppleScript dispatch can be slow (30–90s) on busy stores,
    especially after a remindd restart. Use a generous timeout — slow sync
    beats silent data loss."""
    script = (
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0
    except subprocess.TimeoutExpired:
        return False

def esc(s):
    """Escape a string for AppleScript double-quoted literals.
    Covers backslash, double-quote, and every kind of control/line-break
    character that can terminate an AppleScript string (\n, \r, \t, U+0085,
    U+2028, U+2029)."""
    s = s.replace("\\", "\\\\").replace('"', '\\"')
    for ch in ("\r", "\n", "\t", "\u0085", "\u2028", "\u2029"):
        s = s.replace(ch, " ")
    # Strip remaining ASCII control chars (0x00-0x1F except already-handled)
    return "".join(c if ord(c) >= 0x20 else " " for c in s)

def applescript_date_var(dt, varname="d"):
    """Build a locale-neutral AppleScript snippet that defines `<varname>` as
    the given local datetime via numeric field-assignment. This works on any
    macOS locale; `date "..."` parsing breaks on non-English locales and
    silently falls through to the bridge (which has its own sync gotchas).
    All values are bounded ints — no user-input interpolation."""
    return (
        f'set {varname} to current date\n'
        f'set year of {varname} to {dt.year}\n'
        f'set month of {varname} to {dt.month}\n'
        f'set day of {varname} to {dt.day}\n'
        f'set hours of {varname} to {dt.hour}\n'
        f'set minutes of {varname} to {dt.minute}\n'
        f'set seconds of {varname} to {dt.second}'
    )

def as_date_assign(dt, target="due date of r"):
    """Return an AppleScript snippet that assigns a locale-neutral date to
    the given target (e.g., `due date of r`). Preferred over the old
    `date "..."` string literal pattern, which was locale-dependent."""
    return applescript_date_var(dt, "_rdt") + f"\nset {target} to _rdt"

# Kept for backwards compatibility with a handful of callers that still
# embed date literals. Prefer as_date_assign for new code.
def as_date(dt):
    return dt.strftime("%A, %B %d, %Y at %I:%M:%S %p")

# ── Date Parser ──────────────────────────────────────────────────────────────

def parse_clock_time(value):
    if not value:
        return None
    text = value.strip().lower()
    m = re.match(r'^(\d{1,2})(?::(\d{2}))?\s*(am|pm)?$', text)
    if not m:
        return None
    hour, minute, ampm = m.groups()
    hour = int(hour)
    minute = int(minute or 0)
    if minute > 59:
        return None
    if ampm:
        if hour < 1 or hour > 12:
            return None
        if ampm == "pm" and hour < 12:
            hour += 12
        if ampm == "am" and hour == 12:
            hour = 0
    elif hour > 23:
        return None
    return hour, minute

def due_date_examples(now=None):
    current = now or datetime.now()
    today_text = current.strftime("%Y-%m-%d")
    tomorrow_text = (current + timedelta(days=1)).strftime("%Y-%m-%d")
    return [
        f"{today_text} 15:00",
        "today at 3pm",
        "tomorrow 09:30",
        "tonight at 11",
        "Friday at 15:00",
        "+3d",
    ]

def invalid_due_date_payload(value, field="due"):
    return {
        "status": "error",
        "code": "invalid_due_date",
        "field": field,
        "input": value,
        "message": "Could not parse due date. No reminder was created or changed.",
        "examples": due_date_examples(),
    }

def fail_invalid_due_date(value, *, json_mode=False, field="due"):
    payload = invalid_due_date_payload(value, field=field)
    if json_mode:
        print(json.dumps(payload), file=sys.stderr)
    else:

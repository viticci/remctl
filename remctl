def _cmd_list_pin_state(a, pinned):
    if getattr(a, "list_id", None) is not None and getattr(a, "smart_list_id", None) is not None:
        print("Error: pass either --list-id or --smart-list-id, not both.", file=sys.stderr)
        sys.exit(1)
    if not (getattr(a, "name", None) or getattr(a, "list_id", None) is not None or getattr(a, "smart_list_id", None) is not None):
        print("Error: pass a list/smart-list name, --list-id, or --smart-list-id.", file=sys.stderr)
        sys.exit(1)
    require_private_metadata(a)
    db = open_db()
    smart_list_id = getattr(a, "smart_list_id", None)
    name = getattr(a, "name", None)
    if smart_list_id is not None:
        target_kind = "smart-list"
        target_ref = resolve_smart_list_or_die(db, smart_list_id=smart_list_id)
        result = apply_private_smart_list_pinned(db, target_ref["id"], a, pinned)
    elif getattr(a, "list_id", None) is not None:
        target_kind = "list"
        target_ref = resolve_list_or_die(db, list_id=a.list_id)
        result = apply_private_list_pinned(db, target_ref["id"], a, pinned)
    elif name:
        list_ref = resolve_list_ref(db, name=name)
        smart_ref = resolve_smart_list_ref(db, name=name)
        list_ok = list_ref and not list_ref.get("error")
        smart_ok = smart_ref and not smart_ref.get("error")
        if list_ref and list_ref.get("error"):
            _print_list_resolution_error(name, list_ref)
            sys.exit(1)
        if smart_ref and smart_ref.get("error"):
            _print_smart_list_resolution_error(name, smart_ref)
            sys.exit(1)
        if list_ok and smart_ok:
            print(
                f"Error: {name!r} matches both a list and a smart list. Use --list-id or --smart-list-id.",
                file=sys.stderr,
            )
            sys.exit(1)
        if list_ok:
            target_kind = "list"
            target_ref = list_ref
            result = apply_private_list_pinned(db, target_ref["id"], a, pinned)
        elif smart_ok:
            target_kind = "smart-list"
            target_ref = smart_ref
            result = apply_private_smart_list_pinned(db, target_ref["id"], a, pinned)
        else:
            print(f"Error: list or smart list not found: {name}", file=sys.stderr)
            sys.exit(1)
    else:
        print("Error: pass a list/smart-list name, --list-id, or --smart-list-id.", file=sys.stderr)
        sys.exit(1)
    status = "pinned" if pinned else "unpinned"
    if a.json:
        print(json.dumps({
            "status": status,
            "kind": target_kind,
            "id": target_ref["id"],
            "name": target_ref["title"],
            "private": result,
        }, ensure_ascii=False))
    else:
        label = "smart list" if target_kind == "smart-list" else "list"
        print(f"{status.capitalize()} {label}: {safe_display(target_ref['title'])}")



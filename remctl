def uuid_from_blob(value):
    if not value:
        return None
    try:
        data = bytes(value)
        if len(data) != 16:
            return None
        return str(uuid.UUID(bytes=data)).upper()
    except (TypeError, ValueError):
        return None


def uuid_blob_from_string(value):
    if not value:
        return None
    try:
        return uuid.UUID(str(value)).bytes
    except (TypeError, ValueError):
        return None



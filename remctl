def gather_doctor_checks():
    checks = []

    def add(name, status, detail, fix=None):
        checks.append({"name": name, "status": status, "detail": detail, "fix": fix})

    is_darwin = sys.platform == "darwin"
    add(
        "platform",
        "ok" if is_darwin else "fail",
        f"{platform.system()} {platform.mac_ver()[0] or platform.release()}",
        None if is_darwin else "RemCTL only supports macOS.",
    )

    py_ok = sys.version_info >= (3, 10)
    add(
        "python",
        "ok" if py_ok else "fail",
        platform.python_version(),
        None if py_ok else "Install Python 3.10 or newer.",
    )

    add(
        "store_dir",
        "ok" if STORE_DIR.exists() else "fail",
        str(STORE_DIR),
        None if STORE_DIR.exists() else "Set REMCTL_STORE_DIR if your Reminders store lives elsewhere.",
    )

    db_access_error = reminders_store_access_error()
    db_path = find_main_db_path()
    if db_access_error:
        add(
            "database",
            "fail",
            db_access_error,
            full_disk_access_fix_text(
                rerun_command="remctl doctor --for-agent",
                mention_onboard=True,
            ),
        )
    else:
        add(
            "database",
            "ok" if db_path else "fail",
            str(db_path) if db_path else "No Reminders database found",
            None if db_path else "Enable iCloud Reminders and open Reminders.app once, or run remctl onboard.",
        )

    cli_path = current_cli_path()
    cli_on_path = shutil.which("remctl") is not None
    add(
        "cli",
        "ok" if cli_path.exists() else "fail",
        str(cli_path),
        None if cli_on_path else f"Add {cli_path.parent} to PATH.",
    )

    bridge_path = current_bridge_path()
    bridge_ok = bridge_path.exists() and os.access(bridge_path, os.X_OK)
    bridge_fix = None
    if not bridge_ok:
        bridge_fix = "Run ./install.sh or compile remctl-bridge.swift with swiftc, then run remctl onboard."
    add(
        "bridge",
        "ok" if bridge_ok else "warn",
        str(bridge_path),
        bridge_fix,
    )

    private_path = current_private_path()
    private_ok = private_path.exists() and os.access(private_path, os.X_OK)
    add(
        "private_helper",
        "ok" if private_ok else "warn",
        str(private_path),
        None if private_ok else "Run ./install.sh to compile remctl-private, or avoid --private writes.",
    )

    permissions_path = current_permissions_path()
    permissions_ok = permissions_path.exists() and os.access(permissions_path, os.X_OK)
    add(
        "permissions_helper",
        "ok" if permissions_ok else "warn",
        str(permissions_path),
        None if permissions_ok else "Run ./install.sh to compile remctl-permissions for the guided Full Disk Access flow.",
    )

    config_ok = CONFIG_DIR.exists()
    add(
        "config_dir",
        "ok" if config_ok else "warn",
        str(CONFIG_DIR),
        None if config_ok else "Run remctl setup to create config files.",
    )

    shell = detect_shell_name()
    if shell in {"zsh", "bash", "fish"}:
        completion_path = completion_target_path(shell)
        add(
            "completion",
            "ok" if completion_path.exists() else "warn",
            f"{shell}: {completion_path}",
            None if completion_path.exists() else f"Run remctl setup --shell {shell} to install completion.",
        )
    else:
        add("completion", "warn", f"Unsupported shell '{shell}'", "Run remctl setup --shell zsh|bash|fish.")

    return checks


def cmd_doctor(a):
    checks = gather_doctor_checks()
    context = doctor_execution_context()
    fail_count = sum(1 for check in checks if check["status"] == "fail")
    warn_count = sum(1 for check in checks if check["status"] == "warn")
    result = {
        "ok": fail_count == 0,
        "warnings": warn_count,
        "failures": fail_count,
        "context": context,
        "checks": checks,
    }
    if getattr(a, "for_agent", False):
        result["agent_note"] = (
            "This report only applies to the process context shown in `context`. "
            "`doctor` must pass in the same context that will run the write. "
            "Terminal and Codex or other agent runners can have different Full Disk Access grants."
        )
    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print(C.bold("RemCTL doctor"))
        print(f"Context: {context.get('effective_context') or 'unknown'}")
        print(f"Python: {context.get('python')}")
        parent = context.get("parent_process") or {}
        if parent:
            print(f"Parent process: {parent.get('name')} (pid {parent.get('pid')})")
        if context.get("host_app"):
            print(f"Host app: {context.get('host_app')}")
        if context.get("terminal_app"):
            print(f"Terminal app: {context.get('terminal_app')}")
        if getattr(a, "for_agent", False):
            print(
                "Agent note: `doctor` must pass in the same context that will run the write; "
                "Terminal may be green while this runner is blocked."
            )
        print()
        print_check_report(None, checks)
    if fail_count:
        sys.exit(1)


def cmd_onboard(a):
    result = run_onboarding(auto=False)
    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print(C.bold("RemCTL onboard"))
        print(C.dim("Approve any macOS prompts for Reminders or Automation access."))
        print()
        print_check_report(None, result["checks"])
        database_check = next((check for check in result["checks"] if check["name"] == "database"), None)
        needs_cli_access = needs_full_disk_access_guidance(database_check)
        if needs_cli_access:
            if launch_full_disk_access_helper(include_cli=True):
                print_permission_helper_opened()
            else:
                print_full_disk_access_guidance(
                    settings_opened=open_full_disk_access_settings(),
                    rerun_command="remctl doctor",
                )
    if result["failures"]:
        sys.exit(1)


def cmd_permissions(a):

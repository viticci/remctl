def resolve_list_ref(db, name=None, list_id=None):
    if list_id is not None:
        columns = list_select_columns(db)
        row = db.execute(
            f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
            "WHERE Z_PK = ? AND ZMARKEDFORDELETION = 0 AND Z_ENT = 3 "
            "AND ZNAME IS NOT NULL AND ZNAME != ''",
            (list_id,),
        ).fetchone()
        return list_ref_payload(row, requested=str(list_id), method="id") if row else None

    if not name:
        return None

    rows = q_lists(db)
    exact = [row for row in rows if _row_value(row, "ZNAME") == name]
    if len(exact) == 1:
        return list_ref_payload(exact[0], requested=name, method="exact")
    if len(exact) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [list_ref_payload(row) for row in exact]}

    folded = str(name).casefold()
    ci = [row for row in rows if str(_row_value(row, "ZNAME")).casefold() == folded]
    if len(ci) == 1:
        return list_ref_payload(ci[0], requested=name, method="case_insensitive")
    if len(ci) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [list_ref_payload(row) for row in ci]}

    normalized = normalize_list_lookup_name(name)
    if not normalized:
        return None
    normalized_matches = [
        row for row in rows
        if normalize_list_lookup_name(_row_value(row, "ZNAME")) == normalized
    ]
    if len(normalized_matches) == 1:
        return list_ref_payload(normalized_matches[0], requested=name, method="normalized")
    if len(normalized_matches) > 1:
        return {
            "error": "ambiguous",
            "requested": name,
            "candidates": [list_ref_payload(row) for row in normalized_matches],
        }
    return None

def _print_list_resolution_error(requested, result=None):
    if result and result.get("error") == "ambiguous":
        options = ", ".join(
            f"{candidate['id']} ({candidate['title']})"
            for candidate in result.get("candidates", [])
        )
        print(
            f"Error: multiple lists match {requested!r}. Use the exact list name or --list-id with one of: {options}",
            file=sys.stderr,
        )
    else:
        print(f"Error: list not found: {requested}", file=sys.stderr)

def resolve_list_or_die(db, name=None, list_id=None):

def normalize_list_color(value):
    if not value:
        return None
    value = str(value).strip()
    if HEX_COLOR_RE.match(value):
        return value.upper()
    return value.lower()

def is_supported_public_list_color(value):
    normalized = normalize_list_color(value)
    return normalized in LIST_COLOR_MAP

def is_supported_private_list_color(value):
    normalized = normalize_list_color(value)
    return normalized in LIST_COLOR_MAP or bool(normalized and HEX_COLOR_RE.match(normalized))

def validate_list_color(value, *, private=False):
    if not value:
        return
    if private:
        ok = is_supported_private_list_color(value)
        examples = "red, orange, yellow, green, blue, purple, brown, gray, cyan, or #RRGGBB"
    else:
        ok = is_supported_public_list_color(value)
        examples = "red, orange, yellow, green, blue, purple, brown, gray, or cyan"
    if not ok:
        print(f"Error: unsupported list color {value!r}. Use {examples}.", file=sys.stderr)
        sys.exit(1)

def rgb_to_hex(rgb):
    return "#{:02X}{:02X}{:02X}".format(*rgb)

def blend_rgb(rgb, target=(255, 255, 255), amount=0.34):
    return tuple(round(channel + (target_channel - channel) * amount) for channel, target_channel in zip(rgb, target))

def list_color_preview_rows():
    return [

def resolve_group_member_list_refs(db, *, names=None, ids=None):
    refs = []
    seen = set()
    for list_id in ids or []:
        ref = resolve_list_or_die(db, list_id=list_id)
        if ref["id"] not in seen:
            refs.append(ref)
            seen.add(ref["id"])
    for name in names or []:
        ref = resolve_list_or_die(db, name=name)
        if ref["id"] not in seen:
            refs.append(ref)
            seen.add(ref["id"])
    return refs


def resolve_single_group_member_ref(db, *, name=None, list_id=None, option_name="--move-list"):
    if name and list_id is not None:
        print(f"Error: pass either {option_name} or {option_name}-id, not both.", file=sys.stderr)
        sys.exit(1)
    if not name and list_id is None:
        return None
    return resolve_list_or_die(db, name=name, list_id=list_id)


def group_child_ref_by_position(group_ref, *, first=False, last=False, exclude_id=None):
    children = [child for child in group_ref.get("children") or [] if child.get("id") != exclude_id]
    if not children:
        return None
    return children[-1] if last else children[0]


def resolve_group_ordering_request(db, group_ref, a):
    move_ref = resolve_single_group_member_ref(
        db,
        name=getattr(a, "move_list", None),
        list_id=getattr(a, "move_list_id", None),
        option_name="--move-list",
    )
    before_ref = resolve_single_group_member_ref(
        db,
        name=getattr(a, "before_list", None),
        list_id=getattr(a, "before_list_id", None),
        option_name="--before-list",
    )
    after_ref = resolve_single_group_member_ref(
        db,
        name=getattr(a, "after_list", None),
        list_id=getattr(a, "after_list_id", None),
        option_name="--after-list",
    )
    first = bool(getattr(a, "first", False))
    last = bool(getattr(a, "last", False))
    position_count = sum(1 for item in (before_ref, after_ref) if item is not None) + int(first) + int(last)
    if position_count and move_ref is None:
        print("Error: --before-list/--after-list/--first/--last require --move-list or --move-list-id.", file=sys.stderr)
        sys.exit(1)
    if move_ref is None:
        return None
    if position_count != 1:
        print("Error: pass exactly one of --before-list, --before-list-id, --after-list, --after-list-id, --first, or --last with --move-list.", file=sys.stderr)
        sys.exit(1)
    if before_ref is not None:
        return {"list": move_ref, "sibling": before_ref, "placement": "before", "position": "before"}
    if after_ref is not None:
        return {"list": move_ref, "sibling": after_ref, "placement": "after", "position": "after"}
    if first:
        sibling = group_child_ref_by_position(group_ref, first=True, exclude_id=move_ref["id"])
        return {"list": move_ref, "sibling": sibling, "placement": "before" if sibling else None, "position": "first"}
    sibling = group_child_ref_by_position(group_ref, last=True, exclude_id=move_ref["id"])
    return {"list": move_ref, "sibling": sibling, "placement": "after" if sibling else None, "position": "last"}


def compute_group_child_order_after_move(group_ref, move_request):
    children = list(group_ref.get("children") or [])
    by_id = {child["id"]: child for child in children}
    move_ref = by_id.get(move_request["list"]["id"], move_request["list"])
    sibling = move_request.get("sibling")
    if sibling and sibling["id"] == move_ref["id"]:
        print("Error: cannot place a list relative to itself.", file=sys.stderr)
        sys.exit(1)
    remaining = [child for child in children if child["id"] != move_ref["id"]]
    position = move_request["position"]
    if position in {"before", "after"}:
        if not sibling or sibling["id"] not in by_id:
            sibling_title = (sibling or {}).get("title") or "target sibling"
            print(
                f"Error: sibling list {sibling_title!r} is not currently in group {group_ref['title']!r}.",
                file=sys.stderr,
            )
            sys.exit(1)
        insertion_index = next(idx for idx, child in enumerate(remaining) if child["id"] == sibling["id"])
        if position == "after":
            insertion_index += 1
        return remaining[:insertion_index] + [move_ref] + remaining[insertion_index:]
    if position == "first":
        return [move_ref] + remaining
    if position == "last":
        return remaining + [move_ref]
    print("Error: unsupported group list position.", file=sys.stderr)
    sys.exit(1)


def apply_private_group_child_order(db, group_ref, ordered_children, a):
    current_children = list(group_ref.get("children") or [])
    current_ids = [child["id"] for child in current_children]
    ordered_ids = [child["id"] for child in ordered_children]
    if current_ids == ordered_ids:
        return {
            "status": "updated",
            "method": "unchanged",
            "finalOrder": ordered_ids,
        }
    if not (group_ref.get("objectUUID") or q_list_ckid(db, group_ref["id"])):
        print("Error: target group has no stable CloudKit identifier.", file=sys.stderr)
        sys.exit(1)
    refs_by_id = {child["id"]: child for child in current_children + ordered_children}
    for child in refs_by_id.values():
        if not (child.get("objectUUID") or q_list_ckid(db, child["id"])):
            print(f"Error: list {child['title']!r} has no stable CloudKit identifier.", file=sys.stderr)
            sys.exit(1)

    detached = []
    for child in current_children:
        result = apply_private_list_parent_group(
            db,
            child,
            None,
            require_current_group_id=group_ref["id"],
            required_group_ref=group_ref,
            a=a,
        )
        detached.append(group_change_summary(child, result))

    attached = []
    # Reminders inserts a list at the top when it is assigned to a group.
    # Reattaching in reverse desired order produces the requested visible order
    # without raw SQLite writes or unsupported direct relationship mutation.
    for child in reversed(ordered_children):
        result = apply_private_list_parent_group(db, child, group_ref, a=a)
        attached.append(group_change_summary(child, result))

    return {
        "status": "updated",
        "method": "detach_reattach",
        "detachedLists": detached,
        "attachedLists": attached,
        "finalOrder": ordered_ids,
    }


def group_change_summary(ref, result, *, skipped=False):
    payload = {
        "id": ref["id"],
        "title": ref["title"],
    }
    if ref.get("objectUUID"):
        payload["objectUUID"] = ref["objectUUID"]
    if skipped:
        payload["skipped"] = True
    if result is not None:
        payload["private"] = result
    return payload


def cmd_group_create(a):
    require_private_metadata(a)
    db = open_db()
    if q_list_exact_name_count(db, a.name):
        print(
            f"Error: list or group already exists: {a.name}. Choose a unique group name.",
            file=sys.stderr,
        )
        sys.exit(1)
    add_refs = resolve_group_member_list_refs(
        db,
        names=getattr(a, "add_list", None),
        ids=getattr(a, "add_list_id", None),
    )
    result = private_create_group_call({"action": "create_group", "name": a.name}, a.name)
    if not result or result.get("status") != "created":
        message = result.get("message") if isinstance(result, dict) else "private helper failed"
        print(f"Error: Failed to create group '{a.name}': {message}", file=sys.stderr)
        sys.exit(1)
    created_ref = None
    for _ in range(8):
        try:
            refreshed = resolve_group_ref(open_db(), name=a.name)
            if refreshed and not refreshed.get("error"):
                created_ref = refreshed
                break
        except RemindersDBUnavailable:
            pass
        time.sleep(0.25)
    group_ref = {
        "id": created_ref.get("id") if created_ref else None,
        "title": a.name,
        "objectUUID": (created_ref.get("objectUUID") if created_ref else None) or result.get("id"),
        "isGroup": True,
    }
    added = []
    for ref in add_refs:
        membership = apply_private_list_parent_group(db, ref, group_ref, a=a)
        added.append(group_change_summary(ref, membership))
    if a.json:
        print(json.dumps({
            "status": "created",
            "id": group_ref.get("id"),
            "name": a.name,
            "objectUUID": group_ref.get("objectUUID"),
            "private": result,
            "addedLists": added,
        }, ensure_ascii=False))
    else:
        print(f"Created group: {safe_display(a.name)}")
        if added:
            print("Added lists:")
            for item in added:
                print(f"  {safe_display(item['title'])} (id: {item['id']})")


def cmd_group_edit(a):
    require_private_metadata(a)
    db = open_db()
    group_ref = resolve_required_group_target_or_die(
        db,
        name=getattr(a, "name", None),
        group_id=getattr(a, "group_id", None),
    )
    add_refs = resolve_group_member_list_refs(
        db,
        names=getattr(a, "add_list", None),
        ids=getattr(a, "add_list_id", None),
    )
    remove_refs = resolve_group_member_list_refs(
        db,
        names=getattr(a, "remove_list", None),
        ids=getattr(a, "remove_list_id", None),
    )
    move_request = resolve_group_ordering_request(db, group_ref, a)
    new_name = getattr(a, "new_name", None)
    if move_request:
        move_id = move_request["list"]["id"]
        if any(ref["id"] == move_id for ref in remove_refs):
            print("Error: cannot move and remove the same list in one group edit.", file=sys.stderr)
            sys.exit(1)
        sibling = move_request.get("sibling")
        if sibling and any(ref["id"] == sibling["id"] for ref in remove_refs):
            print("Error: cannot place a list relative to a sibling that is being removed.", file=sys.stderr)
            sys.exit(1)
        add_refs = [ref for ref in add_refs if ref["id"] != move_id]
        if add_refs or remove_refs:
            print("Error: perform group ordering separately from other add/remove edits.", file=sys.stderr)
            sys.exit(1)
    if not new_name and not add_refs and not remove_refs and not move_request:
        print("Error: pass --new-name, --add-list/--add-list-id, --remove-list/--remove-list-id, or --move-list with a position.", file=sys.stderr)
        sys.exit(1)
    renamed = None
    if new_name:
        if new_name != group_ref["title"] and q_list_exact_name_count(db, new_name):
            print(
                f"Error: list or group already exists: {new_name}. Choose a unique group name.",
                file=sys.stderr,
            )
            sys.exit(1)
        group_ckid = group_ref.get("objectUUID") or q_list_ckid(db, group_ref["id"])
        if not group_ckid:
            print("Error: target group has no stable CloudKit identifier.", file=sys.stderr)
            sys.exit(1)
        result = private_call({
            "action": "set_list_appearance",
            "listId": group_ckid,
            "name": new_name,
        })
        if not result or result.get("status") != "updated":
            message = result.get("message") if isinstance(result, dict) else "private helper failed"
            print(f"Error: Failed to rename group '{group_ref['title']}': {message}", file=sys.stderr)
            sys.exit(1)
        renamed = {
            "oldName": group_ref["title"],
            "newName": new_name,
            "private": result,
        }
        group_ref = dict(group_ref)
        group_ref["title"] = new_name
    added = []
    for ref in add_refs:
        if ref.get("parentListId") == group_ref["id"]:
            added.append(group_change_summary(ref, None, skipped=True))
            continue
        membership = apply_private_list_parent_group(db, ref, group_ref, a=a)
        added.append(group_change_summary(ref, membership))
    removed = []
    for ref in remove_refs:
        membership = apply_private_list_parent_group(
            db,
            ref,
            None,
            require_current_group_id=group_ref["id"],
            required_group_ref=group_ref,
            a=a,
        )
        removed.append(group_change_summary(ref, membership))
    moved = None
    if move_request:
        ref = move_request["list"]
        sibling = move_request.get("sibling")
        ordered_children = compute_group_child_order_after_move(group_ref, move_request)
        membership = apply_private_group_child_order(db, group_ref, ordered_children, a)
        moved = group_change_summary(ref, membership)
        moved["position"] = move_request["position"]
        moved["finalOrder"] = [{"id": child["id"], "title": child["title"]} for child in ordered_children]
        if sibling is not None:
            moved["relativeTo"] = {
                "id": sibling["id"],
                "title": sibling["title"],
                "placement": move_request.get("placement"),
            }
    if a.json:
        print(json.dumps({
            "status": "updated",
            "id": group_ref["id"],
            "name": group_ref["title"],
            "objectUUID": group_ref.get("objectUUID"),
            "renamed": renamed,
            "addedLists": added,
            "removedLists": removed,
            "movedList": moved,
        }, ensure_ascii=False))
    else:
        print(f"Updated group: {safe_display(group_ref['title'])}")
        if renamed:
            print(f"Renamed: {safe_display(renamed['oldName'])} -> {safe_display(renamed['newName'])}")
        if added:
            print("Added lists:")
            for item in added:
                suffix = " [already in group]" if item.get("skipped") else ""
                print(f"  {safe_display(item['title'])} (id: {item['id']}){suffix}")
        if removed:
            print("Removed lists:")
            for item in removed:
                print(f"  {safe_display(item['title'])} (id: {item['id']})")
        if moved:
            relative = moved.get("relativeTo")
            if relative:
                print(
                    f"Moved list: {safe_display(moved['title'])} {relative['placement']} "
                    f"{safe_display(relative['title'])}"
                )
            else:
                print(f"Moved list: {safe_display(moved['title'])} ({moved['position']})")



def local_api_check_for_onboarding():
    service = launch_agent_status()
    if not service["running"]:
        fix = "Run `remctl service install` if you want optional local API fallback."
        if service["installed"]:
            fix = "Run `remctl service restart` to bring the optional local API fallback back online."
        return check_result("local_api", "warn", service["path"], fix)

    settings = parse_launch_agent_settings() or {}
    host = settings.get("host") or DEFAULT_SERVER_HOST
    port = settings.get("port") or DEFAULT_SERVER_PORT
    token = TOKEN_FILE.read_text().strip() if TOKEN_FILE.exists() else None
    probe = local_api_probe(host, port, token=token or None)
    assessed = assess_local_api_probe(host, port, probe, settings=settings)

def osa(script):
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        print("Error: AppleScript timed out (Reminders.app may be unresponsive)", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        print(f"AppleScript error: {r.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return r.stdout.strip()


def create_list_with_applescript(name):
    rid = osa(
        f'tell application "Reminders"\n'
        f'set newList to make new list with properties {{name:"{esc(name)}"}}\n'
        f'return id of newList\n'
        f'end tell'
    )
    return {"status": "created", "id": rid, "fallback": "applescript"}


def delete_list_with_applescript(name):
    osa(
        f'tell application "Reminders"\n'
        f'delete list "{esc(name)}"\n'
        f'end tell'
    )
    return {"status": "deleted", "fallback": "applescript"}

def osa_by_id(list_name, rem_id, action):
    """Run AppleScript action on a reminder matched by its x-apple-reminder ID."""
    return osa(
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )

def osa_by_id_try(list_name, rem_id, action, timeout=120):
    """Non-fatal variant: returns True on success, False on failure.
    Used for AppleScript-first write paths that want to fall back to bridge.

    Reminders.app AppleScript dispatch can be slow (30–90s) on busy stores,
    especially after a remindd restart. Use a generous timeout — slow sync
    beats silent data loss."""
    script = (
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0
    except subprocess.TimeoutExpired:
        return False


def osa_flag_reminder_try(list_name, reminder_ckid, *, flagged=True, timeout=120):
    """Set the real ZFLAGGED column via AppleScript without touching priority."""
    if not reminder_ckid:
        return False
    rem_id = reminder_ckid if reminder_ckid.startswith("x-apple-reminder://") else f"x-apple-reminder://{reminder_ckid}"
    action = "set flagged of r to true" if flagged else "set flagged of r to false"
    if list_name:
        return osa_by_id_try(list_name, rem_id, action, timeout=timeout)
    script = (
        f'tell application "Reminders"\n'
        f'tell default list\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0
    except subprocess.TimeoutExpired:
        return False

def esc(s):
    """Escape a string for AppleScript double-quoted literals.
    Covers backslash, double-quote, and every kind of control/line-break
    character that can terminate an AppleScript string (\n, \r, \t, U+0085,
    U+2028, U+2029)."""
    s = s.replace("\\", "\\\\").replace('"', '\\"')
    for ch in ("\r", "\n", "\t", "\u0085", "\u2028", "\u2029"):
        s = s.replace(ch, " ")
    # Strip remaining ASCII control chars (0x00-0x1F except already-handled)
    return "".join(c if ord(c) >= 0x20 else " " for c in s)

def applescript_date_var(dt, varname="d"):
    """Build a locale-neutral AppleScript snippet that defines `<varname>` as
    the given local datetime via numeric field-assignment. This works on any
    macOS locale; `date "..."` parsing breaks on non-English locales and
    silently falls through to the bridge (which has its own sync gotchas).
    All values are bounded ints — no user-input interpolation."""
    return (
        f'set {varname} to current date\n'
        f'set year of {varname} to {dt.year}\n'
        f'set month of {varname} to {dt.month}\n'
        f'set day of {varname} to {dt.day}\n'
        f'set hours of {varname} to {dt.hour}\n'
        f'set minutes of {varname} to {dt.minute}\n'
        f'set seconds of {varname} to {dt.second}'
    )

def as_date_assign(dt, target="due date of r"):
    """Return an AppleScript snippet that assigns a locale-neutral date to
    the given target (e.g., `due date of r`). Preferred over the old
    `date "..."` string literal pattern, which was locale-dependent."""
    return applescript_date_var(dt, "_rdt") + f"\nset {target} to _rdt"

# Kept for backwards compatibility with a handful of callers that still
# embed date literals. Prefer as_date_assign for new code.
def as_date(dt):
    return dt.strftime("%A, %B %d, %Y at %I:%M:%S %p")


    (SELECT rr.ZINTERVAL FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_interval,
    (SELECT rr.ZOCCURRENCECOUNT FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_count,
    (SELECT rr.ZENDDATE FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_end_date,
    (SELECT rr.ZDAYSOFTHEWEEK FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_days_of_week,
    (SELECT rr.ZDAYSOFTHEMONTH FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_days_of_month,
    (SELECT rr.ZMONTHSOFTHEYEAR FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_months_of_year,
    (SELECT rr.ZDAYSOFTHEYEAR FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_days_of_year,
    (SELECT rr.ZWEEKSOFTHEYEAR FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_weeks_of_year,
    (SELECT rr.ZSETPOSITIONS FROM ZREMCDOBJECT rr WHERE rr.ZREMINDER4 = r.Z_PK AND rr.ZMARKEDFORDELETION = 0 AND rr.Z_ENT = 34 ORDER BY rr.Z_PK LIMIT 1) AS recurrence_set_positions"""

_REMINDER_COLUMN_CACHE = {}

def reminder_has_column(db, column):
    key = (id(db), column)
    if key not in _REMINDER_COLUMN_CACHE:
        try:
            rows = db.execute("PRAGMA table_info(ZREMCDREMINDER)").fetchall()
            _REMINDER_COLUMN_CACHE[key] = any(row["name"] == column for row in rows)
        except Exception:
            _REMINDER_COLUMN_CACHE[key] = False
    return _REMINDER_COLUMN_CACHE[key]

def urgent_column_expr(db, table_alias="r"):
    if reminder_has_column(db, "ZISURGENTSTATEENABLEDFORCURRENTUSER"):
        return f"{table_alias}.ZISURGENTSTATEENABLEDFORCURRENTUSER"
    return "0"

def urgent_where_clause(db, table_alias="r"):
    if reminder_has_column(db, "ZISURGENTSTATEENABLEDFORCURRENTUSER"):
        return f"{table_alias}.ZISURGENTSTATEENABLEDFORCURRENTUSER = 1"
    return "0 = 1"

def due_date_delta_alerts_expr(db, table_alias="r"):
    if reminder_has_column(db, "ZDUEDATEDELTAALERTSDATA"):
        return f"{table_alias}.ZDUEDATEDELTAALERTSDATA"
    return "NULL"

def display_due_expr(db, table_alias="r"):
    if reminder_has_column(db, "ZDISPLAYDATEDATE"):
        return f"{table_alias}.ZDISPLAYDATEDATE"
    return "NULL"

def due_expr(table_alias="r"):
    return f"{table_alias}.ZDUEDATE"

def due_filter_expr(db, table_alias="r"):
    """Date used for due-window bucketing.

    Reminders stores all-day items with a synthetic due timestamp, while
    ZDISPLAYDATEDATE is the local day Reminders.app displays.
    """
    due = f"{table_alias}.ZDUEDATE"
    if reminder_has_column(db, "ZALLDAY") and reminder_has_column(db, "ZDISPLAYDATEDATE"):
        return (
            f"(CASE WHEN {table_alias}.ZALLDAY = 1 "
            f"THEN COALESCE({table_alias}.ZDISPLAYDATEDATE, {due}) ELSE {due} END)"
        )
    return due

def rem_cols(db):
    return f"""r.Z_PK, r.ZTITLE, r.ZNOTES, r.ZCOMPLETED, r.ZFLAGGED, r.ZPRIORITY,
    {urgent_column_expr(db)} AS ZISURGENTSTATEENABLEDFORCURRENTUSER,
    {due_date_delta_alerts_expr(db)} AS ZDUEDATEDELTAALERTSDATA,
    {due_expr()} AS ZDUEDATE, {display_due_expr(db)} AS ZDISPLAYDATEDATE,
    r.ZALLDAY, r.ZCOMPLETIONDATE, r.ZCREATIONDATE,
    r.ZPARENTREMINDER, r.ZLIST, r.ZICSURL, r.ZCKIDENTIFIER, l.ZNAME as list_name,
    {_RECURRENCE_COLS}"""

def q_reminders(db, list_pk=None, completed=False, parent_pk=None, top_level=False, limit=500):
    c, params = ["r.ZMARKEDFORDELETION = 0", "r.ZACCOUNT IS NOT NULL"], []
    if not completed: c.append("r.ZCOMPLETED = 0")
    if list_pk is not None: c.append("r.ZLIST = ?"); params.append(list_pk)
    if parent_pk is not None: c.append("r.ZPARENTREMINDER = ?"); params.append(parent_pk)
    elif top_level: c.append("(r.ZPARENTREMINDER IS NULL OR r.ZPARENTREMINDER = 0)")
    return db.execute(
        f"SELECT {rem_cols(db)} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK LIMIT ?",
        params + [limit]
    ).fetchall()

def q_reminder(db, pk):

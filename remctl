def _color_priority(pri_val):
    """Color a priority marker based on level."""
    p = PRI.get(pri_val or 0, "")
    if not p: return ""
    if pri_val == 1: return C.red(p)
    if pri_val == 5: return C.yellow(p)
    if pri_val == 9: return C.green(p)
    return p


def _item_has(item, key):
    if isinstance(item, dict):
        return key in item
    keys = getattr(item, "keys", None)
    if callable(keys):
        try:
            return key in keys()
        except Exception:
            return False
    return False


def _item_get(item, key, default=None):
    if isinstance(item, dict):
        return item.get(key, default)
    if _item_has(item, key):
        return item[key]
    return default


def _item_is_all_day(item):
    if _item_has(item, "ZALLDAY"):
        return bool(_item_get(item, "ZALLDAY"))
    return bool(_item_get(item, "allDay", False))


def row_effective_due(item):
    """Raw due timestamp used for day bucketing and human all-day labels."""
    due = _item_get(item, "ZDUEDATE", _item_get(item, "dueDate"))
    if _item_is_all_day(item):
        display = _item_get(item, "ZDISPLAYDATEDATE", _item_get(item, "displayDate"))
        if display is not None:
            return display
    return due


def _priority_value_from_item(item):

def format_command_columns(commands, width=88):
    commands = sorted(commands)
    lines = []
    current = ""
    for command in commands:
        token = command if not current else f", {command}"
        if current and len(current) + len(token) > width:
            lines.append(current)
            current = command
        else:
            current += token
    if current:
        lines.append(current)
    return lines


def first_command_token(argv):
    skip_value_for = {"--format"}
    iterator = iter(argv)
    for token in iterator:
        if token in {"-h", "--help", "--version"}:
            return None
        if token in skip_value_for:
            next(iterator, None)
            continue
        if token.startswith("--format="):
            continue
        if token == "--no-color":
            continue
        if token.startswith("-"):
            continue
        return token
    return None


def suggest_command(command, choices):
    if command == "symbols" and "list-symbols" in choices:
        return "list-symbols"
    suffix_matches = [choice for choice in choices if choice.endswith(f"-{command}")]
    if len(suffix_matches) == 1:
        return suffix_matches[0]
    return None



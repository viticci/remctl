def permission_helper_available():
    helper = current_permissions_path()
    return helper.exists() and os.access(helper, os.X_OK)


def launch_full_disk_access_helper(*, include_cli=True, wait=False):
    helper = current_permissions_path()
    if not helper.exists() or not os.access(helper, os.X_OK):
        return False
    targets = full_disk_access_target_specs(include_cli=include_cli)
    if not targets:
        targets = full_disk_access_target_specs(include_cli=True)
    args = [
        str(helper),
        "--title",
        "RemCTL Full Disk Access",
        "--subtitle",
        "Drag these targets into System Settings, or use Command-Shift-G and paste the copied path.",
    ]
    for target in targets:
        args.extend(["--target", target["title"], target["path"], target["subtitle"]])
    cli_command = shlex.quote(str(current_cli_path()))
    args.extend(["--after", "Run Doctor", f"{cli_command} doctor"])
    try:
        if wait:
            return subprocess.run(args).returncode == 0
        subprocess.Popen(args, start_new_session=True)
        return True
    except OSError:
        return False



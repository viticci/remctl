def wait_for_grocery_section(list_pk, reminder_ckid, attempts=24, delay=0.25):
    for _ in range(attempts):
        db = open_db()
        memberships = q_section_memberships(db, list_pk)
        section = memberships.get(reminder_ckid)
        if section:
            return section
        time.sleep(delay)
    return None


def apply_private_grocery_categorization(db, list_pk, reminder_ckids):
    require_private_metadata(SimpleNamespace(private=True, private_metadata=False))
    require_grocery_list_target(db, list_pk)
    ckid = q_list_ckid(db, list_pk)
    if not ckid:
        print("Error: target list has no stable CloudKit identifier.", file=sys.stderr)
        sys.exit(1)
    reminder_ckids = [ckid for ckid in reminder_ckids if ckid]
    if not reminder_ckids:
        print("Error: grocery categorization needs a stable reminder identifier.", file=sys.stderr)
        sys.exit(1)

    verified = []
    pending = []
    for reminder_ckid in reminder_ckids:
        section = wait_for_grocery_section(list_pk, reminder_ckid)
        verified.append({"id": reminder_ckid, "section": section})
        if not section:
            pending.append(reminder_ckid)

    if not pending:
        return {
            "status": "updated",
            "action": "categorize_grocery_items",
            "source": "reminders_auto",
            "verifiedSections": verified,
        }

    result = private_call({
        "action": "categorize_grocery_items",
        "listId": ckid,
        "reminderIds": pending,
    })
    if result and result.get("status") == "updated":
        result_verified = []
        for reminder_ckid in reminder_ckids:
            section = wait_for_grocery_section(list_pk, reminder_ckid)
            result_verified.append({"id": reminder_ckid, "section": section})
        result["verifiedSections"] = result_verified
        return result

    message = result.get("message") if isinstance(result, dict) else "private helper failed"
    fallback_verified = []
    for reminder_ckid in reminder_ckids:
        section = wait_for_grocery_section(list_pk, reminder_ckid)
        fallback_verified.append({"id": reminder_ckid, "section": section})
    if any(item.get("section") for item in fallback_verified):
        return {
            "status": "updated",
            "action": "categorize_grocery_items",
            "source": "reminders_auto",
            "warning": message,
            "verifiedSections": fallback_verified,
        }

    print(f"Error: {message}", file=sys.stderr)
    sys.exit(1)


def apply_private_changes(reminder_ckid, a, db=None, list_pk=None):
    require_private_metadata(a)
    results = []
    tags = split_csv(getattr(a, "tags", None))
    urls = [getattr(a, "url")] if getattr(a, "url", None) else []

    if urls or tags:
        results.append(private_action({
            "action": "add_private_metadata",
            "id": reminder_ckid,
            "urls": urls,
            "tags": tags,
        }))

    if getattr(a, "section", None) or getattr(a, "section_id", None):
        if db is None:
            db = open_db()
        section_id = resolve_section_ckid(
            db,
            list_pk,
            section_name=getattr(a, "section", None),
            section_id=getattr(a, "section_id", None),
        )
        results.append(private_action({
            "action": "assign_section",
            "id": reminder_ckid,
            "sectionId": section_id,
        }))

    if getattr(a, "new_section", None):
        results.append(private_action({
            "action": "add_section_and_assign",
            "id": reminder_ckid,
            "name": a.new_section,
        }))

    subtasks = parse_subtask_specs(getattr(a, "subtask", None))
    if subtasks:
        subtask_result = private_action({
            "action": "add_subtasks",
            "id": reminder_ckid,
            "subtasks": subtasks,
        })
        bridge_updates = []
        child_private_updates = []
        for spec, subtask in zip(subtasks, subtask_result.get("subtasks", [])):
            subtask_id = subtask.get("id") if isinstance(subtask, dict) else None
            if subtask_id:
                private_updates = apply_subtask_private_metadata(subtask_id, spec)
                if private_updates:
                    child_private_updates.append({
                        "id": subtask_id,
                        "title": spec["title"],
                        "updates": private_updates,
                    })
                bridge_update = bridge_update_subtask(subtask_id, spec)
                if bridge_update:
                    bridge_updates.append({
                        "id": subtask_id,
                        "title": spec["title"],
                        "status": bridge_update.get("status"),
                    })
        if subtask_specs_need_bridge(subtasks) and len(bridge_updates) < sum(1 for spec in subtasks if subtask_specs_need_bridge([spec])):
            print("Error: private helper did not return subtask IDs for bridge metadata updates.", file=sys.stderr)
            sys.exit(1)
        if bridge_updates:
            subtask_result["bridgeUpdates"] = bridge_updates
        if child_private_updates:
            subtask_result["childPrivateUpdates"] = child_private_updates
        results.append(subtask_result)

    images = normalize_image_paths(getattr(a, "image", None))
    if images:
        results.append(private_action({
            "action": "add_attachments",
            "id": reminder_ckid,
            "files": [],
            "images": images,
        }))

    flagged_value = getattr(a, "flagged", None)
    if flagged_value is None and getattr(a, "flag", False):
        flagged_value = True
    if flagged_value is not None:
        results.append(private_action({
            "action": "set_flagged",
            "id": reminder_ckid,
            "flagged": bool(flagged_value),
        }))

    if getattr(a, "urgent", None) is not None:
        results.append(private_action({
            "action": "set_urgent",
            "id": reminder_ckid,
            "urgent": bool(a.urgent),
        }))

    if getattr(a, "latitude", None) is not None or getattr(a, "longitude", None) is not None:
        if getattr(a, "latitude", None) is None or getattr(a, "longitude", None) is None:
            print("Error: location alarms require both --latitude and --longitude", file=sys.stderr)
            sys.exit(1)
        proximity = 2 if getattr(a, "proximity", "arriving") == "leaving" else 1
        results.append(private_action({
            "action": "add_location_alarm",
            "id": reminder_ckid,
            "title": getattr(a, "location_title", None) or "Location",
            "latitude": a.latitude,
            "longitude": a.longitude,
            "radius": getattr(a, "radius", None) or 100,
            "proximity": proximity,
            "address": getattr(a, "address", None),
        }))

    if getattr(a, "grocery", False):
        if db is None:
            db = open_db()
        if list_pk is None:
            print("Error: --grocery requires a target list.", file=sys.stderr)
            sys.exit(1)
        results.append(apply_private_grocery_categorization(db, list_pk, [reminder_ckid]))

    return results


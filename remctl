# ── Bridge Integration ───────────────────────────────────────────────────────

def bridge_available():
    """Check if remctl-bridge (Swift EventKit binary) is available."""
    return BRIDGE_PATH.exists() and BRIDGE_PATH.stat().st_mode & 0o111


def bridge_error_payload(status, message, stderr=""):
    return {
        "returncode": -1,
        "stdout": "",
        "stderr": stderr,
        "payload": {"status": status, "message": message},
    }


def bridge_call_result(data, timeout=30):
    """Call remctl-bridge and return raw subprocess + parsed JSON details."""
    try:
        proc = subprocess.run(
            [str(BRIDGE_PATH)], input=json.dumps(data),
            capture_output=True, text=True, timeout=timeout
        )
    except subprocess.TimeoutExpired:
        return bridge_error_payload("timeout", f"remctl-bridge did not respond within {timeout}s.")
    except FileNotFoundError:
        return bridge_error_payload(
            "missing_bridge",
            f"remctl-bridge not found at {BRIDGE_PATH}. Reinstall remctl with ./install.sh.",
        )
    except OSError as exc:
        return bridge_error_payload("exec_error", f"could not run remctl-bridge: {exc}", str(exc))

    payload = None
    if proc.stdout:
        try:
            payload = json.loads(proc.stdout)
        except json.JSONDecodeError:
            payload = None
    if not isinstance(payload, dict):
        detail = (proc.stderr or proc.stdout or "").strip()
        payload = {
            "status": "error",
            "message": detail or f"remctl-bridge exited {proc.returncode} with no JSON output.",
        }
    return {
        "returncode": proc.returncode,
        "stdout": proc.stdout,
        "stderr": proc.stderr,
        "payload": payload,
    }

def bridge_call(data):
    """Call remctl-bridge with JSON data. Returns parsed JSON response."""
    result = bridge_call_result(data)
    if result and result["returncode"] == 0 and isinstance(result["payload"], dict):
        return result["payload"]
    return None


def bridge_result_ok(result, *statuses):
    if not result or result.get("returncode") != 0:
        return False
    payload = result.get("payload")
    if not isinstance(payload, dict):
        return False
    return payload.get("status") in statuses


def bridge_failure_message(result):
    if not result:
        return "remctl-bridge did not return a response."
    payload = result.get("payload")
    if isinstance(payload, dict):
        message = payload.get("message") or payload.get("error")
        if message:
            return str(message)
    detail = (result.get("stderr") or result.get("stdout") or "").strip()
    if detail:
        return detail
    return f"remctl-bridge exited with status {result.get('returncode')}"


def bridge_failure_is_access_error(result):
    message = bridge_failure_message(result).lower()
    needles = [
        "eventkit access error",
        "reminders access not granted",
        "not authorized",
        "authorization",
        "not permitted",
        "mach error 4099",
    ]
    return any(needle in message for needle in needles)


def bridge_failure_is_list_move_rejection(result):
    message = bridge_failure_message(result).lower()
    if "update failed:" not in message and "save failed:" not in message:
        return False
    exclusions = [
        "not found",
        "invalid",
        "required",
        "calendar item",
        "identifier",
    ]
    if any(exclusion in message for exclusion in exclusions):
        return False
    needles = [
        "calendar",
        "container",
        "account",
        "caldav",
        "different store",
        "different source",
        "not editable",
        "not writable",
        "immutable",
        "move",
    ]
    return any(needle in message for needle in needles)


def bridge_failure_allows_clone_delete_fallback(result):
    if not result or result.get("returncode") == 0 or bridge_failure_is_access_error(result):
        return False
    payload = result.get("payload")
    status = payload.get("status") if isinstance(payload, dict) else None
    if status in {"timeout", "missing_bridge", "exec_error"}:
        return False
    return bridge_failure_is_list_move_rejection(result)


def bridge_failure_is_execution_error(result):
    payload = result.get("payload") if result else None
    status = payload.get("status") if isinstance(payload, dict) else None
    return status in {"timeout", "missing_bridge", "exec_error"}


def eventkit_access_fix_text(*, rerun_command="remctl doctor --for-agent"):
    context = doctor_execution_context()
    effective_context = context.get("effective_context") or "this runner"
    host_app = context.get("host_app") or "the app or terminal launching remctl"
    return "\n".join([
        f"EventKit writes are blocked in the current process context: {effective_context}.",
        f"Host app: {host_app}.",
        "Run `remctl onboard` from this same context so macOS can grant Reminders access.",
        f"Then rerun `{rerun_command}` from the same context before writing.",
        "If the same command works in Terminal but fails here, Terminal's permission grant does not carry over to this app or agent runner.",
    ])


def fail_bridge_write(result, *, operation):
    message = bridge_failure_message(result)
    print(f"Error: remctl-bridge failed while trying to {operation}: {message}", file=sys.stderr)
    if bridge_failure_is_access_error(result):
        print(eventkit_access_fix_text(), file=sys.stderr)
    sys.exit(1)


NUDGE_PREP_WARNING = (

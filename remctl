def get_completion_script(shell):
    if shell == "zsh":
        source_path = Path(__file__).resolve().parent / "completions" / "_remctl"
        if source_path.exists():
            return source_path.read_text()
        return ZSH_COMPLETION
    if shell == "bash":
        return BASH_COMPLETION
    if shell == "fish":
        return FISH_COMPLETION
    raise ValueError(f"Unsupported shell '{shell}'")


def detect_shell_name():
    shell = os.environ.get("SHELL", "")
    return Path(shell).name if shell else "zsh"


def completion_target_path(shell):
    if shell == "zsh":
        return Path.home() / ".zsh" / "completions" / "_remctl"
    if shell == "bash":
        return Path.home() / ".local" / "share" / "bash-completion" / "completions" / "remctl"
    if shell == "fish":
        return Path.home() / ".config" / "fish" / "completions" / "remctl.fish"
    raise ValueError(f"Unsupported shell '{shell}'")


def install_completion(shell):
    target = completion_target_path(shell)
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(get_completion_script(shell))
    return target


def resolve_setup_shell(requested_shell):
    if requested_shell != "auto":
        return requested_shell
    detected = detect_shell_name()
    return detected if detected in {"zsh", "bash", "fish"} else "skip"



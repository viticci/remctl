def q_section_memberships(db, list_pk):
    row = db.execute(
        "SELECT ZMEMBERSHIPSOFREMINDERSINSECTIONSASDATA FROM ZREMCDBASELIST WHERE Z_PK = ?",
        (list_pk,)
    ).fetchone()
    if not row or not row[0]: return {}
    try:
        data = json.loads(row[0])
    except (json.JSONDecodeError, TypeError):
        return {}
    sections = db.execute(
        "SELECT ZCKIDENTIFIER, ZDISPLAYNAME FROM ZREMCDBASESECTION "
        "WHERE ZLIST = ? AND ZMARKEDFORDELETION = 0", (list_pk,)
    ).fetchall()
    g2n = {s["ZCKIDENTIFIER"]: s["ZDISPLAYNAME"] for s in sections}
    return {
        m["memberID"]: g2n[m["groupID"]]
        for m in data.get("memberships", [])
        if m.get("groupID") in g2n and m.get("memberID")
    }

def q_section_member_counts(db, list_pk):
    row = db.execute(
        "SELECT ZMEMBERSHIPSOFREMINDERSINSECTIONSASDATA FROM ZREMCDBASELIST WHERE Z_PK = ?",
        (list_pk,)
    ).fetchone()
    if not row or not row[0]:
        return {}
    try:
        data = json.loads(row[0])
    except (json.JSONDecodeError, TypeError):
        return {}
    counts = {}
    for membership in data.get("memberships", []):
        if membership.get("isObsolete"):
            continue
        group_id = membership.get("groupID")
        member_id = membership.get("memberID")
        if group_id and member_id:
            counts[group_id] = counts.get(group_id, 0) + 1
    return counts



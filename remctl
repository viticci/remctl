def location_alarm_exists(reminder_ckid, *, title=None, latitude=None, longitude=None):
    try:
        db = open_db()
        row = q_reminder_by_identifier(db, reminder_ckid)
        if not row:
            return False
        for alarm in alarm_rows_to_json(q_alarms(db, row["Z_PK"])):
            if alarm.get("type") != "location":
                continue
            location = alarm.get("location", {})
            if title and location.get("title") != title:
                continue
            if latitude is not None and abs(float(location.get("latitude")) - float(latitude)) > 0.0001:
                continue
            if longitude is not None and abs(float(location.get("longitude")) - float(longitude)) > 0.0001:
                continue
            return True
    except (RemindersDBUnavailable, sqlite3.Error, TypeError, ValueError):
        return False
    return False


IDEMPOTENT_PRIVATE_ACTIONS = {
    "assign_section",
    "assign_sharee",
    "clear_assignment",
    "set_flagged",
    "set_urgent",
    "set_early_reminder",
}


def fail_private_add_partial(partial_context, failed_action, error_message):
    if partial_context.get("json"):
        payload = {
            "status": "partial",
            "id": partial_context.get("id", ""),
            "failed": failed_action,
            "error": error_message,
        }
        numeric_id = partial_context.get("numericId")
        if numeric_id is not None:
            payload["numericId"] = numeric_id
        completed = partial_context.get("completed")
        if completed:
            payload["completed"] = completed
        print(json.dumps(payload))
    else:
        numeric_id = partial_context.get("numericId")
        if numeric_id is not None:
            ident = f"#{numeric_id}"
        else:
            ident = partial_context.get("id") or "(unknown)"
        print(
            f"Created reminder {ident} but failed to apply {failed_action}; "
            "re-run edit to finish. Do NOT re-run add (would duplicate).",
            file=sys.stderr,
        )
        print(f"Error: {error_message}", file=sys.stderr)
    sys.exit(1)


def private_action(data, partial_context=None):
    attempts = 3 if data.get("action") in IDEMPOTENT_PRIVATE_ACTIONS else 1
    result = None
    for attempt in range(attempts):
        result = private_call(data)
        if result and result.get("status") == "updated":
            if partial_context is not None:
                partial_context.setdefault("completed", []).append(data.get("action", "private_action"))
            return result
        if not private_helper_error_is_transient(result) or attempt == attempts - 1:
            break
        time.sleep(0.5)
    if not result or result.get("status") != "updated":
        message = result.get("message") if isinstance(result, dict) else "private helper failed"
        if partial_context is not None:
            fail_private_add_partial(partial_context, data.get("action", "private_action"), message)
        print(f"Error: {message}", file=sys.stderr)
        sys.exit(1)
    return result


def subtask_rows_for_parent_move(db, reminder):
    try:
        parent_pk = reminder["Z_PK"]
    except (KeyError, TypeError):

def main():
    p, sub = build_parser()
    # --- Parse ---
    a = parse_cli_args(p, sub)
    command_format = getattr(a, "command_format", None)
    if command_format:
        a.format = command_format

    # Image rendering: env vars provide defaults, CLI flags win.
    if not a.images:
        a.images = env_bool("REMCTL_IMAGES")
    if a.image_mode is None:
        env_mode = os.environ.get("REMCTL_IMAGE_MODE", "").strip().lower()
        if env_mode in IMAGE_MODES:
            a.image_mode = None if env_mode == "none" else env_mode
        elif env_mode:
            print(f"remctl: ignoring unknown REMCTL_IMAGE_MODE {env_mode!r} "
                  f"(expected one of: {', '.join(m for m in IMAGE_MODES if m != 'none')}, none)", file=sys.stderr)
    if a.image_mode == "none":
        a.images = False
        a.image_mode = None
    if a.image_width is None:
        env_width = os.environ.get("REMCTL_IMAGE_WIDTH", "").strip()
        try:
            a.image_width = int(env_width) if env_width else None
        except ValueError:
            a.image_width = None
        if env_width and a.image_width is None:
            print(f"remctl: ignoring invalid REMCTL_IMAGE_WIDTH {env_width!r} (expected a positive integer)", file=sys.stderr)
    if a.image_width is not None and a.image_width < 1:
        a.image_width = None

    # Set up color
    if a.no_color or os.environ.get("NO_COLOR") or not sys.stdout.isatty():
        C.enabled = False

    # Propagate global --format to json flag where needed
    if a.format == "json" and not hasattr(a, 'json'):
        a.json = True
    elif a.format == "json" and hasattr(a, 'json'):
        a.json = True

    maybe_run_first_launch_onboarding(a)

    # No command: splash screen + today
    if not a.cmd:
        a.no_overdue = False
        a.verbose = False
        if a.format == "json":
            a.json = True
            run_handler_with_fallback(a, cmd_today)
        else:
            a.json = False
            show_splash()
            run_handler_with_fallback(a, cmd_today)
        return

    # Propagate --format table to subcommand

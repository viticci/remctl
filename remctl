def _badges_from_item(item, db=None, _ind=None):
    """Trailing one-liner badge flags {"image": bool, "link": bool}.

    Consumes the preload_indicators batch map; only when the map is None AND
    db is real does it fall back to two direct guarded queries (mirrors the
    _sc/_ht fallback shape).
    """
    none = {"image": False, "link": False}
    if not _item_has(item, "Z_PK"):
        return none
    pk = item["Z_PK"]
    if _ind is not None:
        return _ind.get(pk, none)
    if db is None:
        return none
    image = False
    try:
        for a in q_attachments(db, pk):
            if _row_get(a, "ZATTACHMENTTYPERAWVALUE") == "image":
                image = True
                break
    except Exception:
        image = False
    try:
        link = bool(q_rich_links(db, pk))
    except Exception:
        link = False
    return {"image": image, "link": link}


RECURRENCE_DAY_NAMES = {
    1: "Sun",
    2: "Mon",
    3: "Tue",
    4: "Wed",
    5: "Thu",
    6: "Fri",
    7: "Sat",
}


def _recurrence_from_item(item):
    if _item_has(item, "recurrence"):
        return _item_get(item, "recurrence")
    return recurrence_from_row(item, ts=ts)


def _recurrence_weekday_specs(recurrence):
    """Return [(dayOfTheWeek, weekNumber)] pairs; weekNumber 0 means every week."""
    detailed = recurrence.get("daysOfWeekDetailed") or []
    if detailed:
        return [
            (int(item.get("dayOfTheWeek", 0)), int(item.get("weekNumber") or 0))
            for item in detailed
            if isinstance(item, dict) and item.get("dayOfTheWeek")
        ]
    days = recurrence.get("daysOfWeek") or []
    weeks = recurrence.get("weekNumbers") or []
    return [
        (int(day), int(weeks[idx]) if idx < len(weeks) else 0)
        for idx, day in enumerate(days)
    ]


def _weekday_spec_label(day, week):
    name = RECURRENCE_DAY_NAMES.get(day, str(day))
    if not week:
        return name
    if week == -1:
        return f"last {name}"
    if week < 0:
        week = abs(week)
        suffix = {1: "st", 2: "nd", 3: "rd"}.get(week if week < 20 else week % 10, "th")
        return f"{week}{suffix}-last {name}"
    suffix = {1: "st", 2: "nd", 3: "rd"}.get(week if week < 20 else week % 10, "th")
    return f"{week}{suffix} {name}"


def recurrence_summary(recurrence):
    if not recurrence:
        return ""
    frequency = recurrence.get("frequency")
    interval = int(recurrence.get("interval") or 1)
    units = {
        "daily": ("day", "days"),
        "weekly": ("week", "weeks"),
        "monthly": ("month", "months"),
        "yearly": ("year", "years"),
    }
    if frequency not in units:
        return ""
    singular, plural = units[frequency]
    if interval == 1:
        label = frequency
    else:
        label = f"every {interval} {plural}"

    day_specs = _recurrence_weekday_specs(recurrence)
    if frequency in ("weekly", "monthly", "yearly") and day_specs:
        label += " " + ", ".join(_weekday_spec_label(day, week) for day, week in day_specs)

    days_of_month = recurrence.get("daysOfMonth") or []
    if frequency == "monthly" and days_of_month:
        label += " on " + ", ".join(str(day) for day in days_of_month)

    count = recurrence.get("count")
    if count:
        label += f" x{count}"
    elif recurrence.get("endDate"):
        label += f" until {str(recurrence['endDate'])[:10]}"

    return label


def recurrence_badge(item):
    summary = recurrence_summary(_recurrence_from_item(item))
    return C.magenta(f"↻ {summary}") if summary else ""


def fmt(r, db=None, verbose=False, indent="", _sc=None, _ht=None, _img=None, _ind=None):
    completed = r["ZCOMPLETED"] if _item_has(r, "ZCOMPLETED") else bool(_item_get(r, "completed"))
    if completed:
        status = C.green("[x]")
    else:
        status = C.dim("[ ]")
    markers = _state_markers(r)
    marker_str = f" {markers}" if markers else ""
    pri_val = _priority_value_from_item(r)
    sc = _subtask_count_from_item(r, db=db, _sc=_sc)
    tags = _tags_from_item(r, db=db, _ht=_ht)
    tag_str = " " + " ".join(f"#{safe_display(t)}" for t in tags) if tags else ""
    sub_str = f" [{sc} subtask{'s' if sc != 1 else ''}]" if sc > 0 else ""
    badges = _badges_from_item(r, db=db, _ind=_ind)
    # Rich link first (reads better next to tags), then the image marker.
    badge_str = (" 🔗" if badges["link"] else "") + (" 🌄" if badges["image"] else "")
    pri_str = f" {_color_priority(pri_val)}" if PRI.get(pri_val, "") else ""
    assignment = _assignment_from_item(r, db)
    assign_str = ""
    if assignment and assignment.get("assignee", {}).get("name"):
        assign_str = f" @{safe_display(assignment['assignee']['name'])}"
    id_str = reminder_id_from_item(r, db)
    title = safe_display((r["ZTITLE"] if _item_has(r, "ZTITLE") else _item_get(r, "title")) or "(untitled)")
    all_day = _item_is_all_day(r)
    due_str = fmt_due(row_effective_due(r), all_day=all_day)
    repeat_badge = recurrence_badge(r)
    recur_str = f" {repeat_badge}" if repeat_badge else ""
    if completed:
        title = C.dim(C.strikethrough(title))
        due_str = C.dim(due_str)
        recur_str = C.dim(recur_str)
        tag_str = C.dim(tag_str)
        sub_str = C.dim(sub_str)
        assign_str = C.dim(assign_str)
    parts = [f"{indent}{status} {id_str}{pri_str}{marker_str} {title}{due_str}{recur_str}{assign_str}{tag_str}{sub_str}{badge_str}"]
    if verbose:
        list_name = _list_name_from_item(r)
        if list_name:
            parts.append(f"{indent}    List: {color_list_name(list_name, db)}")
        notes = r["ZNOTES"] if _item_has(r, "ZNOTES") else _item_get(r, "notes")
        if notes:
            parts.append(f"{indent}    Notes: {C.dim(safe_display(notes)[:200])}")
        url = _url_from_item(r)
        if url:
            parts.append(f"{indent}    URL: {C.dim(safe_display(url))}")
        recurrence = recurrence_summary(_recurrence_from_item(r))
        if recurrence:
            parts.append(f"{indent}    Repeats: {C.magenta(recurrence)}")
        if all_day:
            parts.append(f"{indent}    All-day: {C.cyan('Yes')}")
        early_reminders = due_date_delta_alerts_from_row(r, ts=ts)
        if not early_reminders and db is not None and _item_has(r, "ZCKIDENTIFIER"):
            try:
                early_reminders = due_date_delta_alert_rows_to_json(q_due_date_delta_alerts(db, r["ZCKIDENTIFIER"]))
            except (sqlite3.Error, ValueError):
                early_reminders = []
        if early_reminders:
            labels = ", ".join(item["label"] for item in early_reminders)
            parts.append(f"{indent}    Early: {C.cyan(labels)}")
        if assignment and assignment.get("assignee", {}).get("name"):
            parts.append(f"{indent}    Assigned: {C.cyan(safe_display(assignment['assignee']['name']))}")
        if _item_is_flagged(r):
            parts.append(f"{indent}    Flagged: {C.yellow('Yes')}")
        if _item_is_urgent(r):
            parts.append(f"{indent}    Urgent: {C.red('Yes')}")
        if _img and db is not None and _item_has(r, "Z_PK"):
            mode, width = _img
            try:
                att_rows = q_attachments(db, r["Z_PK"])
            except Exception:
                att_rows = []
            for a2 in att_rows:
                rendered = _render_attachment_row(a2, mode, width)
                if rendered == "unresolved":
                    suffix = C.dim(" (file not downloaded on this Mac)")
                elif rendered is None:
                    suffix = C.dim(" (preview unavailable)")
                else:
                    suffix = ""
                parts.append(
                    f"{indent}    Attachment: {safe_display(a2['ZFILENAME'] or 'untitled')}"
                    f" ({safe_display(a2['ZATTACHMENTTYPERAWVALUE'] or '?')}){suffix}"
                )
                if rendered not in (None, "unresolved"):
                    parts.append(rendered)
    return "\n".join(parts)

def to_dict(r, db=None, section=None, _sc=None, _ht=None, _att=None):
    payload = serialize_reminder(
        r,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        section=section,
        subtask_counts=_sc,
        hashtags=_ht,
        rich_link_resolver=q_rich_link,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
    )
    if db is not None and _item_has(r, "Z_PK"):
        try:
            if _att is not None:
                # Batch path: callers preload the page's attachment rows once
                # and hand them in, avoiding a per-reminder query.
                att_rows = _att.get(r["Z_PK"], [])
            else:
                att_rows = q_attachments(db, r["Z_PK"])
            attachment_payload = attachment_rows_to_json(att_rows)
        except Exception:
            attachment_payload = []
        if attachment_payload:
            payload["attachments"] = attachment_payload
        assignment = assignment_to_dict(q_assignment(db, r["Z_PK"]))
        if assignment:
            payload["assignment"] = assignment
        if not payload.get("earlyReminders"):
            alerts = due_date_delta_alert_rows_to_json(q_due_date_delta_alerts(db, _row_get(r, "ZCKIDENTIFIER")))
            if alerts:
                payload["earlyReminder"] = alerts[0]
                payload["earlyReminders"] = alerts
    return payload

def reminders_to_dicts(items, db=None, memberships=None):
    payloads = serialize_reminders(
        items,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        memberships=memberships,
        rich_link_resolver=q_rich_link,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
        attachment_rows_to_json=attachment_rows_to_json if db is not None else None,
    )
    if db is not None:
        for item, payload in zip(items, payloads):
            if _item_has(item, "Z_PK"):
                assignment = assignment_to_dict(q_assignment(db, item["Z_PK"]))
                if assignment:
                    payload["assignment"] = assignment
                if not payload.get("earlyReminders"):
                    alerts = due_date_delta_alert_rows_to_json(q_due_date_delta_alerts(db, _row_get(item, "ZCKIDENTIFIER")))
                    if alerts:
                        payload["earlyReminder"] = alerts[0]
                        payload["earlyReminders"] = alerts
    return payloads

# ── Inline Images ────────────────────────────────────────────────────────────

def _image_render_enabled(a):
    """True when inline image rendering is allowed for this invocation."""
    if not getattr(a, "images", False):
        return False
    if getattr(a, "json", False) or getattr(a, "format", "plain") == "table":
        return False
    if not C.enabled:
        return False
    # REMCTL_IMAGES_FORCE bypasses ONLY the isatty check (test-only escape hatch).
    if not sys.stdout.isatty() and not env_bool("REMCTL_IMAGES_FORCE"):
        return False
    return True


def _default_image_width(mode=None):
    """Terminal-relative default render width in cells.

    Used when neither --image-width nor REMCTL_IMAGE_WIDTH is set. Aims for
    ~40% of the terminal, capped to [24, 100]; half-block gets a lower cap
    because two pixel rows per cell make it read large. Falls back to 48
    when the terminal size can't be determined.
    """
    cap = 64 if mode == "halfblock" else 100
    try:
        cols = os.get_terminal_size().columns
    except OSError:
        return 48
    return max(24, min(cap, int(cols * 0.4)))


def _image_render_config(a):
    """(mode, width) when inline rendering is active, else None."""
    if not _image_render_enabled(a):
        return None
    mode = getattr(a, "image_mode", None) or detect_image_mode()
    if not mode:
        return None
    return mode, _resolve_image_width(a, mode)


def _resolve_image_width(a, mode):
    """Explicit flag/env width wins; otherwise the terminal-relative default."""
    explicit = getattr(a, "image_width", None)
    if explicit:
        return explicit
    return _default_image_width(mode)


def _image_render_config_verbose(a):
    """Image config for list commands: only with --verbose (quiet by default)."""
    if not getattr(a, "verbose", False):
        return None
    return _image_render_config(a)


def _render_attachment_row(row, mode, width):
    """Rendered string for one attachment row, or None.

    Unresolved files yield the 'not downloaded' suffix marker; resolved but
    unrenderable files yield the 'preview unavailable' marker.
    """
    payload = attachment_row_to_json(row)
    path = payload.get("path")
    if not path:
        return "unresolved"
    return render_attachment(path, mode, width)


# ── Table Format ─────────────────────────────────────────────────────────────

def _strip_ansi(s):
    """Remove ANSI escape codes for width calculation."""
    return re.sub(r'\033\[[0-9;]*m', '', s)

def _cell_width_char(ch):
    if not ch:
        return 0
    code = ord(ch)
    if code == 0x200D or 0xFE00 <= code <= 0xFE0F:
        return 0
    if unicodedata.combining(ch):
        return 0
    category = unicodedata.category(ch)
    if category in {"Cc", "Cf"}:
        return 0
    return 2 if unicodedata.east_asian_width(ch) in {"F", "W"} else 1

def _visible_len(s):
    """Terminal cell width of string as displayed (without ANSI codes)."""
    return sum(_cell_width_char(ch) for ch in _strip_ansi(str(s)))

def _pad(s, width):
    """Pad string to width, accounting for ANSI codes."""
    visible = _visible_len(s)
    return s + " " * max(0, width - visible)

def _truncate_visible(s, width):
    plain = _strip_ansi(str(s))
    if _visible_len(plain) <= width:
        return str(s)
    if width <= 1:
        return "…"[:width]
    target = width - 1
    out = []
    used = 0
    for ch in plain:
        ch_width = _cell_width_char(ch)
        if used + ch_width > target:
            break
        out.append(ch)
        used += ch_width
    return "".join(out) + "…"

def fmt_table(rows_data, max_width=None, *, date_mode="due", include_list=True, columns=None):
    """Format data as a Unicode box-drawing table.

    rows_data: list of dicts with keys: id, title, list, due, repeat, pri
    """
    if not rows_data:
        return ""
    if max_width is None:
        try:
            max_width = os.get_terminal_size().columns
        except (ValueError, OSError):
            max_width = 80

    if columns is None:
        date_key, date_label = ("completed", "Completed") if date_mode == "completed" else ("due", "Due")
        columns = [("id", "ID"), ("title", "Title")]
        if include_list:
            columns.append(("list", "List"))
        columns.append((date_key, date_label))
        if any(row.get("repeat") for row in rows_data):
            columns.append(("repeat", "Repeat"))
        columns.append(("pri", "Pri"))
    headers = [label for _, label in columns]
    # Calculate column widths
    col_widths = [len(h) for h in headers]
    for row in rows_data:
        vals = [row.get(key, "") for key, _ in columns]
        for i, v in enumerate(vals):
            col_widths[i] = max(col_widths[i], _visible_len(str(v)))

    # Cap title column so table fits terminal
    title_index = next(i for i, (key, _) in enumerate(columns) if key == "title")
    fixed = sum(width for i, width in enumerate(col_widths) if i != title_index) + 3 * len(columns) + 1
    max_title = max(10, max_width - fixed)
    col_widths[title_index] = min(col_widths[title_index], max_title)

    def hline(left, mid, right, fill="─"):
        parts = [left]
        for i, w in enumerate(col_widths):
            parts.append(fill * (w + 2))
            parts.append(mid if i < len(col_widths) - 1 else "")
        parts.append(right)
        return "".join(parts)

    def row_line(vals):
        cells = []
        for i, v in enumerate(vals):
            s = str(v)
            # Truncate if needed (by visible length)
            if _visible_len(s) > col_widths[i]:
                s = _truncate_visible(s, col_widths[i])
            cells.append(f" {_pad(s, col_widths[i])} ")
        return "│" + "│".join(cells) + "│"

    lines = []
    lines.append(hline("┌", "┬", "┐"))
    lines.append(row_line([C.bold(h) for h in headers]))
    lines.append(hline("├", "┼", "┤"))
    for row in rows_data:
        vals = [str(row.get(key, "")) for key, _ in columns]
        lines.append(row_line(vals))
    lines.append(hline("└", "┴", "┘"))
    return "\n".join(lines)

def _format_completed_for_table(r):
    value = _item_get(r, "ZCOMPLETIONDATE")
    if value is None:
        value = _item_get(r, "completionDate")
    if not value:
        return ""
    if isinstance(value, str):
        try:
            dt = datetime.fromisoformat(value)
        except ValueError:
            return safe_display(value)
    else:
        dt = ts(value)
    if not dt:
        return ""
    return dt.strftime("%Y-%m-%d %H:%M")

def reminders_to_table_data(items, db=None):
    """Convert reminder rows to table-friendly dicts."""
    data = []
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    for r in items:
        due_str = ""
        all_day = _item_is_all_day(r)
        due_value = row_effective_due(r)
        if due_value:
            if isinstance(due_value, str):
                try:
                    dt = datetime.fromisoformat(due_value)
                except ValueError:
                    dt = None
            else:
                dt = ts(due_value)
        else:
            dt = None
        if dt:
            if dt.date() == sod.date():
                due_str = "Today"
                if not all_day and (dt.hour or dt.minute):
                    due_str += f" {dt.strftime('%H:%M')}"
            elif dt.date() == (sod + timedelta(days=1)).date():
                due_str = "Tomorrow"
            elif dt < now:
                due_str = C.red(f"Overdue {(now - dt).days}d")
            else:
                due_str = dt.strftime("%Y-%m-%d")
        pri_val = _priority_value_from_item(r)
        pri_str = _color_priority(pri_val) if PRI.get(pri_val, "") else ""
        title = safe_display((r["ZTITLE"] if _item_has(r, "ZTITLE") else _item_get(r, "title")) or "(untitled)")
        markers = _state_markers(r)
        if markers:
            title = f"{markers} {title}"
        list_name = _list_name_from_item(r) or ""
        if db and C.enabled:
            list_name = color_list_name(list_name, db)
        else:
            list_name = safe_display(list_name)
        repeat = recurrence_summary(_recurrence_from_item(r))
        data.append({
            "id": reminder_id_from_item(r, db),
            "title": title,
            "list": list_name,
            "due": due_str,
            "completed": _format_completed_for_table(r),
            "repeat": C.magenta(repeat) if repeat else "",
            "pri": pri_str,
        })
    return data

def reminder_table_date_mode(args):

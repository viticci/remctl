def gather_onboarding_checks():
    checks = [
        open_reminders_app_for_onboarding(),
        bridge_access_check_for_onboarding(),
        applescript_access_check_for_onboarding(),
    ]
    service = launch_agent_status()
    api_check = local_api_check_for_onboarding() if service["installed"] else None
    db_check = database_access_check_for_onboarding(api_check=api_check)
    checks.append(db_check)
    if api_check and (db_check["status"] != "ok" or api_check["status"] == "ok"):
        checks.append(api_check)
    return checks


def run_onboarding(*, auto=False):
    ensure_api_token()
    checks = gather_onboarding_checks()
    fail_count = sum(1 for check in checks if check["status"] == "fail")
    warn_count = sum(1 for check in checks if check["status"] == "warn")
    result = {
        "ok": fail_count == 0,
        "warnings": warn_count,
        "failures": fail_count,
        "checks": checks,
    }
    write_onboard_state(result, auto=auto)
    return result


def should_auto_onboard(args):
    if sys.platform != "darwin":
        return False
    if os.environ.get(AUTO_ONBOARD_SKIP_ENV):
        return False
    if getattr(args, "cmd", None) in AUTO_ONBOARD_SKIP_COMMANDS:
        return False
    if getattr(args, "json", False) or getattr(args, "format", None) == "json":
        return False
    if not sys.stdout.isatty():
        return False
    return load_onboard_state() is None


def maybe_run_first_launch_onboarding(args):
    if not should_auto_onboard(args):
        return None
    print(C.bold("First launch detected. Running remctl onboard."))
    print(C.dim("Approve any macOS prompts for Reminders or Automation access, then the original command will continue."))
    print()
    result = run_onboarding(auto=True)
    print_check_report("RemCTL onboard", result["checks"])
    database_check = next((check for check in result["checks"] if check["name"] == "database"), None)
    api_check = next((check for check in result["checks"] if check["name"] == "local_api"), None)
    if needs_full_disk_access_guidance(database_check):
        print_full_disk_access_guidance(
            api_healthy=bool(api_check and api_check["status"] == "ok"),
            settings_opened=False,
            rerun_command="remctl doctor",
        )
    print()
    return result

# ── AppleScript ──────────────────────────────────────────────────────────────

def osa(script):
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        print("Error: AppleScript timed out (Reminders.app may be unresponsive)", file=sys.stderr)
        sys.exit(1)
    if r.returncode != 0:
        print(f"AppleScript error: {r.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return r.stdout.strip()

def osa_by_id(list_name, rem_id, action):
    """Run AppleScript action on a reminder matched by its x-apple-reminder ID."""
    return osa(
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )

def osa_by_id_try(list_name, rem_id, action, timeout=120):
    """Non-fatal variant: returns True on success, False on failure.
    Used for AppleScript-first write paths that want to fall back to bridge.

    Reminders.app AppleScript dispatch can be slow (30–90s) on busy stores,
    especially after a remindd restart. Use a generous timeout — slow sync
    beats silent data loss."""
    script = (
        f'tell application "Reminders"\n'
        f'tell list "{esc(list_name)}"\n'
        f'set r to (first reminder whose id is "{esc(rem_id)}")\n'
        f'{action}\n'
        f'end tell\n'
        f'end tell'
    )
    try:
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0
    except subprocess.TimeoutExpired:
        return False

def esc(s):
    """Escape a string for AppleScript double-quoted literals.
    Covers backslash, double-quote, and every kind of control/line-break
    character that can terminate an AppleScript string (\n, \r, \t, U+0085,
    U+2028, U+2029)."""
    s = s.replace("\\", "\\\\").replace('"', '\\"')
    for ch in ("\r", "\n", "\t", "\u0085", "\u2028", "\u2029"):
        s = s.replace(ch, " ")
    # Strip remaining ASCII control chars (0x00-0x1F except already-handled)
    return "".join(c if ord(c) >= 0x20 else " " for c in s)

def applescript_date_var(dt, varname="d"):
    """Build a locale-neutral AppleScript snippet that defines `<varname>` as
    the given local datetime via numeric field-assignment. This works on any
    macOS locale; `date "..."` parsing breaks on non-English locales and
    silently falls through to the bridge (which has its own sync gotchas).
    All values are bounded ints — no user-input interpolation."""
    return (
        f'set {varname} to current date\n'
        f'set year of {varname} to {dt.year}\n'
        f'set month of {varname} to {dt.month}\n'
        f'set day of {varname} to {dt.day}\n'
        f'set hours of {varname} to {dt.hour}\n'
        f'set minutes of {varname} to {dt.minute}\n'
        f'set seconds of {varname} to {dt.second}'
    )

def as_date_assign(dt, target="due date of r"):
    """Return an AppleScript snippet that assigns a locale-neutral date to
    the given target (e.g., `due date of r`). Preferred over the old
    `date "..."` string literal pattern, which was locale-dependent."""
    return applescript_date_var(dt, "_rdt") + f"\nset {target} to _rdt"

# Kept for backwards compatibility with a handful of callers that still
# embed date literals. Prefer as_date_assign for new code.
def as_date(dt):
    return dt.strftime("%A, %B %d, %Y at %I:%M:%S %p")

# ── Natural Language Date Parser ─────────────────────────────────────────────

def parse_due(s):
    """Parse due date. Accepts:
      - ISO: 2026-04-15, 2026-04-15 14:00, 2026-04-15T14:00
      - Shortcuts: today, tomorrow, eod, eow, +3d, +1w, +2h, +1m
      - Relative: "in 3 days", "in 2 weeks"
      - Named days: "next monday", "next friday at 3pm"
      - Natural language (if parsedatetime installed): "march 30 2pm"
    """
    if not s: return None
    sl = s.lower().strip()
    today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    now = datetime.now()

    # Exact shortcuts
    if sl == "today": return today
    if sl == "tomorrow": return today + timedelta(days=1)
    if sl == "eod": return today.replace(hour=17, minute=0)
    if sl == "eow":
        days_ahead = 4 - today.weekday()  # Friday = 4
        if days_ahead <= 0: days_ahead += 7
        return today + timedelta(days=days_ahead)

    # Relative: +3d, +1w, +2m, +2h
    m = re.match(r'^[+]?(\d+)([dwmh])$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit == 'd': return today + timedelta(days=n)
        if unit == 'w': return today + timedelta(weeks=n)
        if unit == 'h': return now + timedelta(hours=n)
        if unit == 'm': return today + timedelta(days=n * 30)

    # "next monday", "next friday at 3pm"
    days_map = {
        "monday": 0, "tuesday": 1, "wednesday": 2, "thursday": 3,
        "friday": 4, "saturday": 5, "sunday": 6,
        "mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6
    }
    m = re.match(r'^next\s+(\w+)(?:\s+at\s+(\d{1,2})(?::(\d{2}))?\s*(am|pm)?)?$', sl)
    if m:
        day_name, hour, minute, ampm = m.groups()
        if day_name in days_map:
            target = days_map[day_name]
            days_ahead = (target - today.weekday()) % 7
            if days_ahead == 0: days_ahead = 7
            dt = today + timedelta(days=days_ahead)
            if hour:
                h = int(hour)
                if ampm == "pm" and h < 12: h += 12
                if ampm == "am" and h == 12: h = 0
                dt = dt.replace(hour=h, minute=int(minute or 0))
            return dt

    # "in N days/weeks/hours/months"
    m = re.match(r'^in\s+(\d+)\s+(day|days|week|weeks|hour|hours|month|months)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if "day" in unit: return today + timedelta(days=n)
        if "week" in unit: return today + timedelta(weeks=n)
        if "hour" in unit: return now + timedelta(hours=n)
        if "month" in unit: return today + timedelta(days=n * 30)

    # ISO formats
    for f in ("%Y-%m-%d", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            return datetime.strptime(s.strip(), f)
        except ValueError:
            pass

    # Fallback to parsedatetime if available
    if _cal:
        result, status = _cal.parseDT(s)
        if status > 0: return result

    return None

# ── Recurrence / Alarm Parsing ───────────────────────────────────────────────

def parse_recurrence(spec):
    """Parse recurrence spec like 'daily', 'weekly mon,wed,fri', 'monthly 1,15'."""
    parts = spec.lower().split()
    freq = parts[0]
    result = {"frequency": freq, "interval": 1}
    if freq == "weekly" and len(parts) > 1:
        day_map = {"sun": 1, "mon": 2, "tue": 3, "wed": 4, "thu": 5, "fri": 6, "sat": 7}
        days = [day_map[d.strip()] for d in parts[1].split(",") if d.strip() in day_map]
        if days: result["daysOfWeek"] = days
    elif freq == "monthly" and len(parts) > 1:
        days = [int(d) for d in parts[1].split(",") if d.strip().isdigit()]
        if days: result["daysOfMonth"] = days
    return result

def parse_alarm(spec):
    """Normalize alarm spec for the Swift bridge.

    Relative alarms are converted to the bridge format (`-15m`, `-1h`, `-1d`).
    Absolute alarms are returned as ISO-like strings the bridge already accepts.
    """
    if not spec: return None
    sl = spec.lower().strip()
    m = re.match(r'^(\d+)(m|min|h|hr|d)$', sl)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit in ("m", "min"): return f"-{n}m"
        if unit in ("h", "hr"): return f"-{n}h"
        if unit == "d": return f"-{n}d"
    # Try ISO datetime
    for f in ("%Y-%m-%dT%H:%M", "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M:%S"):
        try:
            dt = datetime.strptime(spec.strip(), f)
            return dt.isoformat()
        except ValueError:
            pass
    return None


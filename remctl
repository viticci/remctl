def split_list_group_rows(rows):
    groups = sorted([row for row in rows if is_group_list_row(row)], key=list_row_title_sort_key)
    group_ids = {_row_value(row, "Z_PK") for row in groups}
    child_rows = {group_id: [] for group_id in group_ids}
    ungrouped = []
    for row in rows:
        if is_group_list_row(row):
            continue
        parent_id = list_parent_pk(row)
        if parent_id in group_ids:
            child_rows[parent_id].append(row)
        else:
            ungrouped.append(row)
    for group_id in child_rows:
        child_rows[group_id] = sorted(child_rows[group_id], key=list_child_sort_key)
    return groups, child_rows, sorted(ungrouped, key=list_row_title_sort_key)


def list_hierarchy_payloads(rows, *, groups_only=False, include_child_duplicates=True, db=None):
    groups, child_rows, ungrouped = split_list_group_rows(rows)
    payloads = []
    for group_row in groups:
        group_payload = group_payload_from_rows(
            db,
            group_row,
            child_rows.get(_row_value(group_row, "Z_PK"), []),
        )
        children = group_payload["children"]
        payloads.append(group_payload)
        if include_child_duplicates and not groups_only:
            payloads.extend(children)
    if not groups_only:
        payloads.extend(list_to_dict(row) for row in ungrouped)
    return payloads


def group_payload_from_rows(db, group_row, children_rows):
    group_payload = list_to_dict(group_row)
    group_stub = list_group_stub(group_row)
    children = []
    for child_row in children_rows:
        child_payload = list_to_dict(child_row)
        child_payload["group"] = group_stub
        children.append(child_payload)
    if db is not None:
        attach_group_counts(db, group_payload, children)
    group_payload["children"] = children
    return group_payload



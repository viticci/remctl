def output_eventkit_read(payload, a, *, heading=None, empty_message="No reminders found", group_by_day=False):
    if getattr(a, "json", False):
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    items = payload["items"]
    print_eventkit_notice()
    if heading:
        print(C.bold(heading))
    if not items:
        print(empty_message)
        return
    if group_by_day:
        groups = {}
        for item in items:
            due = item.get("dueDate")
            try:
                dt = datetime.fromisoformat(due) if due else None
            except ValueError:
                dt = None
            key = dt.strftime("%Y-%m-%d") if dt else "No due date"
            label = dt.strftime("%A, %b %d") if dt else "No due date"
            today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
            if dt and dt.date() == today.date():
                label = "Today"
            elif dt and dt.date() == (today + timedelta(days=1)).date():
                label = "Tomorrow"
            groups.setdefault((key, label), []).append(item)
        for (_key, label), day_items in sorted(groups.items()):
            print(f"\n  {C.bold(label)}:")
            for item in day_items:
                print(fmt_eventkit_item(item, verbose=getattr(a, "verbose", False), indent="    "))
    else:
        for item in items:
            print(fmt_eventkit_item(item, verbose=getattr(a, "verbose", False), indent="  "))
    print(f"\n{len(items)} reminder{'s' if len(items) != 1 else ''}")



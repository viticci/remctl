def _print_today_payload(items, args):
    if args.no_overdue:
        items = [item for item in items if not _item_is_overdue(item)]
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(f"Nothing due today ({datetime.now().strftime('%Y-%m-%d')})")
        return
    overdue = [item for item in items if _item_is_overdue(item)]
    due = [item for item in items if not _item_is_overdue(item)]
    if overdue:
        print(C.red(f"Overdue ({len(overdue)}):"))
        for item in overdue:
            print(fmt(item, indent="  "))
        print()
    if due:
        print(C.bold(f"Due Today ({len(due)}):"))
        for item in due:
            print(fmt(item, indent="  "))
    print(f"\n{len(items)} total")


def _print_simple_reminder_list(items, args, *, empty_message, heading, total_label, group_by_day=False):
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(empty_message)
        return
    if group_by_day:
        print(C.bold(heading))
        groups = {}
        today = start_of_day()
        for item in items:
            due_dt = _item_due_datetime(item)
            if not due_dt:
                continue
            day_key = due_dt.strftime("%Y-%m-%d")
            day_label = due_dt.strftime("%A, %b %d")
            if due_dt.date() == today.date():
                day_label = "Today"
            elif due_dt.date() == (today + timedelta(days=1)).date():
                day_label = "Tomorrow"
            groups.setdefault((day_key, day_label), []).append(item)
        for (_, day_label), day_items in sorted(groups.items()):
            print(f"\n  {C.bold(day_label)}:")
            for item in day_items:
                print(fmt(item, indent="    "))
        print(f"\n{len(items)} {total_label}")
        return
    print(heading)
    for item in items:
        print(fmt(item, verbose=getattr(args, "verbose", False), indent="  "))
    print(f"\n{len(items)} {total_label}")



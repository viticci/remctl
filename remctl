def wait_for_cloned_reminder_tree(reminder_ckid, target_list_pk, expected_subtasks, attempts=24, delay=0.25):
    for _ in range(attempts):
        db = open_db()
        row = q_reminder_by_identifier(db, reminder_ckid)
        if row and row["ZLIST"] == target_list_pk:
            subtasks = q_subtasks_for_parent(db, row["Z_PK"], limit=max(500, expected_subtasks + 5))
            if len(subtasks) == expected_subtasks:
                return row, subtasks
        time.sleep(delay)
    return None, []


def delete_reminder_by_identifier_or_die(reminder):
    reminder_ckid = _row_get(reminder, "ZCKIDENTIFIER")
    if bridge_available() and reminder_ckid:
        result = bridge_call({"action": "delete", "id": reminder_ckid})
        if result and result.get("status") == "deleted":
            return result
    rid = _rem_id(reminder)
    if rid and osa_by_id_try(reminder["list_name"], rid, "delete r"):
        return {"status": "deleted", "fallback": "applescript"}
    title = safe_display(_row_get(reminder, "ZTITLE") or "(untitled)")
    print(
        f"Error: cloned '{title}' into the target list, but failed to delete original #{reminder['Z_PK']}. "
        "Leaving both reminders in place to avoid data loss.",
        file=sys.stderr,
    )

        return item["ZPRIORITY"] or 0
    return {"high": 1, "medium": 5, "low": 9}.get((_item_get(item, "priority") or "none").lower(), 0)

def _item_is_flagged(item):
    return bool(item["ZFLAGGED"] if _item_has(item, "ZFLAGGED") else _item_get(item, "flagged", False))

def _item_is_urgent(item):
    return bool(
        item["ZISURGENTSTATEENABLEDFORCURRENTUSER"]

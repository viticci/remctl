    # Set up color
    if a.no_color or os.environ.get("NO_COLOR") or not sys.stdout.isatty():
        C.enabled = False

    # Propagate global --format to json flag where needed
    if a.format == "json" and not hasattr(a, 'json'):
        a.json = True
    elif a.format == "json" and hasattr(a, 'json'):
        a.json = True

    maybe_run_first_launch_onboarding(a)

    # No command: splash screen + today
    if not a.cmd:
        a.no_overdue = False
        a.verbose = False
        if a.format == "json":
            a.json = True
            run_handler_with_fallback(a, cmd_today)
        else:
            a.json = False
            show_splash()
            run_handler_with_fallback(a, cmd_today)
        return

    # Propagate --format table to subcommand
    if a.format == "table" and not hasattr(a, 'format_override'):
        pass  # format is already on the namespace

    # Route to command handler
    cmds = {
        "lists": cmd_lists,
        "smart-lists": cmd_smart_lists,
        "show": cmd_show,
        "add": cmd_add,
        "done": cmd_done,
        "undone": cmd_undone,
        "edit": cmd_edit,
        "delete": cmd_delete,
        "search": cmd_search,
        "today": cmd_today,
        "flagged": cmd_flagged,
        "urgent": cmd_urgent,
        "tags": cmd_tags,
        "subtasks": cmd_subtasks,
        "info": cmd_info,
        "sections": cmd_sections,
        "stats": cmd_stats,
        "link": cmd_link,
        "open": cmd_open,
        "flag": cmd_flag,
        "unflag": cmd_unflag,
        "upcoming": cmd_upcoming,
        "overdue": cmd_overdue,
        "list-symbols": cmd_list_symbols,
        "list-create": cmd_list_create,
        "smart-list-create": cmd_smart_list_create,
        "smart-list-edit": cmd_smart_list_edit,
        "smart-list-delete": cmd_smart_list_delete,
        "list-edit": cmd_list_edit,
        "list-pin": cmd_list_pin,
        "list-unpin": cmd_list_unpin,
        "list-rename": cmd_list_rename,
        "list-delete": cmd_list_delete,
        "export": cmd_export,
        "import": cmd_import,
        "onboard": cmd_onboard,
        "doctor": cmd_doctor,
        "setup": cmd_setup,
        "permissions": cmd_permissions,
        "completion": cmd_completion,
    }

    handler = cmds.get(a.cmd)
    if handler:
        run_handler_with_fallback(a, handler)
    else:
        p.print_help()


if __name__ == "__main__":
    main()

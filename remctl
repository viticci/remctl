def smart_list_to_dict(row):
    filter_data = row["ZFILTERDATA"]
    decoded = decode_smart_list_filter_blob(filter_data)
    pinned_date = None
    try:
        pinned_date = row["ZPINNEDDATE"]
    except (IndexError, KeyError):
        pinned_date = None
    payload = {
        "id": row["Z_PK"],
        "objectUUID": row["ZCKIDENTIFIER"],
        "name": smart_list_display_name(row),
        "kind": "custom" if row["ZSMARTLISTTYPE"] == CUSTOM_SMART_LIST_TYPE else "built-in",
        "smartListType": row["ZSMARTLISTTYPE"],
        "filterLength": len(filter_data) if filter_data else 0,
    }
    if _row_has_key(row, "ZCOLOR") and row["ZCOLOR"]:
        payload["color"] = parse_list_color(row["ZCOLOR"])
    if _row_has_key(row, "ZBADGEEMBLEM") and row["ZBADGEEMBLEM"]:
        payload["badge"] = parse_badge_emblem(row["ZBADGEEMBLEM"])
        payload["badgeEmblem"] = row["ZBADGEEMBLEM"]
    try:
        minimum_version = row["ZMINIMUMSUPPORTEDAPPVERSION"]
        effective_minimum_version = row["ZEFFECTIVEMINIMUMSUPPORTEDAPPVERSION"]
    except (IndexError, KeyError):
        minimum_version = None
        effective_minimum_version = None
    if minimum_version is not None:
        payload["minimumSupportedVersion"] = minimum_version
    if effective_minimum_version is not None:
        payload["effectiveMinimumSupportedVersion"] = effective_minimum_version
    if _row_has_key(row, "ZISPINNEDBYCURRENTUSER") or pinned_date is not None:
        is_pinned = bool(_row_get(row, "ZISPINNEDBYCURRENTUSER", False))
        if not is_pinned and pinned_date is not None:
            try:
                is_pinned = float(pinned_date) > 0
            except (TypeError, ValueError):
                is_pinned = False
        payload["pinned"] = is_pinned
    if pinned_date is not None:
        payload["pinnedDate"] = pinned_date
    if decoded["summary"] is not None:
        payload["filter"] = decoded["summary"]
    if decoded["encoding"]:
        payload["filterEncoding"] = decoded["encoding"]
        payload["filterJSON"] = decoded["payload"]
    elif decoded["error"]:
        payload["filterError"] = decoded["error"]
    return payload


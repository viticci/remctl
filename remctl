def normalize_list_lookup_name(name):
    if not name:
        return ""
    text = unicodedata.normalize("NFKC", str(name)).casefold()
    parts = []
    last_space = False
    for ch in text:
        if ch.isalnum():
            parts.append(ch)
            last_space = False
        else:
            category = unicodedata.category(ch)
            if ch.isspace() or category[0] in {"M", "P", "S", "Z"}:
                if parts and not last_space:
                    parts.append(" ")
                    last_space = True
    return "".join(parts).strip()


def cmd_flag(a):
    db = open_db()
    r = q_reminder(db, a.id)
    if not r:
        print(f"Error: #{a.id} not found", file=sys.stderr)
        sys.exit(1)

    # Try bridge first
    if bridge_available() and r["ZCKIDENTIFIER"]:
        data = {"action": "flag", "id": r["ZCKIDENTIFIER"]}
        result = bridge_call(data)
        if result and result.get("status") == "flagged":
            if a.json:
                print(json.dumps({"status": "flagged", "id": a.id, "title": r["ZTITLE"]}))
            else:
                print(f"Flagged: {r['ZTITLE']}")
            return

    # Fall back to AppleScript
    rid = _rem_id(r)
    if rid:
        osa_by_id(r["list_name"], rid, "set flagged of r to true")
    else:
        osa(
            f'tell application "Reminders"\n'
            f'tell list "{esc(r["list_name"])}"\n'
            f'set rs to (every reminder whose name is "{esc(r["ZTITLE"])}")\n'
            f'if (count of rs) > 0 then\n'
            f'set flagged of item 1 of rs to true\n'
            f'end if\nend tell\nend tell'
        )
    if a.json:
        print(json.dumps({"status": "flagged", "id": a.id, "title": r["ZTITLE"]}))
    else:
        print(f"Flagged: {r['ZTITLE']}")


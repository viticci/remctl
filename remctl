def _date_components_dict(value):
    if value in (None, ""):
        return None
    if isinstance(value, bytes):
        value = value.decode("utf-8", "replace")
    try:
        parsed = json.loads(value)
    except (TypeError, ValueError):
        return None
    return parsed if isinstance(parsed, dict) else None

def _date_components_iso(components):
    if not components:
        return None
    try:
        year = int(components["year"])
        month = int(components["month"])
        day = int(components["day"])
        hour = int(components.get("hour", 0))
        minute = int(components.get("minute", 0))
        second = int(components.get("second", 0))
    except (KeyError, TypeError, ValueError):
        return None
    return f"{year:04d}-{month:02d}-{day:02d}T{hour:02d}:{minute:02d}:{second:02d}"

def _relative_alarm_label(seconds):
    try:
        seconds = int(seconds)
    except (TypeError, ValueError):
        return None
    value = abs(seconds)
    units = (
        (86400, "day"),
        (3600, "hour"),
        (60, "minute"),
    )
    for unit_seconds, unit_name in units:
        if value and value % unit_seconds == 0:
            amount = value // unit_seconds
            break
    else:
        amount, unit_name = value, "second"
    plural = "" if amount == 1 else "s"
    direction = "before due date" if seconds < 0 else "after due date"
    return f"{amount} {unit_name}{plural} {direction}"

def alarm_rows_to_json(rows):
    alarms = []
    for row in rows:
        alarm = {"id": row["alarm_id"]}
        interval = _row_get(row, "time_interval")
        if interval is not None:
            seconds = int(interval)
            minutes = seconds / 60
            if seconds % 60 == 0:
                minutes = int(minutes)
            alarm.update({
                "type": "relative",
                "relativeOffset": seconds,
                "relativeOffsetMinutes": minutes,
            })
            label = _relative_alarm_label(seconds)
            if label:
                alarm["label"] = label
        elif _row_get(row, "latitude") is not None or _row_get(row, "longitude") is not None:
            proximity_code = _row_get(row, "proximity")
            alarm.update({
                "type": "location",
                "location": {
                    "title": _row_get(row, "location_title") or "Location",
                    "latitude": _row_get(row, "latitude"),
                    "longitude": _row_get(row, "longitude"),
                    "radius": _row_get(row, "radius"),
                    "proximity": "leaving" if proximity_code == 2 else "arriving",
                    "proximityCode": proximity_code,
                },
            })
            address = _row_get(row, "address")
            if address:
                alarm["location"]["address"] = address
        else:
            components = _date_components_dict(_row_get(row, "date_components"))
            if components:
                alarm.update({
                    "type": "absolute",
                    "dateComponents": components,
                })
                iso_date = _date_components_iso(components)
                if iso_date:
                    alarm["date"] = iso_date
                timezone = components.get("timeZone")
                if isinstance(timezone, dict) and timezone.get("identifier"):
                    alarm["timeZone"] = timezone["identifier"]
            else:
                alarm["type"] = "unknown"
        alarms.append(alarm)
    return alarms

def _same_datetime_second(left, right):
    if not left or not right:
        return False
    return int(left.timestamp()) == int(right.timestamp())

def _parse_alarm_iso_datetime(value):
    if not value:
        return None
    try:
        return datetime.fromisoformat(value)
    except (TypeError, ValueError):
        return None

def should_carry_absolute_alarm_to_new_due(db, reminder, new_due, explicit_alarm=False):
    """Keep Reminders.app's visible time aligned when moving due-at-time items.

    Reminders may store an absolute alarm/display date that is the UI-facing
    time. EventKit does not move that alarm when only dueDateComponents change,
    so a plain `edit -d` can leave the app showing the old time. Only carry a
    single absolute alarm when it matches the old due/display time; otherwise
    preserve the user's custom alarm setup.
    """
    if explicit_alarm or db is None or new_due is None:
        return False
    reminder_pk = _row_get(reminder, "Z_PK")
    if not reminder_pk:
        return False
    try:
        alarms = alarm_rows_to_json(q_alarms(db, reminder_pk))
    except Exception:
        return False
    absolute_alarms = [alarm for alarm in alarms if alarm.get("type") == "absolute"]
    if len(alarms) != 1 or len(absolute_alarms) != 1:
        return False
    alarm_dt = _parse_alarm_iso_datetime(absolute_alarms[0].get("date"))
    old_due = ts(_row_get(reminder, "ZDUEDATE"))
    return _same_datetime_second(alarm_dt, old_due)

def should_clear_matching_absolute_alarm(db, reminder):
    if db is None:
        return False
    reminder_pk = _row_get(reminder, "Z_PK")
    if not reminder_pk:
        return False
    try:
        alarms = alarm_rows_to_json(q_alarms(db, reminder_pk))
    except Exception:
        return False
    absolute_alarms = [alarm for alarm in alarms if alarm.get("type") == "absolute"]
    if len(alarms) != 1 or len(absolute_alarms) != 1:
        return False
    alarm_dt = _parse_alarm_iso_datetime(absolute_alarms[0].get("date"))
    old_due = ts(_row_get(reminder, "ZDUEDATE"))
    old_display = ts(_row_get(reminder, "ZDISPLAYDATEDATE"))
    return any(_same_datetime_second(alarm_dt, candidate) for candidate in (old_due, old_display))

def hydrate_reminder_detail(db, payload, reminder_id):
    attachments = attachment_rows_to_json(q_attachments(db, reminder_id))
    if attachments:
        payload["attachments"] = attachments
    alarms = alarm_rows_to_json(q_alarms(db, reminder_id))
    if alarms:
        payload["alarms"] = alarms
    return payload

def q_search(db, query, completed=False):
    # Escape LIKE metacharacters so `%` and `_` in the query match literally;
    # previously `search "%"` dumped every reminder in the store.
    safe = query.replace("\\", "\\\\").replace("%", "\\%").replace("_", "\\_")
    c = [
        "r.ZMARKEDFORDELETION = 0", "r.ZACCOUNT IS NOT NULL", "l.Z_PK IS NOT NULL",
        "(r.ZTITLE LIKE ? ESCAPE '\\' OR r.ZNOTES LIKE ? ESCAPE '\\')"
    ]
    if not completed: c.append("r.ZCOMPLETED = 0")
    pat = f"%{safe}%"
    return db.execute(
        f"SELECT {rem_cols(db)} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK DESC LIMIT 100",
        (pat, pat)
    ).fetchall()

def q_due_today(db, include_overdue=True):
    sod, eod = due_today_window()
    due_column = due_filter_expr(db)
    if include_overdue:
        w = f"{due_column} < {to_ts(eod)} AND {due_column} IS NOT NULL"
    else:
        w = f"{due_column} >= {to_ts(sod)} AND {due_column} < {to_ts(eod)}"
    return db.execute(
        f"SELECT {rem_cols(db)} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND {w} ORDER BY {due_column}"
    ).fetchall()


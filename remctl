def _template_time(row, key):
    value = _row_get(row, key)
    return ts(value).isoformat() if value else None


def _metadata_tags(metadata):
    tags = []
    for tag in (metadata or {}).get("hashtags", []) or []:
        if isinstance(tag, dict) and tag.get("name"):
            tags.append(tag["name"])
        elif isinstance(tag, str):
            tags.append(tag)
    return tags


def saved_reminder_to_dict(row):
    metadata = decode_template_metadata(_row_get(row, "ZMETADATA")) or {}
    title = _row_get(row, "ZTITLE") or metadata.get("title") or ""
    payload = {
        "id": row["Z_PK"],
        "title": title,
        "objectUUID": _row_get(row, "ZCKIDENTIFIER"),
        "priority": PRI_NAME.get(_row_get(row, "ZPRIORITY", metadata.get("priority", 0)) or 0, "none"),
    }
    created = _template_time(row, "ZCREATIONDATE")
    if created:
        payload["createdDate"] = created
    display_date = _template_time(row, "ZDISPLAYDATEDATE")
    if display_date:
        payload["displayDate"] = display_date
        payload["displayDateIsAllDay"] = bool(_row_get(row, "ZDISPLAYDATEISALLDAY", 0))
    parent_uuid = uuid_from_blob(_row_get(row, "ZPARENTSAVEDREMINDERIDENTIFIER"))
    if parent_uuid:
        payload["parentObjectUUID"] = parent_uuid
    if metadata:
        payload["metadataKeys"] = sorted(metadata.keys())
        payload["flagged"] = bool(metadata.get("flagged", False))
        tags = _metadata_tags(metadata)
        if tags:
            payload["tags"] = tags
        if metadata.get("dueDateComponents"):
            payload["dueDateComponents"] = metadata["dueDateComponents"]
        if metadata.get("startDateComponents"):
            payload["startDateComponents"] = metadata["startDateComponents"]
        if metadata.get("recurrenceRules"):
            payload["recurrenceRules"] = metadata["recurrenceRules"]
        alarm_triggers = metadata.get("alarmTriggers")
        if alarm_triggers:
            payload["alarmTriggers"] = alarm_triggers
        if metadata.get("notesDocumentData"):
            payload["hasNotes"] = True
    return payload


def template_section_to_dict(row):
    payload = {
        "id": row["Z_PK"],
        "name": _row_get(row, "ZDISPLAYNAME") or _row_get(row, "ZCANONICALNAME") or "",
        "objectUUID": _row_get(row, "ZCKIDENTIFIER"),
    }
    created = _template_time(row, "ZCREATIONDATE")
    if created:
        payload["createdDate"] = created
    canonical = _row_get(row, "ZCANONICALNAME")
    if canonical and canonical != payload["name"]:
        payload["canonicalName"] = canonical
    return payload


def template_to_dict(row, db=None, *, include_items=False):
    object_uuid = _row_get(row, "ZCKIDENTIFIER")
    payload = {
        "id": row["Z_PK"],
        "name": row["ZNAME"],
        "objectUUID": object_uuid,
        "deepLink": template_deep_link(object_uuid),
        "itemCount": _row_get(row, "item_count", 0),
        "sectionCount": _row_get(row, "section_count", 0),
    }
    for key, out_key in (
        ("ZCREATIONDATE", "createdDate"),
        ("ZLASTMODIFIEDDATE", "modifiedDate"),
    ):
        value = _template_time(row, key)
        if value:
            payload[out_key] = value
    if _row_has_key(row, "ZBADGEEMBLEM") and row["ZBADGEEMBLEM"]:
        payload["badgeEmblem"] = row["ZBADGEEMBLEM"]
    public_uuid = uuid_from_blob(_row_get(row, "ZPUBLICLINKURLUUID"))
    if public_uuid:
        public = {
            "uuid": public_uuid,
            "url": template_public_link(row["ZNAME"], public_uuid),
        }
        for key, out_key in (
            ("ZPUBLICLINKCREATIONDATE", "createdDate"),
            ("ZPUBLICLINKLASTMODIFIEDDATE", "modifiedDate"),
            ("ZPUBLICLINKEXPIRATIONDATE", "expirationDate"),
        ):
            value = _template_time(row, key)
            if value:
                public[out_key] = value
        config = _row_get(row, "ZPUBLICLINKCONFIGURATIONDATA")
        if config:
            public["configurationLength"] = len(config)
        payload["publicLink"] = public
    if include_items and db is not None:
        payload["sections"] = [template_section_to_dict(item) for item in q_template_sections(db, row["Z_PK"])]
        payload["items"] = [saved_reminder_to_dict(item) for item in q_template_saved_reminders(db, row["Z_PK"])]
    return payload



def private_location_action(data, partial_context=None):
    action_name = data.get("action", "add_location_alarm")
    if bridge_available():
        bridge_payload = {
            "action": "update",
            "id": data.get("id"),
            "locationTitle": data.get("title"),
            "latitude": data.get("latitude"),
            "longitude": data.get("longitude"),
            "radius": data.get("radius"),
            "proximity": "leaving" if data.get("proximity") == 2 else "arriving",
        }
        result = bridge_call(bridge_payload)
        if result and result.get("status") == "updated":
            if partial_context is not None:
                partial_context.setdefault("completed", []).append(action_name)
            return {
                "status": "updated",
                "action": action_name,
                "source": "eventkit_bridge",
                "locationTitle": data.get("title"),
            }
        message = result.get("message") if isinstance(result, dict) else "remctl-bridge failed"
        if partial_context is not None:
            fail_private_add_partial(partial_context, action_name, message)
        print(f"Error: {message}", file=sys.stderr)
        sys.exit(1)

    result = None
    for attempt in range(3):
        result = private_call(data)
        if result and result.get("status") == "updated":
            if partial_context is not None:
                partial_context.setdefault("completed", []).append(action_name)
            return result
        if private_helper_error_is_transient(result):
            for _ in range(8):
                if location_alarm_exists(
                    data.get("id"),
                    title=data.get("title"),
                    latitude=data.get("latitude"),
                    longitude=data.get("longitude"),
                ):
                    if partial_context is not None:
                        partial_context.setdefault("completed", []).append(action_name)
                    return {
                        "status": "updated",
                        "action": action_name,
                        "verifiedAfterTransientError": True,
                        "warning": result.get("message") if isinstance(result, dict) else "private helper failed",
                    }
                time.sleep(0.25)
            if attempt < 2:
                continue
        break
    message = result.get("message") if isinstance(result, dict) else "private helper failed"
    if partial_context is not None:
        fail_private_add_partial(partial_context, action_name, message)
    print(f"Error: {message}", file=sys.stderr)
    sys.exit(1)


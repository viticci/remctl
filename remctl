def cmd_edit(a):
    refuse_private_args_without_opt_in(a)
    if getattr(a, "tags", None) and not private_metadata_enabled(a):
        print("Error: editing synced tags requires --private.", file=sys.stderr)
        sys.exit(1)
    db = open_db()
    r = q_reminder(db, a.id)
    if not r:
        print(f"Error: #{a.id} not found", file=sys.stderr)
        sys.exit(1)
    target_list_ref = None
    target_list_name = getattr(a, "list", None)
    target_list_id = getattr(a, "list_id", None)
    target_list_pk = r["ZLIST"]
    if target_list_name or target_list_id is not None:
        target_list_ref = resolve_required_list_target_or_die(
            db,
            name=target_list_name,
            list_id=target_list_id,
        )
        target_list_name = target_list_ref["title"]
        target_list_pk = target_list_ref["id"]
    wants_private = private_metadata_enabled(a) and private_changes_from_args(a)
    if wants_private:
        require_private_metadata(a)
        validate_private_args(a)
        if getattr(a, "grocery", False):
            require_grocery_list_target(db, target_list_pk)
        if subtask_specs_need_bridge(parse_subtask_specs(getattr(a, "subtask", None))) and not bridge_available():
            print("Error: rich private subtasks require remctl-bridge for notes, due dates, priority, recurrence, or alarms.", file=sys.stderr)
            sys.exit(1)

    pm = {"high": 1, "medium": 5, "low": 9, "none": 0}
    priority_value = None
    if a.priority:
        priority_value = pm.get(a.priority.lower())
        if priority_value is None:
            print("Error: priority must be high, medium, low, or none.", file=sys.stderr)
            sys.exit(1)
    parsed_recurrence = None
    if hasattr(a, 'recurrence') and a.recurrence:
        parsed_recurrence = recurrence_or_die(a.recurrence)

    # Parse due date exactly once, up front. Warn loudly if an unparseable
    # string was given so the user doesn't silently get a no-op write that
    # falls through to the broken bridge path.
    dt = None
    if a.due and a.due != "clear":
        dt = parse_due(a.due)
        if dt is None:
            fail_invalid_due_date(a.due, json_mode=getattr(a, "json", False))
    due_all_day = bool(dt and due_spec_is_all_day(a.due))
    if early_reminder_requires_due_date(a) and a.due == "clear":
        fail_early_reminder_without_due(json_mode=getattr(a, "json", False))
    if early_reminder_requires_due_date(a) and dt is None and not r["ZDUEDATE"]:
        fail_early_reminder_without_due(json_mode=getattr(a, "json", False))
    parsed_alarm = None
    clear_alarm = False
    if getattr(a, "alarm", None):
        clear_alarm = alarm_clear_requested(a.alarm)
        if not clear_alarm:
            parsed_alarm = parse_alarm(a.alarm)
            if parsed_alarm is None:
                print(f"Error: could not parse alarm {a.alarm!r}. Use 15m, 1h, 1d, an absolute date, or clear.", file=sys.stderr)
                sys.exit(1)

    # Auto double-tap: if Reminders' displayed due date already equals the
    # requested target, AppleScript treats it as a no-op and pushes only
    # lastModifiedDate. Force a real value change by setting an intermediate
    # date first (bumped 1 hour), then the real target.
    dt_nudge = None
    if dt is not None and r["ZDUEDATE"] is not None:
        current = ts(r["ZDUEDATE"])
        if current and int(current.timestamp()) == int(dt.timestamp()):
            dt_nudge = dt + (timedelta(days=1) if due_all_day else timedelta(hours=1))
    carry_absolute_alarm = should_carry_absolute_alarm_to_new_due(
        db,
        r,
        dt,
        explicit_alarm=bool(getattr(a, "alarm", None)),
    )
    clear_matching_absolute_alarm = (
        a.due == "clear"
        and not clear_alarm
        and should_clear_matching_absolute_alarm(db, r)
    )

    moving_to_different_list = bool(target_list_ref and target_list_pk != r["ZLIST"])
    child_rows_for_move = []
    has_other_changes_for_move = bool(
        a.title
        or a.notes is not None
        or a.priority
        or a.due
        or (hasattr(a, 'url') and a.url)
        or parsed_recurrence is not None
        or clear_alarm
        or parsed_alarm
        or wants_private
    )
    if moving_to_different_list:
        child_rows_for_move = subtask_rows_for_parent_move(db, r)
        if child_rows_for_move:
            if has_other_changes_for_move:
                print(
                    "Error: moving a parent reminder with subtasks cannot currently be combined with other edits. "
                    "Move it first, then edit the cloned reminder returned by remctl.",
                    file=sys.stderr,
                )
                sys.exit(1)
            move_result = clone_reminder_tree_to_list_or_die(db, r, target_list_ref, child_rows_for_move)
            emit_clone_delete_move_result(a, move_result, target_list_ref)
            return

    # Bridge-first for speed (post-2026-04-17 bridge fix: reminder.timeZone
    # is set explicitly and .timeZone is no longer embedded in the
    # dueDateComponents set, so CloudKit now receives the new due date). If
    # the bridge is unavailable, we fall back to AppleScript via Reminders.app.
    #
    # Double-tap defense: if the displayed date already equals the new target,
    # fire an intermediate update first so the CKRecord is forced to carry a
    # real dueDateComponents change.
    bridge_write_result = None
    bridge_write_attempted = False
    nudge_succeeded = False
    if bridge_available() and r["ZCKIDENTIFIER"]:
        if dt_nudge is not None:
            nudge_data = {
                "action": "update",
                "id": r["ZCKIDENTIFIER"],
                "due": dt_nudge.isoformat(),
            }
            if due_all_day:
                nudge_data["allDay"] = True
            nudge_result = bridge_call_result(nudge_data)
            if bridge_failure_is_access_error(nudge_result):
                fail_bridge_write(nudge_result, operation="prepare the reminder edit")
            elif bridge_result_ok(nudge_result, "updated"):
                nudge_succeeded = True
            else:
                print(NUDGE_PREP_WARNING, file=sys.stderr)
        data = {"action": "update", "id": r["ZCKIDENTIFIER"]}
        has_changes = False
        if a.title: data["title"] = a.title; has_changes = True
        if target_list_ref:
            data.update(bridge_list_target_payload(target_list_ref))
            has_changes = True
        # Merge url into notes to keep URL-append semantics identical across
        # bridge and AppleScript paths.
        notes_body = a.notes
        if hasattr(a, 'url') and a.url and not wants_private:
            notes_body = (notes_body + "\n\n" + a.url) if notes_body else a.url
        if notes_body is not None:
            data["notes"] = notes_body
            has_changes = True
        if priority_value is not None:
            data["priority"] = priority_value; has_changes = True
        if a.due == "clear":
            data["due"] = None; has_changes = True
            if clear_matching_absolute_alarm:
                data["clearAlarms"] = True
        elif dt is not None:
            data["due"] = dt.isoformat(); has_changes = True
            if due_all_day:
                data["allDay"] = True
        if parsed_recurrence is not None:
            data["recurrence"] = parsed_recurrence; has_changes = True
        if clear_alarm:
            data["clearAlarms"] = True; has_changes = True
        elif parsed_alarm:
            data["alarm"] = parsed_alarm; has_changes = True
        elif carry_absolute_alarm:
            data["alarm"] = dt.isoformat(); has_changes = True
        if has_changes:
            bridge_write_attempted = True
            bridge_write_result = bridge_call_result(data)
            if bridge_result_ok(bridge_write_result, "updated"):
                result = bridge_write_result["payload"]
                private_results = apply_private_changes(
                    r["ZCKIDENTIFIER"],
                    a,
                    db=db,
                    list_pk=target_list_pk,
                ) if wants_private else []
                if a.json:
                    payload = {"status": "updated", "id": a.id}
                    if target_list_ref:
                        payload["list"] = target_list_name
                        if target_list_ref.get("method") != "exact":
                            payload["resolvedList"] = {
                                "requested": target_list_ref.get("requested"),
                                "title": target_list_ref["title"],
                                "id": target_list_ref["id"],
                                "method": target_list_ref["method"],
                            }
                    if private_results:
                        payload["private"] = private_results
                    print(json.dumps(payload))
                else:
                    print(f"Updated #{a.id}")
                    if target_list_ref:
                        print(f"List: {safe_display(target_list_name)}")
                    if private_results:
                        print(f"Private metadata: applied {len(private_results)} update{'s' if len(private_results) != 1 else ''}")
                return
            if bridge_failure_is_access_error(bridge_write_result):
                warn_if_nudged_due_stranded(r, nudge_succeeded, dt, due_all_day)
                fail_bridge_write(bridge_write_result, operation="edit the reminder")
            if (
                moving_to_different_list
                and not child_rows_for_move
                and not has_other_changes_for_move
                and bridge_failure_allows_clone_delete_fallback(bridge_write_result)
            ):
                move_result = clone_reminder_tree_to_list_or_die(db, r, target_list_ref, [])
                emit_clone_delete_move_result(a, move_result, target_list_ref)
                return
        elif wants_private:
            private_results = apply_private_changes(
                r["ZCKIDENTIFIER"],
                a,
                db=db,
                list_pk=target_list_pk,
            )
            if a.json:
                print(json.dumps({"status": "updated", "id": a.id, "private": private_results}, indent=2))
            else:
                print(f"Updated #{a.id}")
                print(f"Private metadata: applied {len(private_results)} update{'s' if len(private_results) != 1 else ''}")
            return

    if (
        bridge_write_attempted
        and bridge_write_result
        and bridge_write_result.get("returncode") != 0
        and (
            target_list_ref
            or parsed_recurrence is not None
            or clear_alarm
            or parsed_alarm
            or wants_private
        )
    ):
        warn_if_nudged_due_stranded(r, nudge_succeeded, dt, due_all_day)
        fail_bridge_write(bridge_write_result, operation="edit the reminder")

    if carry_absolute_alarm or clear_matching_absolute_alarm:
        warn_if_nudged_due_stranded(r, nudge_succeeded, dt, due_all_day)
        print("Error: this edit requires remctl-bridge to keep due/display/alarm state aligned.", file=sys.stderr)
        sys.exit(1)
    if dt is not None and due_all_day:
        warn_if_nudged_due_stranded(r, nudge_succeeded, dt, due_all_day)
        print("Error: all-day due date edits require remctl-bridge so Reminders can store date-only components.", file=sys.stderr)
        sys.exit(1)

    # AppleScript fallback for when bridge isn't available.
    has_bridge_only = (
        (hasattr(a, 'recurrence') and a.recurrence) or
        (hasattr(a, 'alarm') and a.alarm) or wants_private
        or target_list_ref
    )
    has_applescript_fields = bool(
        a.title or a.notes or a.due or a.priority
        or (hasattr(a, 'url') and a.url and not wants_private)
    )

    if r["ZCKIDENTIFIER"] and has_applescript_fields and not has_bridge_only:
        parts = []
        if a.title:
            parts.append(f'set name of r to "{esc(a.title)}"')
        notes_body = a.notes
        if hasattr(a, 'url') and a.url and not wants_private:
            notes_body = (notes_body + "\n\n" + a.url) if notes_body else a.url
        if notes_body:
            parts.append(f'set body of r to "{esc(notes_body)}"')
        if priority_value is not None:
            parts.append(f"set priority of r to {priority_value}")
        if a.due == "clear":
            parts.append("set due date of r to missing value")
        elif dt is not None:
            # Same double-tap defense as the bridge path.
            if dt_nudge is not None:
                parts.append(as_date_assign(dt_nudge))
            parts.append(as_date_assign(dt))
        if parts and osa_by_id_try(r["list_name"], _rem_id(r), chr(10).join(parts)):
            if a.json:
                print(json.dumps({"status": "updated", "id": a.id}))
            else:
                print(f"Updated #{a.id}")
            return

    if not has_applescript_fields and not has_bridge_only:
        print("Nothing to update.")
        return
    if not r["ZCKIDENTIFIER"]:
        _refuse_unsafe_title_fallback(r, "edit it", "The reminder has no stable identifier")
    warn_if_nudged_due_stranded(r, nudge_succeeded, dt, due_all_day)

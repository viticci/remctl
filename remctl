def wait_for_grocery_section(list_pk, reminder_ckid, attempts=24, delay=0.25):
    for _ in range(attempts):
        db = open_db()
        memberships = q_section_memberships(db, list_pk)
        section = memberships.get(reminder_ckid)
        if section:
            return section
        time.sleep(delay)
    return None


def apply_private_grocery_categorization(db, list_pk, reminder_ckids, partial_context=None):
    require_private_metadata(SimpleNamespace(private=True, private_metadata=False))
    require_grocery_list_target(db, list_pk)
    ckid = q_list_ckid(db, list_pk)
    if not ckid:
        print("Error: target list has no stable CloudKit identifier.", file=sys.stderr)
        sys.exit(1)
    reminder_ckids = [ckid for ckid in reminder_ckids if ckid]
    if not reminder_ckids:
        print("Error: grocery categorization needs a stable reminder identifier.", file=sys.stderr)
        sys.exit(1)

    verified = []
    pending = []
    for reminder_ckid in reminder_ckids:
        section = wait_for_grocery_section(list_pk, reminder_ckid)
        verified.append({"id": reminder_ckid, "section": section})
        if not section:
            pending.append(reminder_ckid)

    if not pending:
        return {
            "status": "updated",
            "action": "categorize_grocery_items",
            "source": "reminders_auto",
            "verifiedSections": verified,
        }

    request = {
        "action": "categorize_grocery_items",
        "listId": ckid,
        "reminderIds": pending,
    }
    result = None
    for attempt in range(3):
        result = private_call(request)
        if result and result.get("status") == "updated":
            break
        result_verified = []
        for reminder_ckid in reminder_ckids:
            section = wait_for_grocery_section(list_pk, reminder_ckid, attempts=8, delay=0.25)
            result_verified.append({"id": reminder_ckid, "section": section})
        if any(item.get("section") for item in result_verified):
            return {
                "status": "updated",
                "action": "categorize_grocery_items",
                "source": "reminders_auto",
                "warning": result.get("message") if isinstance(result, dict) else "private helper failed",
                "verifiedSections": result_verified,
            }
        if not private_helper_error_is_transient(result) or attempt == 2:
            break
        time.sleep(0.5)
    if result and result.get("status") == "updated":
        result_verified = []
        for reminder_ckid in reminder_ckids:
            section = wait_for_grocery_section(list_pk, reminder_ckid)
            result_verified.append({"id": reminder_ckid, "section": section})
        result["verifiedSections"] = result_verified
        return result

    message = result.get("message") if isinstance(result, dict) else "private helper failed"
    fallback_verified = []
    for reminder_ckid in reminder_ckids:
        section = wait_for_grocery_section(list_pk, reminder_ckid)
        fallback_verified.append({"id": reminder_ckid, "section": section})
    if any(item.get("section") for item in fallback_verified):
        return {
            "status": "updated",
            "action": "categorize_grocery_items",
            "source": "reminders_auto",
            "warning": message,
            "verifiedSections": fallback_verified,
        }

    print(f"Error: {message}", file=sys.stderr)
    if partial_context is not None:
        fail_private_add_partial(partial_context, "categorize_grocery_items", message)
    sys.exit(1)



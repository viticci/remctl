)


def rollback_nudged_due(reminder_ckid, original_dt, due_all_day):
    if not reminder_ckid or original_dt is None:
        return None
    data = {"action": "update", "id": reminder_ckid, "due": original_dt.isoformat()}
    if due_all_day:
        data["allDay"] = True
    result = bridge_call_result(data)
    if bridge_result_ok(result, "updated"):
        return None
    offset = "1 day" if due_all_day else "1 hour"
    return (
        f"Warning: reminder due date may be wrong by {offset} "
        f"(reminder id {reminder_ckid}); check it in Reminders."
    )


def warn_if_nudged_due_stranded(reminder, nudge_succeeded, original_dt, due_all_day):
    if not nudge_succeeded:
        return
    warning = rollback_nudged_due(reminder["ZCKIDENTIFIER"], original_dt, due_all_day)
    if warning:
        print(warning, file=sys.stderr)



def q_lists(db):
    return db.execute(
        "SELECT Z_PK, ZNAME FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL AND ZNAME != '' "
        "ORDER BY ZNAME"
    ).fetchall()

def q_list_pk(db, name):
    r = db.execute(
        "SELECT Z_PK FROM ZREMCDBASELIST WHERE ZNAME = ? COLLATE NOCASE AND ZMARKEDFORDELETION = 0 LIMIT 1", (name,)
    ).fetchone()
    return r[0] if r else None

_REM_COLS = """r.Z_PK, r.ZTITLE, r.ZNOTES, r.ZCOMPLETED, r.ZFLAGGED, r.ZPRIORITY,
    r.ZDUEDATE, r.ZALLDAY, r.ZCOMPLETIONDATE, r.ZCREATIONDATE,
    r.ZPARENTREMINDER, r.ZLIST, r.ZICSURL, r.ZCKIDENTIFIER, l.ZNAME as list_name"""

def q_reminders(db, list_pk=None, completed=False, parent_pk=None, top_level=False, limit=500):
    c, params = ["r.ZMARKEDFORDELETION = 0", "r.ZACCOUNT IS NOT NULL"], []
    if not completed: c.append("r.ZCOMPLETED = 0")
    if list_pk is not None: c.append("r.ZLIST = ?"); params.append(list_pk)
    if parent_pk is not None: c.append("r.ZPARENTREMINDER = ?"); params.append(parent_pk)
    elif top_level: c.append("(r.ZPARENTREMINDER IS NULL OR r.ZPARENTREMINDER = 0)")
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK LIMIT ?",
        params + [limit]
    ).fetchall()

def q_reminder(db, pk):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK "
        f"WHERE r.Z_PK = ? AND r.ZMARKEDFORDELETION = 0 AND r.ZACCOUNT IS NOT NULL",
        (pk,)
    ).fetchone()

def q_subtask_count(db, pk):
    return db.execute(
        "SELECT COUNT(*) FROM ZREMCDREMINDER WHERE ZPARENTREMINDER = ? "
        "AND ZMARKEDFORDELETION = 0 AND ZCOMPLETED = 0", (pk,)
    ).fetchone()[0]

def q_sections(db, list_pk=None):
    if list_pk:
        return db.execute(
            "SELECT Z_PK, ZDISPLAYNAME, ZLIST FROM ZREMCDBASESECTION "
            "WHERE ZMARKEDFORDELETION = 0 AND ZLIST = ? ORDER BY Z_PK", (list_pk,)
        ).fetchall()
    return db.execute(
        "SELECT s.Z_PK, s.ZDISPLAYNAME, s.ZLIST, l.ZNAME as list_name FROM ZREMCDBASESECTION s "
        "LEFT JOIN ZREMCDBASELIST l ON s.ZLIST = l.Z_PK "
        "WHERE s.ZMARKEDFORDELETION = 0 ORDER BY l.ZNAME, s.Z_PK"
    ).fetchall()

def q_section_memberships(db, list_pk):
    row = db.execute(
        "SELECT ZMEMBERSHIPSOFREMINDERSINSECTIONSASDATA FROM ZREMCDBASELIST WHERE Z_PK = ?",
        (list_pk,)
    ).fetchone()
    if not row or not row[0]: return {}
    try:
        data = json.loads(row[0])
    except (json.JSONDecodeError, TypeError):
        return {}
    sections = db.execute(
        "SELECT ZCKIDENTIFIER, ZDISPLAYNAME FROM ZREMCDBASESECTION "
        "WHERE ZLIST = ? AND ZMARKEDFORDELETION = 0", (list_pk,)
    ).fetchall()
    g2n = {s["ZCKIDENTIFIER"]: s["ZDISPLAYNAME"] for s in sections}
    return {
        m["memberID"]: g2n[m["groupID"]]
        for m in data.get("memberships", [])
        if m.get("groupID") in g2n and m.get("memberID")
    }

def q_attachments(db, pk):
    return db.execute(
        "SELECT ZFILENAME, ZUTI, ZATTACHMENTTYPERAWVALUE FROM ZREMCDSAVEDATTACHMENT "
        "WHERE ZREMINDER = ? AND ZMARKEDFORDELETION = 0", (pk,)
    ).fetchall()

def q_hashtags(db, pk):
    return db.execute(
        "SELECT h.ZNAME FROM ZREMCDOBJECT o JOIN ZREMCDHASHTAGLABEL h "
        "ON o.ZHASHTAGLABEL = h.Z_PK WHERE o.ZREMINDER3 = ?", (pk,)
    ).fetchall()

def q_search(db, query, completed=False):
    # Escape LIKE metacharacters so `%` and `_` in the query match literally;
    # previously `search "%"` dumped every reminder in the store.
    safe = query.replace("\\", "\\\\").replace("%", "\\%").replace("_", "\\_")
    c = [
        "r.ZMARKEDFORDELETION = 0", "r.ZACCOUNT IS NOT NULL", "l.Z_PK IS NOT NULL",
        "(r.ZTITLE LIKE ? ESCAPE '\\' OR r.ZNOTES LIKE ? ESCAPE '\\')"
    ]
    if not completed: c.append("r.ZCOMPLETED = 0")
    pat = f"%{safe}%"
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE {' AND '.join(c)} ORDER BY r.Z_PK DESC LIMIT 100",
        (pat, pat)
    ).fetchall()

def q_due_today(db, include_overdue=True):
    sod, eod = due_today_window()
    if include_overdue:
        w = f"r.ZDUEDATE < {to_ts(eod)} AND r.ZDUEDATE IS NOT NULL"
    else:
        w = f"r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(eod)}"
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND {w} ORDER BY r.ZDUEDATE"
    ).fetchall()

def q_flagged(db):
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZFLAGGED = 1 ORDER BY r.ZDUEDATE NULLS LAST"
    ).fetchall()

def q_upcoming(db, days=7):
    """Reminders due within the next N days (not overdue)."""
    sod, future = upcoming_window(days)
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE >= {to_ts(sod)} AND r.ZDUEDATE < {to_ts(future)} "
        f"ORDER BY r.ZDUEDATE"
    ).fetchall()

def q_overdue(db):
    """All overdue incomplete reminders."""
    sod = start_of_day()
    return db.execute(
        f"SELECT {_REM_COLS} FROM ZREMCDREMINDER r LEFT JOIN ZREMCDBASELIST l "
        f"ON r.ZLIST = l.Z_PK WHERE r.ZMARKEDFORDELETION = 0 AND r.ZCOMPLETED = 0 AND r.ZACCOUNT IS NOT NULL "
        f"AND l.Z_PK IS NOT NULL AND r.ZDUEDATE IS NOT NULL "
        f"AND r.ZDUEDATE < {to_ts(sod)} ORDER BY r.ZDUEDATE"
    ).fetchall()

# ── Format ───────────────────────────────────────────────────────────────────

def fmt_due(v, colored=True):
    if not v: return ""
    if isinstance(v, datetime):
        dt = v
    elif isinstance(v, str):
        try:
            dt = datetime.fromisoformat(v)
        except ValueError:
            return ""
    else:
        dt = ts(v)
    if not dt:
        return ""
    now = datetime.now()
    today = now.replace(hour=0, minute=0, second=0, microsecond=0)
    if dt.date() == today.date():
        label = f" (today {dt.strftime('%H:%M')})" if dt.hour or dt.minute else " (today)"
        return label
    if dt.date() == (today + timedelta(days=1)).date():
        return " (tomorrow)"
    if dt < now:
        label = f" (overdue {(now - dt).days}d)"
        return C.red(label) if colored else label
    return f" ({dt.strftime('%Y-%m-%d')})"

def preload_extras(db, pks):
    return shared_preload_extras(db, pks)

def _color_priority(pri_val):
    """Color a priority marker based on level."""
    p = PRI.get(pri_val or 0, "")
    if not p: return ""
    if pri_val == 1: return C.red(p)
    if pri_val == 5: return C.yellow(p)
    if pri_val == 9: return C.green(p)
    return p


def _item_has(item, key):
    if isinstance(item, dict):
        return key in item
    keys = getattr(item, "keys", None)
    if callable(keys):
        try:
            return key in keys()
        except Exception:
            return False
    return False


def _item_get(item, key, default=None):
    if isinstance(item, dict):
        return item.get(key, default)
    if _item_has(item, key):
        return item[key]
    return default


def _priority_value_from_item(item):
    if _item_has(item, "ZPRIORITY"):
        return item["ZPRIORITY"] or 0
    return {"high": 1, "medium": 5, "low": 9}.get((_item_get(item, "priority") or "none").lower(), 0)


def _list_name_from_item(item):
    return _item_get(item, "list_name", _item_get(item, "list"))


def _url_from_item(item):
    return _item_get(item, "ZICSURL", _item_get(item, "url"))


def _subtask_count_from_item(item, db=None, _sc=None):
    if _item_has(item, "Z_PK"):
        return (_sc or {}).get(item["Z_PK"], q_subtask_count(db, item["Z_PK"]) if db else 0)
    return _item_get(item, "subtaskCount", 0) or 0


def _tags_from_item(item, db=None, _ht=None):
    if _item_has(item, "Z_PK"):
        return (_ht or {}).get(item["Z_PK"], [t["ZNAME"] for t in q_hashtags(db, item["Z_PK"])] if db else [])
    return _item_get(item, "tags", []) or []

def fmt(r, db=None, verbose=False, indent="", _sc=None, _ht=None):
    completed = r["ZCOMPLETED"] if _item_has(r, "ZCOMPLETED") else bool(_item_get(r, "completed"))
    if completed:
        status = C.green("[x]")
    else:
        status = C.dim("[ ]")
    flag = C.yellow(" *") if (r["ZFLAGGED"] if _item_has(r, "ZFLAGGED") else bool(_item_get(r, "flagged"))) else ""
    pri_val = _priority_value_from_item(r)
    sc = _subtask_count_from_item(r, db=db, _sc=_sc)
    tags = _tags_from_item(r, db=db, _ht=_ht)
    tag_str = " " + " ".join(f"#{t}" for t in tags) if tags else ""
    sub_str = f" [{sc} subtask{'s' if sc != 1 else ''}]" if sc > 0 else ""
    pri_str = f" {_color_priority(pri_val)}" if PRI.get(pri_val, "") else ""
    rid = r["Z_PK"] if _item_has(r, "Z_PK") else _item_get(r, "id", "?")
    id_str = C.dim(f"#{rid}")
    title = (r["ZTITLE"] if _item_has(r, "ZTITLE") else _item_get(r, "title")) or "(untitled)"
    due_str = fmt_due(r["ZDUEDATE"] if _item_has(r, "ZDUEDATE") else _item_get(r, "dueDate"))
    if completed:
        title = C.dim(C.strikethrough(title))
        due_str = C.dim(due_str)
        tag_str = C.dim(tag_str)
        sub_str = C.dim(sub_str)
    parts = [f"{indent}{status} {id_str}{pri_str}{flag} {title}{due_str}{tag_str}{sub_str}"]
    if verbose:
        list_name = _list_name_from_item(r)
        if list_name:
            parts.append(f"{indent}    List: {color_list_name(list_name, db)}")
        notes = r["ZNOTES"] if _item_has(r, "ZNOTES") else _item_get(r, "notes")
        if notes:
            parts.append(f"{indent}    Notes: {C.dim(str(notes)[:200])}")
        url = _url_from_item(r)
        if url:
            parts.append(f"{indent}    URL: {C.dim(url)}")
    return "\n".join(parts)

def to_dict(r, db=None, section=None, _sc=None, _ht=None):
    return serialize_reminder(
        r,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        section=section,
        subtask_counts=_sc,
        hashtags=_ht,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
    )

def reminders_to_dicts(items, db=None, memberships=None):
    return serialize_reminders(
        items,
        ts=ts,
        priority_names=PRI_NAME,
        db=db,
        memberships=memberships,
        fallback_subtask_count=q_subtask_count,
        fallback_hashtags=lambda inner_db, pk: [t["ZNAME"] for t in q_hashtags(inner_db, pk)],
    )

# ── Table Format ─────────────────────────────────────────────────────────────

def _strip_ansi(s):
    """Remove ANSI escape codes for width calculation."""
    return re.sub(r'\033\[[0-9;]*m', '', s)

def _visible_len(s):
    """Length of string as displayed (without ANSI codes)."""
    return len(_strip_ansi(s))

def _pad(s, width):
    """Pad string to width, accounting for ANSI codes."""
    visible = _visible_len(s)
    return s + " " * max(0, width - visible)

def fmt_table(rows_data, max_width=None):
    """Format data as a Unicode box-drawing table.

    rows_data: list of dicts with keys: id, title, list, due, pri
    """
    if not rows_data:
        return ""
    if max_width is None:
        try:
            max_width = os.get_terminal_size().columns
        except (ValueError, OSError):
            max_width = 80

    headers = ["ID", "Title", "List", "Due", "Pri"]
    # Calculate column widths
    col_widths = [len(h) for h in headers]
    for row in rows_data:
        vals = [str(row.get("id", "")), row.get("title", ""), row.get("list", ""),
                row.get("due", ""), row.get("pri", "")]
        for i, v in enumerate(vals):
            col_widths[i] = max(col_widths[i], _visible_len(str(v)))

    # Cap title column so table fits terminal
    fixed = col_widths[0] + col_widths[2] + col_widths[3] + col_widths[4] + 16  # borders + padding
    max_title = max(10, max_width - fixed)
    col_widths[1] = min(col_widths[1], max_title)

    def hline(left, mid, right, fill="─"):
        parts = [left]
        for i, w in enumerate(col_widths):
            parts.append(fill * (w + 2))
            parts.append(mid if i < len(col_widths) - 1 else "")
        parts.append(right)
        return "".join(parts)

    def row_line(vals):
        cells = []
        for i, v in enumerate(vals):
            s = str(v)
            # Truncate if needed (by visible length)
            if _visible_len(s) > col_widths[i]:
                plain = _strip_ansi(s)
                s = plain[:col_widths[i] - 1] + "…"
            cells.append(f" {_pad(s, col_widths[i])} ")
        return "│" + "│".join(cells) + "│"

    lines = []
    lines.append(hline("┌", "┬", "┐"))
    lines.append(row_line([C.bold(h) for h in headers]))
    lines.append(hline("├", "┼", "┤"))
    for row in rows_data:
        vals = [
            C.dim(str(row.get("id", ""))),
            row.get("title", ""),
            row.get("list", ""),
            row.get("due", ""),
            row.get("pri", "")
        ]
        lines.append(row_line(vals))
    lines.append(hline("└", "┴", "┘"))
    return "\n".join(lines)

def reminders_to_table_data(items, db=None):
    """Convert reminder rows to table-friendly dicts."""
    data = []
    now = datetime.now()
    sod = now.replace(hour=0, minute=0, second=0, microsecond=0)
    for r in items:
        due_str = ""
        due_value = r["ZDUEDATE"] if _item_has(r, "ZDUEDATE") else _item_get(r, "dueDate")
        if due_value:
            if isinstance(due_value, str):
                try:
                    dt = datetime.fromisoformat(due_value)
                except ValueError:
                    dt = None
            else:
                dt = ts(due_value)
        else:
            dt = None
        if dt:
            if dt.date() == sod.date():
                due_str = "Today"
                if dt.hour or dt.minute:
                    due_str += f" {dt.strftime('%H:%M')}"
            elif dt.date() == (sod + timedelta(days=1)).date():
                due_str = "Tomorrow"
            elif dt < now:
                due_str = C.red(f"Overdue {(now - dt).days}d")
            else:
                due_str = dt.strftime("%Y-%m-%d")
        pri_val = _priority_value_from_item(r)
        pri_str = _color_priority(pri_val) if PRI.get(pri_val, "") else ""
        title = (r["ZTITLE"] if _item_has(r, "ZTITLE") else _item_get(r, "title")) or "(untitled)"
        flagged = r["ZFLAGGED"] if _item_has(r, "ZFLAGGED") else bool(_item_get(r, "flagged"))
        if flagged:
            title = C.yellow("* ") + title
        list_name = _list_name_from_item(r) or ""
        if db and C.enabled:
            list_name = color_list_name(list_name, db)
        data.append({
            "id": r["Z_PK"] if _item_has(r, "Z_PK") else _item_get(r, "id", ""),
            "title": title,
            "list": list_name,
            "due": due_str,
            "pri": pri_str,
        })
    return data

# ── Bridge Integration ───────────────────────────────────────────────────────

def bridge_available():
    """Check if remctl-bridge (Swift EventKit binary) is available."""
    return BRIDGE_PATH.exists() and BRIDGE_PATH.stat().st_mode & 0o111

def bridge_call_result(data, timeout=30):
    """Call remctl-bridge and return raw subprocess + parsed JSON details."""
    try:
        proc = subprocess.run(
            [str(BRIDGE_PATH)], input=json.dumps(data),
            capture_output=True, text=True, timeout=timeout
        )
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return None

    payload = None
    if proc.stdout:
        try:
            payload = json.loads(proc.stdout)
        except json.JSONDecodeError:
            payload = None
    return {
        "returncode": proc.returncode,
        "stdout": proc.stdout,
        "stderr": proc.stderr,
        "payload": payload,
    }

def bridge_call(data):
    """Call remctl-bridge with JSON data. Returns parsed JSON response."""
    result = bridge_call_result(data)
    if result and result["returncode"] == 0 and isinstance(result["payload"], dict):
        return result["payload"]
    return None


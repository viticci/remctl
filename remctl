# sqlite3.Connection rejects attribute assignment, so the capability cache
# lives module-side. Keyed by database file path when the connection reports
# one (PRAGMA database_list); in-memory DBs and test mocks fall back to
# id(db). id-reuse after GC could theoretically alias a dead connection's
# entry, but the worst case is a stale schema guess for a fresh connection
# whose queries would then fail soft — acceptable for a read-only guard.
_attachment_sha_capability_cache = {}
_ATTACHMENT_SHA_CACHE_MAX = 64


def _attachment_sha_capability(db):
    """Per-db cache of which attachment tables expose ZSHA512SUM (schema drift guard)."""
    id_key = ("id", id(db))
    cached = _attachment_sha_capability_cache.get(id_key)
    if cached is not None:
        return cached
    # New connection: alias to the database file path so other connections to
    # the same store share one entry. In-memory DBs/mocks report no path and
    # stay keyed by id. id-reuse after GC could alias a dead connection's
    # entry; the worst case is a stale schema guess whose queries fail soft.
    try:
        rows = db.execute("PRAGMA database_list").fetchall()
        path = next((row[2] for row in rows if row[1] == "main" and row[2]), None)
    except Exception:
        path = None
    path_key = ("path", path) if path else None
    if path_key is not None:
        cached = _attachment_sha_capability_cache.get(path_key)
        if cached is not None:
            _attachment_sha_capability_cache[id_key] = cached
            return cached
    result = {}
    for table in ("ZREMCDSAVEDATTACHMENT", "ZREMCDOBJECT"):
        try:
            columns = {row[1] for row in db.execute(f"PRAGMA table_info({table})")}
            result[table] = "ZSHA512SUM" in columns
        except Exception:
            result[table] = False
    if len(_attachment_sha_capability_cache) >= _ATTACHMENT_SHA_CACHE_MAX:
        _attachment_sha_capability_cache.clear()
    _attachment_sha_capability_cache[id_key] = result
    if path_key is not None:
        _attachment_sha_capability_cache[path_key] = result
    return result



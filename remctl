def write_list_symbols_html(path=None):
    rows = list_symbol_rows()
    output_path = Path(path).expanduser() if path else default_list_symbols_html_path()
    image_data = export_list_symbol_asset_data(rows)
    html = build_list_symbols_html(rows, image_data)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(html, encoding="utf-8")
    return output_path

def cmd_list_symbols(a):
    rows = list_symbol_rows()
    if getattr(a, "html", None) is not None or getattr(a, "preview", False):
        if a.json:
            print("Error: --json cannot be combined with --html or --preview.", file=sys.stderr)
            sys.exit(1)
        try:
            output_path = write_list_symbols_html(a.html or None)
        except RuntimeError as e:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)
        if a.preview:
            subprocess.run(["open", str(output_path)], check=False)
        print(f"HTML preview: {output_path}")
        return
    if a.json:
        print(json.dumps({
            "count": len(rows),
            "note": "These are Reminders' bundled list badge emblems; emoji badges are separate. The preview field is an approximate Unicode text fallback, not the native Reminders/SF Symbol rendering.",
            "symbols": rows,
        }, indent=2, ensure_ascii=False))
        return
    print(C.bold(f"Official Reminders list symbols ({len(rows)}):"))
    print(C.dim("Use these with: remctl list-create \"Name\" --private --symbol <name>"))
    print(C.dim("The left column is an approximate text fallback, not native Reminders/SF Symbol rendering."))
    print(C.dim("Tip: run `remctl list-symbols --preview` to open the native badge preview in your browser."))
    width = max(len(row["name"]) for row in rows)
    print(f"  {C.dim('approx'):<2}  {C.dim('name'):<{width}}  {C.dim('asset')}")
    for row in rows:
        print(f"  {row['preview']:<2}  {row['name']:<{width}}  {C.dim(row['asset'])}")


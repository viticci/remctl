def table_column_names(db, table_name):
    return {row["name"] for row in db.execute(f"PRAGMA table_info({table_name})").fetchall()}


def list_select_columns(db):
    columns = ["Z_PK", "ZNAME", "ZCKIDENTIFIER"]
    table_columns = table_column_names(db, "ZREMCDBASELIST")
    optional_columns = [
        "ZBADGEEMBLEM",
        "ZCOLOR",
        "ZISGROUP",
        "ZPARENTLIST",
        "ZPARENTLIST1",
        "Z_FOK_PARENTLIST",
        "Z_FOK_PARENTLIST1",
        "ZDADISPLAYORDER",
        "ZISPINNEDBYCURRENTUSER",
        "ZPINNEDDATE",
        "ZSHOULDCATEGORIZEGROCERYITEMS",
        "ZSHOULDAUTOCATEGORIZEITEMS",
        "ZSHOULDSUGGESTCONVERSIONTOGROCERYLIST",
        "ZGROCERYLOCALEID",
        "ZAUTOCATEGORIZATIONLOCALCORRECTIONSCHECKSUM",
        "ZCACHEDGROCERYITEMSCOUNT",
        "ZMEMBERSHIPSOFREMINDERSINPREDEFINEDGROCERYSECTIONSCHECKSUM",
    ]
    columns.extend(column for column in optional_columns if column in table_columns)
    if "ZAUTOCATEGORIZATIONLOCALCORRECTIONSASDATA" in table_columns:
        columns.append("length(ZAUTOCATEGORIZATIONLOCALCORRECTIONSASDATA) AS ZAUTOCATEGORIZATIONLOCALCORRECTIONSASDATA_LENGTH")
    if "ZMEMBERSHIPSOFREMINDERSINPREDEFINEDGROCERYSECTIONSASDATA" in table_columns:
        columns.append("length(ZMEMBERSHIPSOFREMINDERSINPREDEFINEDGROCERYSECTIONSASDATA) AS ZMEMBERSHIPSOFREMINDERSINPREDEFINEDGROCERYSECTIONSASDATA_LENGTH")
    return columns


def list_group_filter_sql(db, *, include_groups):
    table_columns = table_column_names(db, "ZREMCDBASELIST")
    if include_groups or "ZISGROUP" not in table_columns:
        return ""
    return "AND COALESCE(ZISGROUP, 0) = 0 "


def q_base_lists(db, *, include_groups=False):
    columns = list_select_columns(db)
    return db.execute(
        f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL AND ZNAME != '' "
        f"{list_group_filter_sql(db, include_groups=include_groups)}"
        "ORDER BY ZNAME"
    ).fetchall()


def q_lists(db):
    return q_base_lists(db, include_groups=False)


def q_all_lists(db):
    return q_base_lists(db, include_groups=True)


def q_list_groups(db):
    if "ZISGROUP" not in table_column_names(db, "ZREMCDBASELIST"):
        return []
    columns = list_select_columns(db)
    return db.execute(
        f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL AND ZNAME != '' "
        "AND COALESCE(ZISGROUP, 0) = 1 ORDER BY ZNAME"
    ).fetchall()


def q_child_lists(db, group_pk):
    table_columns = table_column_names(db, "ZREMCDBASELIST")
    if "ZPARENTLIST" not in table_columns and "ZPARENTLIST1" not in table_columns:
        return []
    columns = list_select_columns(db)
    parent_clauses = []
    params = []
    if "ZPARENTLIST" in table_columns:
        parent_clauses.append("ZPARENTLIST = ?")
        params.append(group_pk)
    if "ZPARENTLIST1" in table_columns:
        parent_clauses.append("ZPARENTLIST1 = ?")
        params.append(group_pk)
    rows = db.execute(
        f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
        "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL AND ZNAME != '' "
        f"{list_group_filter_sql(db, include_groups=False)}"
        f"AND ({' OR '.join(parent_clauses)})",
        params,
    ).fetchall()
    return sorted(rows, key=list_child_sort_key)


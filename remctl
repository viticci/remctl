def private_metadata_enabled(a=None):
    """True when the caller explicitly opted into private ReminderKit writes."""
    if a is not None and (getattr(a, "private", False) or getattr(a, "private_metadata", False)):
        return True
    return False


def private_available():
    """Check if remctl-private (private ReminderKit helper) is available."""
    return PRIVATE_PATH.exists() and PRIVATE_PATH.stat().st_mode & 0o111


def remindd_running():
    try:
        proc = subprocess.run(
            ["pgrep", "-x", "remindd"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    return proc.returncode == 0


def private_error_payload(status, message, stderr=""):
    return {
        "returncode": -1,
        "stdout": "",
        "stderr": stderr,
        "payload": {"status": status, "message": message},
    }


def private_call_result(data, timeout=30):
    """Call remctl-private and return raw subprocess + parsed JSON details."""
    try:
        proc = subprocess.run(
            [str(PRIVATE_PATH)], input=json.dumps(data),
            capture_output=True, text=True, timeout=timeout
        )
    except subprocess.TimeoutExpired:
        suffix = ""
        if remindd_running() is False:
            suffix = " Reminders daemon (remindd) is not running; open Reminders.app, then retry."
        return private_error_payload(
            "timeout",
            f"private helper did not respond within {timeout}s.{suffix}",
        )
    except FileNotFoundError:
        return private_error_payload(
            "missing_helper",
            f"private helper not found at {PRIVATE_PATH}. Reinstall remctl with ./install.sh.",
        )
    except OSError as exc:
        return private_error_payload("exec_error", f"could not run private helper: {exc}", str(exc))

    payload = None
    if proc.stdout:
        try:
            payload = json.loads(proc.stdout)
        except json.JSONDecodeError:
            payload = None
    if not isinstance(payload, dict):
        detail = (proc.stderr or proc.stdout or "").strip()
        payload = {
            "status": "error",
            "message": detail or f"private helper exited {proc.returncode} with no JSON output.",
        }
    return {
        "returncode": proc.returncode,
        "stdout": proc.stdout,
        "stderr": proc.stderr,
        "payload": payload,
    }


def private_call(data):
    """Call remctl-private with JSON data. Returns parsed JSON response."""
    result = private_call_result(data)
    if result and isinstance(result.get("payload"), dict):
        return result["payload"]
    return {"status": "error", "message": "private helper failed"}


def private_helper_error_is_transient(result):
    if not isinstance(result, dict):
        return False
    message = str(result.get("message") or "")
    return "communicate with a helper application" in message


def private_create_list_call(request, name, attempts=3):
    last_result = None
    for attempt in range(attempts):
        result = private_call(request)
        last_result = result
        if isinstance(result, dict) and result.get("status") == "created":
            return result
        if not private_helper_error_is_transient(result):
            return result

        # ReminderKit can report a transient helper communication failure while
        # the daemon catches up. Re-read before retrying to avoid duplicates.
        for _ in range(4):
            time.sleep(0.25)
            try:
                if q_list_exact_name_count(open_db(), name):
                    recovered = dict(result or {})
                    recovered.update({
                        "status": "created",
                        "action": request.get("action"),
                        "name": name,
                        "verifiedAfterTransientError": True,
                    })
                    return recovered
            except RemindersDBUnavailable:
                break
        if attempt < attempts - 1:
            time.sleep(0.75 * (attempt + 1))
    return last_result


def private_create_group_call(request, name, attempts=3):
    last_result = None
    for attempt in range(attempts):
        result = private_call(request)
        last_result = result
        if isinstance(result, dict) and result.get("status") == "created":
            return result
        if not private_helper_error_is_transient(result):
            return result

        for _ in range(4):
            time.sleep(0.25)
            try:
                if q_group_exact_name_count(open_db(), name):
                    recovered = dict(result or {})
                    recovered.update({
                        "status": "created",
                        "action": request.get("action"),
                        "name": name,
                        "verifiedAfterTransientError": True,
                    })
                    return recovered
            except RemindersDBUnavailable:
                break
        if attempt < attempts - 1:
            time.sleep(0.75 * (attempt + 1))
    return last_result


def _probe_private_protocol_version():
    global _private_protocol_probe
    if _private_protocol_probe is not None:
        return _private_protocol_probe
    result = private_call_result({"action": "protocol_version"}, timeout=5)
    payload = result.get("payload") if isinstance(result, dict) else None
    if not isinstance(payload, dict):
        _private_protocol_probe = {"ok": False, "reason": "broken"}
        return _private_protocol_probe
    version = payload.get("protocolVersion")
    if payload.get("status") == "ok" and isinstance(version, int):
        _private_protocol_probe = {"ok": True, "version": version}
        return _private_protocol_probe
    message = payload.get("message", "")
    if payload.get("status") == "error" and "Unknown action" in message:
        _private_protocol_probe = {"ok": False, "reason": "outdated", "version": 0}
        return _private_protocol_probe
    _private_protocol_probe = {
        "ok": False,
        "reason": "broken",
        "message": message or "private helper protocol check failed",
    }
    return _private_protocol_probe


def require_private_metadata(a=None):
    if not private_metadata_enabled(a):
        print(
            "Error: private metadata writes require --private.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not private_available():
        print(
            "Error: remctl-private is unavailable. Reinstall or set REMCTL_PRIVATE_PATH.",
            file=sys.stderr,
        )
        sys.exit(1)
    probe = _probe_private_protocol_version()
    if probe.get("ok") and probe.get("version", 0) >= PRIVATE_PROTOCOL_VERSION:
        return
    if probe.get("reason") == "outdated":
        version = probe.get("version", 0)
        print(
            f"Error: remctl-private is outdated (protocol {version} < required {PRIVATE_PROTOCOL_VERSION}); re-run install.sh to rebuild.",
            file=sys.stderr,
        )
        sys.exit(1)
    message = probe.get("message")
    if message:
        print(f"Error: {message}", file=sys.stderr)
        sys.exit(1)
    print("Error: remctl-private protocol check failed.", file=sys.stderr)
    sys.exit(1)


def split_csv(value):
    if not value:
        return []
    return [part.strip().lstrip("#") for part in value.split(",") if part.strip().lstrip("#")]


def dedupe_tags(tags):
    result = []
    seen = set()
    for tag in tags:
        tag = tag.strip().lstrip("#")
        if not tag:
            continue
        key = tag.casefold()
        if key in seen:
            continue
        seen.add(key)
        result.append(tag)
    return result


def remove_tag_values(values):
    tags = []
    for value in normalize_repeatable(values):
        tags.extend(split_csv(value))
    return dedupe_tags(tags)


def validate_tag_replacement_args(a):
    additive_tags = bool(getattr(a, "tags", None))
    set_requested = getattr(a, "set_tags", None) is not None
    clear_requested = bool(getattr(a, "clear_tags", False))
    remove_requested = getattr(a, "remove_tag", None) is not None
    replace_modes = sum([set_requested, clear_requested, remove_requested])
    if replace_modes and additive_tags:
        print(
            "Error: -t/--tags adds synced tags and cannot be combined with --set-tags, --clear-tags, or --remove-tag.",
            file=sys.stderr,
        )
        sys.exit(1)
    if replace_modes > 1:
        print("Error: pass only one of --set-tags, --clear-tags, or --remove-tag.", file=sys.stderr)
        sys.exit(1)
    if set_requested and not split_csv(getattr(a, "set_tags", None)):
        print("Error: --set-tags requires at least one tag. Use --clear-tags to remove all tags.", file=sys.stderr)
        sys.exit(1)
    if remove_requested and not remove_tag_values(getattr(a, "remove_tag", None)):
        print("Error: --remove-tag requires a non-empty tag.", file=sys.stderr)
        sys.exit(1)


def normalize_repeatable(values):
    result = []
    for value in values or []:
        if isinstance(value, str):
            value = value.strip()
            if value:
                result.append(value)
    return result


def normalize_image_paths(values):
    result = []
    for value in normalize_repeatable(values):
        result.append(str(Path(value).expanduser()))
    return result


def normalize_string_list(value, field):
    if value is None:
        return []
    if isinstance(value, str):
        if field == "tags":
            return split_csv(value)
        value = value.strip()
        return [value] if value else []
    if isinstance(value, list):
        result = []
        for item in value:
            if not isinstance(item, str):
                print(f"Error: subtask {field} must contain only strings.", file=sys.stderr)
                sys.exit(1)
            item = item.strip()
            if item:
                result.extend(split_csv(item) if field == "tags" else [item])
        return result
    print(f"Error: subtask {field} must be a string or array of strings.", file=sys.stderr)
    sys.exit(1)


def normalize_json_bool(value, field):
    if value is None:
        return None
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "on"}:
            return True
        if lowered in {"0", "false", "no", "off"}:
            return False
    print(f"Error: subtask {field} must be a boolean.", file=sys.stderr)
    sys.exit(1)


def parse_subtask_specs(values):
    specs = []
    for raw in normalize_repeatable(values):
        if raw.lstrip().startswith("{"):
            try:
                spec = json.loads(raw)
            except json.JSONDecodeError as exc:
                print(f"Error: invalid --subtask JSON: {exc.msg}.", file=sys.stderr)
                sys.exit(1)
            if not isinstance(spec, dict):
                print("Error: --subtask JSON must be an object.", file=sys.stderr)
                sys.exit(1)
        else:
            spec = {"title": raw}

        title = spec.get("title")
        if not isinstance(title, str) or not title.strip():
            print("Error: each --subtask requires a non-empty title.", file=sys.stderr)
            sys.exit(1)

        normalized = {"title": title.strip()}
        if "notes" in spec:
            if spec["notes"] is not None and not isinstance(spec["notes"], str):
                print("Error: subtask notes must be a string.", file=sys.stderr)
                sys.exit(1)
            normalized["notes"] = spec["notes"]

        if spec.get("due"):
            due_text = str(spec["due"])
            dt = parse_due(due_text)
            if not dt:
                print(
                    f"Error: could not parse subtask due date {spec['due']!r}. "
                    "Use ISO (YYYY-MM-DD [HH:MM]) or shortcuts like today/tomorrow/eod/+3d.",
                    file=sys.stderr,
                )
                sys.exit(1)
            normalized["due"] = dt.isoformat()
            if due_spec_is_all_day(due_text):
                normalized["allDay"] = True

        if spec.get("priority"):
            priority = str(spec["priority"]).lower()
            if priority not in {"high", "h", "medium", "med", "m", "low", "l", "none"}:
                print("Error: subtask priority must be high, medium, low, or none.", file=sys.stderr)
                sys.exit(1)
            normalized["priority"] = priority

        if spec.get("alarm"):
            alarm = parse_alarm(str(spec["alarm"]))
            if not alarm:
                print(f"Error: could not parse subtask alarm {spec['alarm']!r}.", file=sys.stderr)
                sys.exit(1)
            normalized["alarm"] = alarm

        if spec.get("recurrence"):
            recurrence = parse_recurrence(str(spec["recurrence"]))
            if recurrence is None:
                print(
                    "Error: subtask recurrence must be daily, weekly, monthly, yearly, "
                    "'weekly mon,wed,fri', 'monthly 1,15', 'monthly 4th-fri', or any "
                    "with an 'xN' interval like 'yearly x2'.",
                    file=sys.stderr,
                )
                sys.exit(1)
            normalized["recurrence"] = recurrence

        early_value = spec.get("earlyReminder", spec.get("early_reminder"))
        if early_value is not None:
            early = parse_early_reminder(str(early_value))
            if early is None:
                print(
                    "Error: subtask earlyReminder must be like 15m, 1h, 2d, 1w, 1mo, or clear.",
                    file=sys.stderr,
                )
                sys.exit(1)
            if not early.get("clear") and "due" not in normalized:
                print("Error: subtask earlyReminder requires a subtask due date.", file=sys.stderr)
                sys.exit(1)
            normalized["earlyReminder"] = early_value

        urls = normalize_string_list(spec.get("urls", spec.get("url")), "urls")
        for url in urls:
            if not is_web_url(url):
                print("Error: --private --subtask url requires an http or https URL.", file=sys.stderr)
                sys.exit(1)
            if not is_safe_remote_url(url):
                print("Error: --private --subtask url must resolve to a public http or https host.", file=sys.stderr)
                sys.exit(1)
        if urls:
            normalized["urls"] = urls

        tags = normalize_string_list(spec.get("tags"), "tags")
        if tags:
            normalized["tags"] = tags

        images = normalize_string_list(spec.get("images", spec.get("image")), "images")
        if images:
            readable_images = []
            for image in images:
                image_path = str(Path(image).expanduser())
                if not os.path.isfile(image_path) or not os.access(image_path, os.R_OK):
                    print(f"Error: subtask image attachment is not readable: {image_path}", file=sys.stderr)
                    sys.exit(1)
                readable_images.append(image_path)
            normalized["images"] = readable_images

        for bool_field in ("flagged", "urgent"):
            if bool_field in spec:
                normalized[bool_field] = normalize_json_bool(spec.get(bool_field), bool_field)

        latitude = spec.get("latitude")
        longitude = spec.get("longitude")
        location_title = spec.get("locationTitle", spec.get("location_title"))
        if latitude is not None or longitude is not None or location_title is not None:
            if latitude is None or longitude is None:
                print("Error: subtask location alarms require both latitude and longitude.", file=sys.stderr)
                sys.exit(1)
            try:
                latitude = float(latitude)
                longitude = float(longitude)
                radius = float(spec.get("radius", 100))
            except (TypeError, ValueError):
                print("Error: subtask location latitude, longitude, and radius must be numbers.", file=sys.stderr)
                sys.exit(1)
            if latitude < -90 or latitude > 90:
                print("Error: subtask latitude must be between -90 and 90.", file=sys.stderr)
                sys.exit(1)
            if longitude < -180 or longitude > 180:
                print("Error: subtask longitude must be between -180 and 180.", file=sys.stderr)
                sys.exit(1)
            if radius <= 0:
                print("Error: subtask radius must be greater than 0.", file=sys.stderr)
                sys.exit(1)
            proximity_text = str(spec.get("proximity", "arriving")).lower()
            if proximity_text not in {"arriving", "leaving"}:
                print("Error: subtask proximity must be arriving or leaving.", file=sys.stderr)
                sys.exit(1)
            normalized.update({
                "locationTitle": str(location_title or "Location"),
                "latitude": latitude,
                "longitude": longitude,
                "radius": radius,
                "proximity": 2 if proximity_text == "leaving" else 1,
            })
            if spec.get("address"):
                print("Error: subtask location address is not currently supported.", file=sys.stderr)
                sys.exit(1)

        specs.append(normalized)
    return specs


def subtask_specs_need_bridge(specs):
    bridge_fields = {"notes", "due", "priority", "alarm", "recurrence"}
    return any(bridge_fields.intersection(spec.keys()) for spec in specs)


def bridge_update_subtask(subtask_id, spec):
    pm = {"high": 1, "h": 1, "medium": 5, "med": 5, "m": 5, "low": 9, "l": 9, "none": 0}
    data = {"action": "update", "id": subtask_id}
    if "notes" in spec:
        data["notes"] = spec["notes"]
    if "due" in spec:
        data["due"] = spec["due"]
        if spec.get("allDay"):
            data["allDay"] = True
    if "priority" in spec:
        data["priority"] = pm[spec["priority"]]
    if "alarm" in spec:
        data["alarm"] = spec["alarm"]
    if "recurrence" in spec:
        data["recurrence"] = spec["recurrence"]
    if len(data) == 2:
        return None
    for _ in range(3):
        result = bridge_call(data)
        if result and result.get("status") == "updated":
            return result
        time.sleep(0.2)
    print(
        f"Error: created subtask '{spec['title']}' but failed to apply its public metadata.",
        file=sys.stderr,
    )
    sys.exit(1)


def apply_subtask_private_metadata(subtask_id, spec):
    updates = []
    urls = spec.get("urls", [])
    tags = spec.get("tags", [])
    if urls or tags:
        updates.append(private_action({
            "action": "add_private_metadata",
            "id": subtask_id,
            "urls": urls,
            "tags": tags,
        }))
    if spec.get("images"):
        updates.append(private_action({
            "action": "add_attachments",
            "id": subtask_id,
            "files": [],
            "images": spec["images"],
        }))
    if "flagged" in spec:
        updates.append(private_action({
            "action": "set_flagged",
            "id": subtask_id,
            "flagged": bool(spec["flagged"]),
        }))
    if "urgent" in spec:
        updates.append(private_action({
            "action": "set_urgent",
            "id": subtask_id,
            "urgent": bool(spec["urgent"]),
        }))
    if "earlyReminder" in spec:
        early = parse_early_reminder(spec["earlyReminder"])
        payload = {
            "action": "set_early_reminder",
            "id": subtask_id,
        }
        if early.get("clear"):
            payload["clear"] = True
        else:
            payload["unit"] = early["unit"]
            payload["count"] = early["count"]
        updates.append(private_action(payload))
    if "latitude" in spec or "longitude" in spec:
        updates.append(private_location_action({
            "action": "add_location_alarm",
            "id": subtask_id,
            "title": spec.get("locationTitle") or "Location",
            "latitude": spec["latitude"],
            "longitude": spec["longitude"],
            "radius": spec.get("radius", 100),
            "proximity": spec.get("proximity", 1),
            "address": spec.get("address"),
        }))
    return updates


def is_web_url(value):
    if not value:
        return False
    parsed = urlparse(value)
    return parsed.scheme.lower() in {"http", "https"} and bool(parsed.netloc)


def validate_private_args(a):
    validate_tag_replacement_args(a)

    if getattr(a, "assign", None) and getattr(a, "unassign", False):
        print("Error: pass either --assign or --unassign, not both.", file=sys.stderr)
        sys.exit(1)

    url = getattr(a, "url", None)
    if url and not is_web_url(url):
        print("Error: --private --url requires an http or https URL.", file=sys.stderr)
        sys.exit(1)
    if url and not is_safe_remote_url(url):
        print("Error: --private --url must resolve to a public http or https host.", file=sys.stderr)
        sys.exit(1)

    early_reminder = getattr(a, "early_reminder", None)
    if early_reminder is not None and parse_early_reminder(early_reminder) is None:
        print(
            "Error: --early-reminder must be like 15m, 1h, 2d, 1w, 1mo, or clear.",
            file=sys.stderr,
        )
        sys.exit(1)

    for image in normalize_image_paths(getattr(a, "image", None)):
        if not os.path.isfile(image) or not os.access(image, os.R_OK):
            print(f"Error: image attachment is not readable: {image}", file=sys.stderr)
            sys.exit(1)

    latitude = getattr(a, "latitude", None)
    longitude = getattr(a, "longitude", None)
    if latitude is not None or longitude is not None:
        if latitude is None or longitude is None:
            print("Error: location alarms require both --latitude and --longitude", file=sys.stderr)
            sys.exit(1)
        if getattr(a, "address", None):
            print("Error: --address is not currently supported for location alarms.", file=sys.stderr)
            sys.exit(1)
        if latitude < -90 or latitude > 90:
            print("Error: --latitude must be between -90 and 90.", file=sys.stderr)
            sys.exit(1)
        if longitude < -180 or longitude > 180:
            print("Error: --longitude must be between -180 and 180.", file=sys.stderr)
            sys.exit(1)
        if getattr(a, "radius", 100) is not None and getattr(a, "radius", 100) <= 0:
            print("Error: --radius must be greater than 0.", file=sys.stderr)
            sys.exit(1)

    parse_subtask_specs(getattr(a, "subtask", None))


def early_reminder_requires_due_date(a):
    early_reminder = getattr(a, "early_reminder", None)
    if early_reminder is None:
        return False
    parsed = parse_early_reminder(early_reminder)
    return bool(parsed and not parsed.get("clear"))



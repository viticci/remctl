            None,
            require_current_group_id=group_ref["id"],
            required_group_ref=group_ref,
            a=a,
        )
        detached.append(group_change_summary(child, membership))
    result = apply_private_group_delete(db, group_ref, a)
    if a.json:
        print(json.dumps({
            "status": "deleted",
            "id": group_ref["id"],
            "name": group_ref["title"],
            "objectUUID": group_ref.get("objectUUID"),
            "detachedLists": detached,
            "private": result,
        }, ensure_ascii=False))
    else:
        print(f"Deleted group: {safe_display(group_ref['title'])}")

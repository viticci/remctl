}

def parse_early_reminder(spec):
    """Parse Early Reminder delta specs like 15m, 1h, 2d, 1w, 1mo, or clear."""
    if spec is None:
        return None
    value = str(spec).strip().lower()
    if value in EARLY_REMINDER_CLEAR_VALUES:
        return {"clear": True}
    value = re.sub(r"\s+before$", "", value).strip()
    m = re.match(r"^(\d+)\s*([a-z]+)$", value)
    if not m:
        return None
    amount = int(m.group(1))
    unit_code = EARLY_REMINDER_UNIT_CODES.get(m.group(2))
    if amount <= 0 or unit_code is None:
        return None
    singular, plural = DUE_DATE_DELTA_UNITS[unit_code]
    return {
        "unit": unit_code,
        "unitName": singular if amount == 1 else plural,
        "count": -amount,
        "value": amount,
    }


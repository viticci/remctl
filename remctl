def reminders_store_access_error():
    if STORE_DIR.exists() and not os.access(STORE_DIR, os.R_OK):
        return (
            f"Direct CLI reads are blocked because the Reminders store at {STORE_DIR} "
            f"is not readable from this process context ({sys.executable}). This usually means "
            "Full Disk Access is missing for the app or interpreter that is running remctl here."
        )
    return None


def find_main_db():
    access_error = reminders_store_access_error()
    if access_error:
        raise RemindersDBUnavailable(access_error)
    db_path = find_main_db_path()
    if not db_path:
        raise RemindersDBUnavailable("No Reminders database found. Is iCloud Reminders enabled?")
    return db_path


def find_main_db_path():
    if reminders_store_access_error():
        return None
    candidates = list(STORE_DIR.glob("Data-*.sqlite"))
    if not candidates:
        return None
    scored = [(reminders_db_score(path), path) for path in candidates]
    scored.sort(key=lambda item: item[0], reverse=True)
    return scored[0][1] if scored else None


def sqlite_sidecar_size(path):
    total = 0
    for suffix in ("-wal", "-shm"):
        sidecar = Path(f"{path}{suffix}")
        try:
            total += sidecar.stat().st_size
        except OSError:
            pass
    return total


def table_exists(conn, name):
    try:
        row = conn.execute(
            "SELECT 1 FROM sqlite_master WHERE type='table' AND name=? LIMIT 1",
            (name,),
        ).fetchone()
    except sqlite3.Error:
        return False
    return row is not None


def _db_scalar(conn, sql, default=0):
    try:
        row = conn.execute(sql).fetchone()
    except sqlite3.Error:
        return default
    if not row:
        return default
    value = row[0]
    return default if value is None else value


def reminders_db_score(path):
    """Score a candidate Reminders store using read-only content and sidecars."""
    try:
        db_size = path.stat().st_size
    except OSError:
        db_size = 0
    sidecar_size = sqlite_sidecar_size(path)
    try:
        conn = sqlite3.connect(f"file:{path}?mode=ro", uri=True)
    except sqlite3.Error:
        return (0, 0, 0, 0, 0, sidecar_size, db_size)
    try:
        has_reminder_table = table_exists(conn, "ZREMCDREMINDER")
        has_list_table = table_exists(conn, "ZREMCDBASELIST")
        has_object_table = table_exists(conn, "ZREMCDOBJECT")
        reminder_count = _db_scalar(
            conn,
            "SELECT COUNT(*) FROM ZREMCDREMINDER WHERE COALESCE(ZMARKEDFORDELETION, 0) = 0",
        ) if has_reminder_table else 0
        active_count = _db_scalar(
            conn,
            "SELECT COUNT(*) FROM ZREMCDREMINDER WHERE COALESCE(ZMARKEDFORDELETION, 0) = 0 AND COALESCE(ZCOMPLETED, 0) = 0",
        ) if has_reminder_table else 0
        list_count = _db_scalar(
            conn,
            "SELECT COUNT(*) FROM ZREMCDBASELIST WHERE COALESCE(ZMARKEDFORDELETION, 0) = 0 AND ZNAME IS NOT NULL AND ZNAME != ''",
        ) if has_list_table else 0
        object_count = _db_scalar(
            conn,
            "SELECT COUNT(*) FROM ZREMCDOBJECT WHERE COALESCE(ZMARKEDFORDELETION, 0) = 0",
        ) if has_object_table else 0
        latest_modified = _db_scalar(
            conn,
            "SELECT MAX(COALESCE(ZMODIFIEDDATE, ZLASTMODIFIEDDATE, ZCREATIONDATE, 0)) FROM ZREMCDOBJECT",
        ) if has_object_table else 0
    finally:
        conn.close()
    return (
        1 if has_reminder_table else 0,
        int(reminder_count or 0),
        int(active_count or 0),
        int(list_count or 0),
        int(object_count or 0),
        float(latest_modified or 0),
        sidecar_size,
        db_size,
    )

def open_db():
    conn = sqlite3.connect(f"file:{find_main_db()}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row
    if not table_exists(conn, "ZREMCDREMINDER"):
        conn.close()
        raise RemindersDBUnavailable(
            "Reminders store is missing the expected ZREMCDREMINDER table; "
            "this macOS Reminders schema may need a RemCTL update."
        )
    return conn


def _normalize_write_result(result, *, status, reminder_id, title=None, include_title=True):
    payload = {"status": status, "id": reminder_id}
    final_title = title if title is not None else result.get("title")
    if include_title and final_title:
        payload["title"] = final_title
    return payload


def run_handler_with_fallback(args, handler):
    try:
        handler(args)
    except RemindersDBUnavailable as exc:
        print(f"Error: {exc}", file=sys.stderr)
        if (
            getattr(args, "cmd", None) in EVENTKIT_READ_COMMANDS
            and hasattr(args, "via_eventkit")
            and not eventkit_read_requested(args)
        ):
            print(
                "Limited fallback: rerun with --via-eventkit for a read-only EventKit result "
                "when Full Disk Access is unavailable. This mode is not full fidelity and does "
                "not return RemCTL numeric ids.",
                file=sys.stderr,
            )
        sys.exit(1)



class C:
    """ANSI color helpers. Respects NO_COLOR env and --no-color flag."""
    enabled = True

    @staticmethod
    def _c(code, text):
        return f"\033[{code}m{text}\033[0m" if C.enabled else str(text)

    @staticmethod
    def red(t): return C._c("31", t)
    @staticmethod
    def green(t): return C._c("32", t)
    @staticmethod
    def yellow(t): return C._c("33", t)
    @staticmethod
    def blue(t): return C._c("34", t)
    @staticmethod
    def magenta(t): return C._c("35", t)
    @staticmethod
    def cyan(t): return C._c("36", t)
    @staticmethod
    def dim(t): return C._c("2", t)
    @staticmethod
    def bold(t): return C._c("1", t)
    @staticmethod
    def strikethrough(t): return C._c("9", t)
    @staticmethod
    def rgb(r, g, b, t):
        return f"\033[38;2;{r};{g};{b}m{t}\033[0m" if C.enabled else str(t)


TERMINAL_CONTROL_RE = re.compile(r"[\x00-\x1f\x7f-\x9f\u2028\u2029]")


def safe_display(value):
    """Return text safe to print in a terminal while preserving JSON/raw data."""
    if value is None:
        return ""
    return TERMINAL_CONTROL_RE.sub(" ", str(value))


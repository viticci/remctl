def get_completion_script(shell, command_name="remctl"):
    if shell == "zsh":
        return ZSH_COMPLETION.replace("remctl", command_name)
    if shell == "bash":
        return BASH_COMPLETION.replace("remctl", command_name)
    if shell == "fish":
        return FISH_COMPLETION.replace("remctl", command_name)
    raise ValueError(f"Unsupported shell '{shell}'")


def detect_shell_name():
    shell = os.environ.get("SHELL", "")
    return Path(shell).name if shell else "zsh"


def completion_target_path(shell):
    if shell == "zsh":
        return Path.home() / ".zsh" / "completions" / f"_{CLI_NAME}"
    if shell == "bash":
        return Path.home() / ".local" / "share" / "bash-completion" / "completions" / CLI_NAME
    if shell == "fish":
        return Path.home() / ".config" / "fish" / "completions" / f"{CLI_NAME}.fish"
    raise ValueError(f"Unsupported shell '{shell}'")


def install_completion(shell):
    target = completion_target_path(shell)
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(get_completion_script(shell, command_name=CLI_NAME))
    return target


def zsh_completion_hint(path):
    directory = path.parent
    return (
        f"Add to ~/.zshrc:\n"
        f"    fpath=({directory} $fpath)\n"
        f"    autoload -Uz compinit && compinit"
    )


def zsh_completion_loadable(completion_path):
    target = completion_path.parent.expanduser().resolve(strict=False)
    exported_fpath = os.environ.get("FPATH")
    if exported_fpath:
        for entry in exported_fpath.split(os.pathsep):
            if not entry:
                continue
            try:
                if Path(entry).expanduser().resolve(strict=False) == target:
                    return True
            except OSError:
                continue

    home = Path.home()
    zdotdir = Path(os.environ.get("ZDOTDIR", str(home))).expanduser()
    config_files = [zdotdir / ".zshrc", zdotdir / ".zprofile", zdotdir / ".zshenv"]
    needles = {
        str(completion_path.parent),
        str(completion_path.parent.expanduser()),
        str(completion_path.parent.expanduser().resolve(strict=False)),
    }
    home_relative = None
    try:
        home_relative = completion_path.parent.expanduser().resolve(strict=False).relative_to(home)
    except ValueError:
        pass
    if home_relative is not None:
        rel = str(home_relative)
        needles.update({f"~/{rel}", f"$HOME/{rel}"})
    for config_file in config_files:
        try:
            text = config_file.read_text(errors="ignore")
        except OSError:
            continue
        if any(needle and needle in text for needle in needles):
            return True
    return False


def resolve_setup_shell(requested_shell):
    if requested_shell != "auto":
        return requested_shell
    detected = detect_shell_name()
    return detected if detected in {"zsh", "bash", "fish"} else "skip"



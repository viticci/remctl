# ── Database ─────────────────────────────────────────────────────────────────

def reminders_store_access_error():
    if STORE_DIR.exists() and not os.access(STORE_DIR, os.R_OK):
        return (
            f"Direct CLI reads are blocked because the Reminders store at {STORE_DIR} "
            f"is not readable from {sys.executable}. This usually means Full Disk Access "
            "is missing for the terminal app or this Python interpreter."
        )
    return None


def find_main_db():
    access_error = reminders_store_access_error()
    if access_error:
        raise RemindersDBUnavailable(access_error)
    db_path = find_main_db_path()
    if not db_path:
        raise RemindersDBUnavailable("No Reminders database found. Is iCloud Reminders enabled?")
    return db_path


def find_main_db_path():
    if reminders_store_access_error():
        return None
    candidates = sorted(STORE_DIR.glob("Data-*.sqlite"), key=lambda p: p.stat().st_size, reverse=True)
    return candidates[0] if candidates else None

def open_db():
    conn = sqlite3.connect(f"file:{find_main_db()}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row
    return conn

def ts(v):
    if not v: return None
    return datetime.fromtimestamp(v + APPLE_EPOCH)

def to_ts(dt):
    return dt.timestamp() - APPLE_EPOCH

PRI = {0: "", 1: "!!!", 5: "!!", 9: "!"}
PRI_NAME = {0: "none", 1: "high", 5: "medium", 9: "low"}

# ── List Color Parsing ───────────────────────────────────────────────────────

LIST_COLOR_MAP = {
    "red": (255, 41, 104),
    "orange": (255, 149, 0),
    "yellow": (255, 204, 0),
    "green": (99, 218, 56),
    "blue": (0, 122, 255),
    "purple": (204, 115, 225),
    "brown": (162, 132, 94),
    "cyan": (90, 200, 250),
    "teal": (48, 176, 199),
}

def parse_list_color(blob):
    """Extract color info from ZCOLOR binary plist (NSKeyedArchiver)."""
    if not blob:
        return {"name": "blue", "hex": "#007AFF"}
    try:
        data = plistlib.loads(bytes(blob))
        objects = data.get("$objects", [])
        for obj in objects:
            if isinstance(obj, dict) and "ckSymbolicColorName" in obj:
                name_uid = obj["ckSymbolicColorName"]
                hex_uid = obj.get("daHexString")
                name = objects[name_uid.data] if hasattr(name_uid, 'data') else str(name_uid)
                hex_str = objects[hex_uid.data] if hex_uid and hasattr(hex_uid, 'data') else ""
                return {"name": name, "hex": hex_str}
    except Exception:
        pass
    return {"name": "blue", "hex": "#007AFF"}

def load_list_colors(db):
    """Load all list colors into a dict {list_name: (r, g, b)}."""
    colors = {}
    try:
        rows = db.execute(
            "SELECT ZNAME, ZCOLOR FROM ZREMCDBASELIST "
            "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL"
        ).fetchall()
        for r in rows:
            info = parse_list_color(r["ZCOLOR"])
            rgb = LIST_COLOR_MAP.get(info["name"], (0, 122, 255))
            colors[r["ZNAME"]] = rgb
    except Exception:
        pass
    return colors

# Global list color cache — populated on demand
_list_colors = None

def get_list_colors(db):
    global _list_colors
    if _list_colors is None:
        _list_colors = load_list_colors(db)
    return _list_colors

def color_list_name(name, db=None):
    """Return the list name colored by its Reminders color."""
    if not name or not C.enabled:
        return name or "(none)"
    if db:
        colors = get_list_colors(db)
        if name in colors:
            r, g, b = colors[name]
            return C.rgb(r, g, b, name)
    return C.cyan(name)


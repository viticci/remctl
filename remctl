def require_private_metadata(a=None):
    if not private_metadata_enabled(a):
        print(
            "Error: private metadata writes require --private.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not private_available():
        print(
            "Error: remctl-private is unavailable. Reinstall or set REMCTL_PRIVATE_PATH.",
            file=sys.stderr,
        )
        sys.exit(1)


def split_csv(value):
    if not value:
        return []
    return [part.strip().lstrip("#") for part in value.split(",") if part.strip().lstrip("#")]


def normalize_repeatable(values):
    result = []
    for value in values or []:
        if isinstance(value, str):
            value = value.strip()
            if value:
                result.append(value)
    return result


def normalize_image_paths(values):
    result = []
    for value in normalize_repeatable(values):
        result.append(str(Path(value).expanduser()))
    return result


def normalize_string_list(value, field):
    if value is None:
        return []
    if isinstance(value, str):
        if field == "tags":
            return split_csv(value)
        value = value.strip()
        return [value] if value else []
    if isinstance(value, list):
        result = []
        for item in value:
            if not isinstance(item, str):
                print(f"Error: subtask {field} must contain only strings.", file=sys.stderr)
                sys.exit(1)
            item = item.strip()
            if item:
                result.extend(split_csv(item) if field == "tags" else [item])
        return result
    print(f"Error: subtask {field} must be a string or array of strings.", file=sys.stderr)
    sys.exit(1)


def normalize_json_bool(value, field):
    if value is None:
        return None
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "on"}:
            return True
        if lowered in {"0", "false", "no", "off"}:
            return False
    print(f"Error: subtask {field} must be a boolean.", file=sys.stderr)
    sys.exit(1)


def parse_subtask_specs(values):
    specs = []
    for raw in normalize_repeatable(values):
        if raw.lstrip().startswith("{"):
            try:
                spec = json.loads(raw)
            except json.JSONDecodeError as exc:
                print(f"Error: invalid --subtask JSON: {exc.msg}.", file=sys.stderr)
                sys.exit(1)
            if not isinstance(spec, dict):
                print("Error: --subtask JSON must be an object.", file=sys.stderr)
                sys.exit(1)
        else:
            spec = {"title": raw}

        title = spec.get("title")
        if not isinstance(title, str) or not title.strip():
            print("Error: each --subtask requires a non-empty title.", file=sys.stderr)
            sys.exit(1)

        normalized = {"title": title.strip()}
        if "notes" in spec:
            if spec["notes"] is not None and not isinstance(spec["notes"], str):
                print("Error: subtask notes must be a string.", file=sys.stderr)
                sys.exit(1)
            normalized["notes"] = spec["notes"]

        if spec.get("due"):
            dt = parse_due(str(spec["due"]))
            if not dt:
                print(
                    f"Error: could not parse subtask due date {spec['due']!r}. "
                    "Use ISO (YYYY-MM-DD [HH:MM]) or shortcuts like today/tomorrow/eod/+3d.",
                    file=sys.stderr,
                )
                sys.exit(1)
            normalized["due"] = dt.isoformat()

        if spec.get("priority"):
            priority = str(spec["priority"]).lower()
            if priority not in {"high", "h", "medium", "med", "m", "low", "l", "none"}:
                print("Error: subtask priority must be high, medium, low, or none.", file=sys.stderr)
                sys.exit(1)
            normalized["priority"] = priority

        if spec.get("alarm"):
            alarm = parse_alarm(str(spec["alarm"]))
            if not alarm:
                print(f"Error: could not parse subtask alarm {spec['alarm']!r}.", file=sys.stderr)
                sys.exit(1)
            normalized["alarm"] = alarm

        if spec.get("recurrence"):
            normalized["recurrence"] = parse_recurrence(str(spec["recurrence"]))

        urls = normalize_string_list(spec.get("urls", spec.get("url")), "urls")
        for url in urls:
            if not is_web_url(url):
                print("Error: --private --subtask url requires an http or https URL.", file=sys.stderr)
                sys.exit(1)
        if urls:
            normalized["urls"] = urls

        tags = normalize_string_list(spec.get("tags"), "tags")
        if tags:
            normalized["tags"] = tags

        images = normalize_string_list(spec.get("images", spec.get("image")), "images")
        if images:
            readable_images = []
            for image in images:
                image_path = str(Path(image).expanduser())
                if not os.path.isfile(image_path) or not os.access(image_path, os.R_OK):
                    print(f"Error: subtask image attachment is not readable: {image_path}", file=sys.stderr)
                    sys.exit(1)
                readable_images.append(image_path)
            normalized["images"] = readable_images

        for bool_field in ("flagged", "urgent"):
            if bool_field in spec:
                normalized[bool_field] = normalize_json_bool(spec.get(bool_field), bool_field)

        latitude = spec.get("latitude")
        longitude = spec.get("longitude")
        location_title = spec.get("locationTitle", spec.get("location_title"))
        if latitude is not None or longitude is not None or location_title is not None:
            if latitude is None or longitude is None:
                print("Error: subtask location alarms require both latitude and longitude.", file=sys.stderr)
                sys.exit(1)
            try:
                latitude = float(latitude)
                longitude = float(longitude)
                radius = float(spec.get("radius", 100))
            except (TypeError, ValueError):
                print("Error: subtask location latitude, longitude, and radius must be numbers.", file=sys.stderr)
                sys.exit(1)
            if latitude < -90 or latitude > 90:
                print("Error: subtask latitude must be between -90 and 90.", file=sys.stderr)
                sys.exit(1)
            if longitude < -180 or longitude > 180:
                print("Error: subtask longitude must be between -180 and 180.", file=sys.stderr)
                sys.exit(1)
            if radius <= 0:
                print("Error: subtask radius must be greater than 0.", file=sys.stderr)
                sys.exit(1)
            proximity_text = str(spec.get("proximity", "arriving")).lower()
            if proximity_text not in {"arriving", "leaving"}:
                print("Error: subtask proximity must be arriving or leaving.", file=sys.stderr)
                sys.exit(1)
            normalized.update({
                "locationTitle": str(location_title or "Location"),
                "latitude": latitude,
                "longitude": longitude,
                "radius": radius,
                "proximity": 2 if proximity_text == "leaving" else 1,
            })
            if spec.get("address"):
                normalized["address"] = str(spec["address"])

        specs.append(normalized)
    return specs


def subtask_specs_need_bridge(specs):
    bridge_fields = {"notes", "due", "priority", "alarm", "recurrence"}
    return any(bridge_fields.intersection(spec.keys()) for spec in specs)


def bridge_update_subtask(subtask_id, spec):
    pm = {"high": 1, "h": 1, "medium": 5, "med": 5, "m": 5, "low": 9, "l": 9, "none": 0}
    data = {"action": "update", "id": subtask_id}
    if "notes" in spec:
        data["notes"] = spec["notes"]
    if "due" in spec:
        data["due"] = spec["due"]
    if "priority" in spec:
        data["priority"] = pm[spec["priority"]]
    if "alarm" in spec:
        data["alarm"] = spec["alarm"]
    if "recurrence" in spec:
        data["recurrence"] = spec["recurrence"]
    if len(data) == 2:
        return None
    for _ in range(3):
        result = bridge_call(data)
        if result and result.get("status") == "updated":
            return result
        time.sleep(0.2)
    print(
        f"Error: created subtask '{spec['title']}' but failed to apply its public metadata.",
        file=sys.stderr,
    )
    sys.exit(1)


def apply_subtask_private_metadata(subtask_id, spec):
    updates = []
    urls = spec.get("urls", [])
    tags = spec.get("tags", [])
    if urls or tags:
        updates.append(private_action({
            "action": "add_private_metadata",
            "id": subtask_id,
            "urls": urls,
            "tags": tags,
        }))
    if spec.get("images"):
        updates.append(private_action({
            "action": "add_attachments",
            "id": subtask_id,
            "files": [],
            "images": spec["images"],
        }))
    if "flagged" in spec:
        updates.append(private_action({
            "action": "set_flagged",
            "id": subtask_id,
            "flagged": bool(spec["flagged"]),
        }))
    if "urgent" in spec:
        updates.append(private_action({
            "action": "set_urgent",
            "id": subtask_id,
            "urgent": bool(spec["urgent"]),
        }))
    if "latitude" in spec or "longitude" in spec:
        updates.append(private_action({
            "action": "add_location_alarm",
            "id": subtask_id,
            "title": spec.get("locationTitle") or "Location",
            "latitude": spec["latitude"],
            "longitude": spec["longitude"],
            "radius": spec.get("radius", 100),
            "proximity": spec.get("proximity", 1),
            "address": spec.get("address"),
        }))
    return updates


def is_web_url(value):
    if not value:
        return False
    parsed = urlparse(value)
    return parsed.scheme.lower() in {"http", "https"} and bool(parsed.netloc)


def validate_private_args(a):
    url = getattr(a, "url", None)
    if url and not is_web_url(url):
        print("Error: --private --url requires an http or https URL.", file=sys.stderr)
        sys.exit(1)

    for image in normalize_image_paths(getattr(a, "image", None)):
        if not os.path.isfile(image) or not os.access(image, os.R_OK):
            print(f"Error: image attachment is not readable: {image}", file=sys.stderr)
            sys.exit(1)

    latitude = getattr(a, "latitude", None)
    longitude = getattr(a, "longitude", None)
    if latitude is not None or longitude is not None:
        if latitude is None or longitude is None:
            print("Error: location alarms require both --latitude and --longitude", file=sys.stderr)
            sys.exit(1)
        if latitude < -90 or latitude > 90:
            print("Error: --latitude must be between -90 and 90.", file=sys.stderr)
            sys.exit(1)
        if longitude < -180 or longitude > 180:
            print("Error: --longitude must be between -180 and 180.", file=sys.stderr)
            sys.exit(1)
        if getattr(a, "radius", 100) is not None and getattr(a, "radius", 100) <= 0:
            print("Error: --radius must be greater than 0.", file=sys.stderr)
            sys.exit(1)

    parse_subtask_specs(getattr(a, "subtask", None))


def private_action(data):
    result = private_call(data)
    if not result or result.get("status") != "updated":
        message = result.get("message") if isinstance(result, dict) else "private helper failed"
        print(f"Error: {message}", file=sys.stderr)
        sys.exit(1)
    return result

def validate_list_appearance_args(a):
    symbol = getattr(a, "symbol", None)
    emoji = getattr(a, "emoji", None)
    if symbol and emoji:
        print("Error: pass either --symbol or --emoji, not both.", file=sys.stderr)
        sys.exit(1)
    if symbol is not None:
        normalized_symbol = symbol.strip()
        if not normalized_symbol:
            print("Error: --symbol cannot be empty.", file=sys.stderr)
            sys.exit(1)
    if emoji is not None and not emoji.strip():
        print("Error: --emoji cannot be empty.", file=sys.stderr)
        sys.exit(1)
    if (symbol or emoji) and not private_metadata_enabled(a):
        print(
            "Error: list and smart-list symbols/emojis require --private. "
            "Example: remctl list-create \"Projects\" --private --symbol education3",
            file=sys.stderr,
        )
        sys.exit(1)
    if symbol is not None:
        normalized_symbol = symbol.strip()
        if normalized_symbol not in OFFICIAL_LIST_SYMBOL_NAMES:
            print(
                f"Error: unsupported list symbol {normalized_symbol!r}. "
                "Run `remctl list-symbols` to see official names, or use --emoji for custom emoji badges.",
                file=sys.stderr,
            )
            sys.exit(1)
    color = getattr(a, "color", None)
    validate_list_color(color, private=private_metadata_enabled(a))
    validate_list_grocery_args(a)


GROCERY_LOCALE_RE = re.compile(r"^[A-Za-z]{2,3}(?:[_-][A-Za-z0-9]{2,8})?$")
DEFAULT_GROCERY_LOCALE_ID = "en_US"


def list_grocery_changes_from_args(a):
    return any([
        bool(getattr(a, "groceries", False)),
        bool(getattr(a, "standard", False)),
        getattr(a, "grocery_locale", None),
    ])


def normalize_grocery_locale(value):
    if value is None:
        return None
    locale_id = str(value).strip()
    if not locale_id:
        print("Error: --grocery-locale cannot be empty.", file=sys.stderr)
        sys.exit(1)
    locale_id = locale_id.replace("-", "_")
    if not GROCERY_LOCALE_RE.match(locale_id):
        print("Error: --grocery-locale must look like en_US or it_IT.", file=sys.stderr)
        sys.exit(1)
    parts = locale_id.split("_", 1)
    if len(parts) == 2:
        return f"{parts[0].lower()}_{parts[1].upper()}"
    return parts[0].lower()


def validate_list_grocery_args(a):
    if getattr(a, "groceries", False) and getattr(a, "standard", False):
        print("Error: pass either --groceries or --standard, not both.", file=sys.stderr)
        sys.exit(1)
    if getattr(a, "standard", False) and getattr(a, "grocery_locale", None):
        print("Error: --grocery-locale cannot be combined with --standard.", file=sys.stderr)
        sys.exit(1)
    if list_grocery_changes_from_args(a) and not private_metadata_enabled(a):
        print(
            "Error: grocery list metadata requires --private. "
            "Example: remctl list-create \"Groceries\" --private --groceries --grocery-locale en_US",
            file=sys.stderr,
        )
        sys.exit(1)
    if getattr(a, "grocery_locale", None):
        normalize_grocery_locale(a.grocery_locale)

def list_private_appearance_payload(a, *, include_public_color_names=True):
    payload = {}
    if getattr(a, "new_name", None):
        payload["name"] = a.new_name
    color = getattr(a, "color", None)
    if color and private_metadata_enabled(a):
        normalized_color = normalize_list_color(color)
        if include_public_color_names or (normalized_color and HEX_COLOR_RE.match(normalized_color)):
            payload["color"] = normalized_color
    if getattr(a, "symbol", None):
        payload["symbol"] = a.symbol.strip()
    if getattr(a, "emoji", None):
        payload["emoji"] = a.emoji.strip()
    if getattr(a, "groceries", False):
        payload["shouldCategorizeGroceryItems"] = True
        payload["groceryLocaleID"] = normalize_grocery_locale(getattr(a, "grocery_locale", None)) or DEFAULT_GROCERY_LOCALE_ID
    elif getattr(a, "standard", False):
        payload["shouldCategorizeGroceryItems"] = False
    elif getattr(a, "grocery_locale", None):
        payload["groceryLocaleID"] = normalize_grocery_locale(a.grocery_locale)
    return payload

def list_appearance_changes_from_args(a):
    return any([
        getattr(a, "color", None),
        getattr(a, "symbol", None),
        getattr(a, "emoji", None),
        list_grocery_changes_from_args(a),
    ])

def apply_private_list_appearance(db, list_pk, a, *, exit_on_error=True, include_public_color_names=True):
    require_private_metadata(a)
    ckid = q_list_ckid(db, list_pk)
    if not ckid:
        print("Error: target list has no stable CloudKit identifier.", file=sys.stderr)
        sys.exit(1)
    payload = list_private_appearance_payload(a, include_public_color_names=include_public_color_names)
    if not payload:
        return None
    payload.update({"action": "set_list_appearance", "listId": ckid})
    result = private_call(payload)
    if result and result.get("status") == "updated":
        return result
    message = result.get("message") if isinstance(result, dict) else "private helper failed"
    if exit_on_error:
        print(f"Error: {message}", file=sys.stderr)
        sys.exit(1)
    return {"status": "error", "message": message}



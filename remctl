        for name, asset, preview in OFFICIAL_LIST_SYMBOLS
    ]

def default_list_symbols_html_path():
    return CONFIG_DIR / "list-symbols.html"

def export_list_symbol_asset_data(rows):
    swift = shutil.which("swift") or "/usr/bin/swift"
    if not Path(swift).exists():
        raise RuntimeError("Swift is required to export Reminders badge assets for the HTML preview.")
    if not REMINDERS_UI_CORE_BUNDLE.exists():
        raise RuntimeError(f"RemindersUICore framework not found at {REMINDERS_UI_CORE_BUNDLE}.")

    source = r'''
import AppKit
import Foundation

let args = CommandLine.arguments
guard args.count >= 4 else {
    fputs("usage: swift - <bundle-path> <output-dir> <asset>...\n", stderr)
    exit(64)
}
let bundlePath = args[1]
let outputURL = URL(fileURLWithPath: args[2], isDirectory: true)
let assets = Array(args.dropFirst(3))
guard let bundle = Bundle(path: bundlePath) else {
    fputs("Cannot load bundle: \(bundlePath)\n", stderr)
    exit(65)
}
try FileManager.default.createDirectory(at: outputURL, withIntermediateDirectories: true)
var missing: [String] = []
for asset in assets {
    guard let image = bundle.image(forResource: asset), let tiff = image.tiffRepresentation,
          let rep = NSBitmapImageRep(data: tiff),
          let png = rep.representation(using: .png, properties: [:]) else {
        missing.append(asset)
        continue
    }
    try png.write(to: outputURL.appendingPathComponent(asset + ".png"))
}
if !missing.isEmpty {
    fputs("Missing badge assets: \(missing.joined(separator: ", "))\n", stderr)
    exit(66)
}
'''
    assets = [row["asset"] for row in rows]
    with tempfile.TemporaryDirectory(prefix="remctl-list-symbols-") as tmpdir:
        result = subprocess.run(
            [swift, "-", str(REMINDERS_UI_CORE_BUNDLE), tmpdir, *assets],
            input=source,
            text=True,
            capture_output=True,
        )
        if result.returncode != 0:
            detail = (result.stderr or result.stdout or "asset export failed").strip()
            raise RuntimeError(detail)
        data = {}
        for asset in assets:
            png_path = Path(tmpdir) / f"{asset}.png"
            data[asset] = base64.b64encode(png_path.read_bytes()).decode("ascii")
        return data


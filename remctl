def clone_reminder_tree_to_list_or_die(db, reminder, target_list_ref, child_rows):
    reminder_ckid = _row_get(reminder, "ZCKIDENTIFIER")
    target_list_ckid = target_list_ref.get("objectUUID")
    if not reminder_ckid:
        print("Error: cannot clone-move reminder because it has no stable ReminderKit identifier.", file=sys.stderr)
        sys.exit(1)
    if not target_list_ckid:
        print("Error: cannot clone-move reminder because the target list has no stable ReminderKit identifier.", file=sys.stderr)
        sys.exit(1)
    if not private_available():
        print(
            f"Error: clone-moving #{reminder['Z_PK']} requires remctl-private. "
            "Reinstall remctl with ./install.sh, then retry.",
            file=sys.stderr,
        )
        sys.exit(1)
    child_ids = [_row_get(child, "ZCKIDENTIFIER") for child in child_rows]
    missing = [child["Z_PK"] for child, child_id in zip(child_rows, child_ids) if not child_id]
    if missing:
        print(
            "Error: cannot move parent with subtasks because these subtasks have no stable ReminderKit identifier: "
            + ", ".join(f"#{item}" for item in missing),
            file=sys.stderr,
        )
        sys.exit(1)
    result = private_call({
        "action": "clone_reminder_tree_to_list",
        "id": reminder_ckid,
        "listId": target_list_ckid,
        "childIds": child_ids,
    })
    if not result or result.get("status") != "cloned":
        message = result.get("message") if isinstance(result, dict) else "private helper failed"
        print(f"Error: failed to clone reminder into target list: {message}", file=sys.stderr)
        sys.exit(1)
    new_ckid = result.get("newId")
    if not new_ckid:
        print("Error: private helper cloned the reminder but did not return the new reminder identifier.", file=sys.stderr)
        sys.exit(1)
    new_row, new_children = wait_for_cloned_reminder_tree(new_ckid, target_list_ref["id"], len(child_rows))
    if not new_row:
        print(
            "Error: cloned reminder tree was not visible in the target list with the expected subtask count. "
            f"Original #{reminder['Z_PK']} was not deleted.",
            file=sys.stderr,
        )
        sys.exit(1)
    delete_result = delete_reminder_by_identifier_or_die(reminder)
    return {
        "status": "updated",
        "id": new_row["Z_PK"],
        "oldId": reminder["Z_PK"],
        "list": target_list_ref["title"],
        "objectUUID": new_ckid,
        "subtasksMoved": len(new_children),
        "method": "clone-delete",
        "private": result,
        "delete": delete_result,
    }



def cmd_setup(a):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    try:
        CONFIG_DIR.chmod(0o700)
    except OSError:
        pass
    selected_shell = resolve_setup_shell(a.shell)
    completion_path = None
    if selected_shell != "skip":
        try:
            completion_path = install_completion(selected_shell)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            sys.exit(1)

    result = {
        "ok": True,
        "config_dir": str(CONFIG_DIR),
        "completion_shell": None if selected_shell == "skip" else selected_shell,
        "completion_path": str(completion_path) if completion_path else None,
    }
    if getattr(a, "doctor", False):
        doctor_checks = gather_doctor_checks()
        result["doctor"] = {
            "ok": sum(1 for check in doctor_checks if check["status"] == "fail") == 0,
            "checks": doctor_checks,
        }

    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print(C.bold("RemCTL setup"))
        print(f"Config directory: {CONFIG_DIR}")
        if completion_path:
            print(f"Shell completion: {completion_path}")
        else:
            print("Shell completion: skipped")
        print()
        print("Next:")
        print("  1. remctl onboard   # trigger macOS Reminders and Automation prompts")
        print("  2. remctl permissions full-disk-access   # visual Full Disk Access setup")
        print("  3. remctl doctor    # verify the CLI")
        if getattr(a, "doctor", False):
            print()
            cmd_doctor(SimpleNamespace(json=False))


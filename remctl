    ]

def parse_list_color(blob):
    """Extract color info from ZCOLOR binary plist (NSKeyedArchiver)."""
    if not blob:
        return {"name": "blue", "hex": "#007AFF"}
    try:
        data = plistlib.loads(bytes(blob))
        objects = data.get("$objects", [])
        for obj in objects:
            if isinstance(obj, dict) and "ckSymbolicColorName" in obj:
                name_uid = obj["ckSymbolicColorName"]
                hex_uid = obj.get("daHexString")
                name = objects[name_uid.data] if hasattr(name_uid, 'data') else str(name_uid)
                hex_str = objects[hex_uid.data] if hex_uid and hasattr(hex_uid, 'data') else ""
                return {"name": name, "hex": hex_str}
    except Exception:
        pass
    return {"name": "blue", "hex": "#007AFF"}


def parse_badge_emblem(value):
    if not value:
        return None
    payload = {"raw": value}
    if isinstance(value, str):
        stripped = value.strip()
        if stripped.startswith("{"):
            try:
                decoded = json.loads(stripped)
            except json.JSONDecodeError:
                decoded = None
            if isinstance(decoded, dict):
                emoji = decoded.get("Emoji") or decoded.get("emoji")
                emblem = decoded.get("Emblem") or decoded.get("emblem")
                if emoji:
                    payload["emoji"] = emoji
                if emblem:
                    payload["symbol"] = emblem
        elif stripped:
            payload["symbol"] = stripped
    return payload

def load_list_colors(db):
    """Load all list colors into a dict {list_name: (r, g, b)}."""
    colors = {}
    try:
        rows = db.execute(
            "SELECT ZNAME, ZCOLOR FROM ZREMCDBASELIST "
            "WHERE ZMARKEDFORDELETION = 0 AND Z_ENT = 3 AND ZNAME IS NOT NULL"
        ).fetchall()
        for r in rows:
            info = parse_list_color(r["ZCOLOR"])
            rgb = LIST_COLOR_MAP.get(info["name"], (0, 122, 255))
            colors[r["ZNAME"]] = rgb
    except Exception:
        pass
    return colors

# Global list color cache — populated on demand
_list_colors = None

def get_list_colors(db):
    global _list_colors
    if _list_colors is None:
        _list_colors = load_list_colors(db)
    return _list_colors

def color_list_name(name, db=None):
    """Return the list name colored by its Reminders color."""
    original_name = name
    display_name = safe_display(name or "(none)")
    if not name or not C.enabled:
        return display_name
    if db:
        colors = get_list_colors(db)
        if original_name in colors:
            r, g, b = colors[original_name]
            return C.rgb(r, g, b, display_name)
    return C.cyan(display_name)


def color_for_list_name(name, db=None):
    """Return RGB color tuple for a Reminders list when the database is available."""
    if not name or not db:
        return None
    colors = get_list_colors(db)
    return colors.get(name)


def color_by_list(text, list_name=None, db=None):
    """Color arbitrary text using the Reminders color for its list."""
    text = str(text)
    if not C.enabled:
        return text
    rgb = color_for_list_name(list_name, db)
    if rgb:
        r, g, b = rgb
        return C.rgb(r, g, b, text)
    return C.cyan(text) if list_name else C.dim(text)


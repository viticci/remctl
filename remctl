def format_command_columns(commands, width=88):
    commands = sorted(commands)
    lines = []
    current = ""
    for command in commands:
        token = command if not current else f", {command}"
        if current and len(current) + len(token) > width:
            lines.append(current)
            current = command
        else:
            current += token
    if current:
        lines.append(current)
    return lines


def first_command_token(argv):
    # Flags that consume the following token as their value; the value must
    # not be mistaken for the command name.
    skip_value_for = {"--format", "--image-mode", "--image-width"}
    iterator = iter(argv)
    for token in iterator:
        if token in {"-h", "--help", "--version"}:
            return None
        if token in skip_value_for:
            next(iterator, None)
            continue
        if token.startswith("--format="):
            continue
        if token.startswith("--image-mode=") or token.startswith("--image-width="):
            continue
        if token == "--no-color":
            continue
        if token.startswith("-"):
            continue
        return token
    return None


def suggest_command(command, choices):
    if command == "symbols" and "list-symbols" in choices:
        return "list-symbols"
    suffix_matches = [choice for choice in choices if choice.endswith(f"-{command}")]
    if len(suffix_matches) == 1:
        return suffix_matches[0]
    return None


def parse_cli_args(parser, subparsers, argv=None):
    """Parse argv with a friendly unknown-command error instead of argparse's.

    argv defaults to sys.argv[1:]. Kept separate from main() so tests can
    drive the real parser without running a command.
    """
    args = sys.argv[1:] if argv is None else argv
    command_token = first_command_token(args)
    if command_token and command_token not in subparsers.choices:
        print(f"remctl: error: unknown command: {command_token!r}", file=sys.stderr)
        suggestion = suggest_command(command_token, subparsers.choices)
        if suggestion:
            print(f"Did you mean: remctl {suggestion}", file=sys.stderr)
        print("Available commands:", file=sys.stderr)
        for line in format_command_columns(subparsers.choices):
            print(f"  {line}", file=sys.stderr)
        print("Run `remctl <command> --help` for command-specific options.", file=sys.stderr)
        sys.exit(2)
    return parser.parse_args(args)



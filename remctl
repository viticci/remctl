            )
            sys.exit(1)
        request = {"action": "create_list", "name": a.name}
        request.update(list_private_appearance_payload(a, include_public_color_names=True))
        result = private_call(request)
        if not result or result.get("status") != "created":
            message = result.get("message") if isinstance(result, dict) else "private helper failed"
            print(f"Error: Failed to create list '{a.name}': {message}", file=sys.stderr)
            sys.exit(1)
        if a.json:
            print(json.dumps({"status": "created", "name": a.name, "private": result}, ensure_ascii=False))
        else:
            print(f"Created list: {a.name}")
            details = []

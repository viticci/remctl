def _row_value(row, key):
    try:
        return row[key]
    except (KeyError, TypeError, IndexError):
        if key == "Z_PK":
            return row[0]
        if key == "ZNAME":
            return row[1]
        if key == "ZCKIDENTIFIER":
            return row[2] if len(row) > 2 else None
        raise

def _row_has_key(row, key):
    try:
        return key in row.keys()
    except AttributeError:
        return False


def _row_get(row, key, default=None):
    return row[key] if _row_has_key(row, key) else default


def is_grocery_list_row(row):
    return bool(_row_get(row, "ZSHOULDCATEGORIZEGROCERYITEMS", 0))


def grocery_list_payload(row):
    if not any(
        _row_has_key(row, key)
        for key in (
            "ZSHOULDCATEGORIZEGROCERYITEMS",
            "ZSHOULDAUTOCATEGORIZEITEMS",
            "ZSHOULDSUGGESTCONVERSIONTOGROCERYLIST",
            "ZGROCERYLOCALEID",
            "ZAUTOCATEGORIZATIONLOCALCORRECTIONSASDATA_LENGTH",
        )
    ):
        return None

    payload = {
        "shouldCategorizeItems": bool(_row_get(row, "ZSHOULDCATEGORIZEGROCERYITEMS", 0)),
        "shouldAutoCategorizeItems": bool(_row_get(row, "ZSHOULDAUTOCATEGORIZEITEMS", 0)),
        "shouldSuggestConversion": bool(_row_get(row, "ZSHOULDSUGGESTCONVERSIONTOGROCERYLIST", 0)),
    }
    locale = _row_get(row, "ZGROCERYLOCALEID")
    if locale:
        payload["locale"] = locale
    corrections_length = _row_get(row, "ZAUTOCATEGORIZATIONLOCALCORRECTIONSASDATA_LENGTH")
    if corrections_length is not None:
        payload["localCorrectionsLength"] = corrections_length
    corrections_checksum = _row_get(row, "ZAUTOCATEGORIZATIONLOCALCORRECTIONSCHECKSUM")
    if corrections_checksum:
        payload["localCorrectionsChecksum"] = corrections_checksum
    return payload


def list_to_dict(row):
    is_groceries = is_grocery_list_row(row)
    item = {
        "id": _row_value(row, "Z_PK"),
        "title": _row_value(row, "ZNAME"),
        "listType": "groceries" if is_groceries else "standard",
        "isGroceries": is_groceries,
    }
    object_uuid = _row_value(row, "ZCKIDENTIFIER")
    if object_uuid:
        item["objectUUID"] = object_uuid
    grocery = grocery_list_payload(row)
    if grocery and (is_groceries or any(grocery.values())):
        item["grocery"] = grocery
    if _row_has_key(row, "ZISPINNEDBYCURRENTUSER"):
        item["pinned"] = bool(row["ZISPINNEDBYCURRENTUSER"])
    if _row_has_key(row, "ZPINNEDDATE") and row["ZPINNEDDATE"] is not None:
        item["pinnedDate"] = row["ZPINNEDDATE"]
    return item


def format_list_title(row, db=None, *, color=True):
    title = _row_value(row, "ZNAME")
    rendered = color_list_name(title, db) if color else title
    return f"{rendered} {GROCERY_LIST_MARKER}" if is_grocery_list_row(row) else rendered


def normalize_list_lookup_name(name):
    if not name:
        return ""
    text = unicodedata.normalize("NFKC", str(name)).casefold()
    parts = []
    last_space = False
    for ch in text:
        if ch.isalnum():
            parts.append(ch)
            last_space = False
        else:
            category = unicodedata.category(ch)
            if ch.isspace() or category[0] in {"M", "P", "S", "Z"}:
                if parts and not last_space:
                    parts.append(" ")
                    last_space = True
    return "".join(parts).strip()

def list_ref_payload(row, *, requested=None, method="exact"):
    payload = {
        "id": _row_value(row, "Z_PK"),
        "title": _row_value(row, "ZNAME"),
        "objectUUID": _row_value(row, "ZCKIDENTIFIER"),
        "requested": requested,
        "method": method,
    }
    payload["isGroceries"] = is_grocery_list_row(row)
    grocery = grocery_list_payload(row)
    if grocery and (payload["isGroceries"] or any(grocery.values())):
        payload["grocery"] = grocery
    return payload

def resolve_list_ref(db, name=None, list_id=None):
    if list_id is not None:
        columns = list_select_columns(db)
        row = db.execute(
            f"SELECT {', '.join(columns)} FROM ZREMCDBASELIST "
            "WHERE Z_PK = ? AND ZMARKEDFORDELETION = 0 AND Z_ENT = 3 "
            "AND ZNAME IS NOT NULL AND ZNAME != ''",
            (list_id,),
        ).fetchone()
        return list_ref_payload(row, requested=str(list_id), method="id") if row else None

    if not name:
        return None

    rows = q_lists(db)
    exact = [row for row in rows if _row_value(row, "ZNAME") == name]
    if len(exact) == 1:
        return list_ref_payload(exact[0], requested=name, method="exact")
    if len(exact) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [list_ref_payload(row) for row in exact]}

    folded = str(name).casefold()
    ci = [row for row in rows if str(_row_value(row, "ZNAME")).casefold() == folded]
    if len(ci) == 1:
        return list_ref_payload(ci[0], requested=name, method="case_insensitive")
    if len(ci) > 1:
        return {"error": "ambiguous", "requested": name, "candidates": [list_ref_payload(row) for row in ci]}

    normalized = normalize_list_lookup_name(name)
    if not normalized:
        return None
    normalized_matches = [
        row for row in rows
        if normalize_list_lookup_name(_row_value(row, "ZNAME")) == normalized
    ]
    if len(normalized_matches) == 1:
        return list_ref_payload(normalized_matches[0], requested=name, method="normalized")
    if len(normalized_matches) > 1:
        return {
            "error": "ambiguous",
            "requested": name,
            "candidates": [list_ref_payload(row) for row in normalized_matches],
        }
    return None

def _print_list_resolution_error(requested, result=None):
    if result and result.get("error") == "ambiguous":
        options = ", ".join(
            f"{candidate['id']} ({candidate['title']})"
            for candidate in result.get("candidates", [])
        )
        print(
            f"Error: multiple lists match {requested!r}. Use the exact list name or --list-id with one of: {options}",
            file=sys.stderr,
        )
    else:
        print(f"Error: list not found: {requested}", file=sys.stderr)


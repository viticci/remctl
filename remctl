    return SERVER_PATH.resolve()


def current_python_path():
    return Path(sys.executable).resolve()


def current_bridge_path():
    if BRIDGE_PATH.exists():
        return BRIDGE_PATH.resolve()
    discovered = shutil.which("remctl-bridge")
    if discovered:
        return Path(discovered).resolve()
    return BRIDGE_PATH.resolve()


def launch_agent_path():
    return Path.home() / "Library" / "LaunchAgents" / f"{LAUNCH_AGENT_LABEL}.plist"


def launch_agent_log_path():
    return Path.home() / "Library" / "Logs" / "remctl-server.log"


def launchctl_domain():
    return f"gui/{os.getuid()}"


def launchctl_job_ref():
    return f"{launchctl_domain()}/{LAUNCH_AGENT_LABEL}"


def launch_agent_program_args(
    server_path,
    python_path=None,
    host=DEFAULT_SERVER_HOST,
    port=DEFAULT_SERVER_PORT,
    allow_origin=None,
    enable_opengraph=False,
):
    args = [str(server_path), "--port", str(port)]
    if python_path:
        args = [str(python_path), *args]
    if host and host != DEFAULT_SERVER_HOST:
        args.extend(["--host", host])
    if allow_origin:
        args.extend(["--allow-origin", allow_origin])
    if enable_opengraph:
        args.append("--enable-opengraph")
    return args


def build_launch_agent_plist(
    server_path,
    python_path=None,
    host=DEFAULT_SERVER_HOST,
    port=DEFAULT_SERVER_PORT,
    allow_origin=None,
    enable_opengraph=False,
):
    log_path = launch_agent_log_path()
    return {
        "Label": LAUNCH_AGENT_LABEL,
        "ProgramArguments": launch_agent_program_args(
            server_path,
            python_path=python_path or current_python_path(),
            host=host,
            port=port,
            allow_origin=allow_origin,
            enable_opengraph=enable_opengraph,
        ),
        "RunAtLoad": True,
        "KeepAlive": True,
        "WorkingDirectory": str(Path.home()),
        "EnvironmentVariables": {
            "HOME": str(Path.home()),
            "REMCTL_STORE_DIR": str(STORE_DIR),
            "REMCTL_CONFIG_DIR": str(CONFIG_DIR),
        },
        "StandardOutPath": str(log_path),
        "StandardErrorPath": str(log_path),
    }


def write_launch_agent_plist(
    server_path,
    python_path=None,
    host=DEFAULT_SERVER_HOST,
    port=DEFAULT_SERVER_PORT,
    allow_origin=None,
    enable_opengraph=False,
):
    path = launch_agent_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    launch_agent_log_path().parent.mkdir(parents=True, exist_ok=True)
    with path.open("wb") as fh:
        plistlib.dump(
            build_launch_agent_plist(
                server_path,
                python_path=python_path,
                host=host,
                port=port,
                allow_origin=allow_origin,
                enable_opengraph=enable_opengraph,
            ),
            fh,
        )
    return path


def ensure_api_token():
    ensure_private_dir(CONFIG_DIR)
    if TOKEN_FILE.exists():
        token = TOKEN_FILE.read_text().strip()
        if token:
            TOKEN_FILE.chmod(0o600)
            return token, False
    token = secrets.token_urlsafe(32)
    write_private_text_file(TOKEN_FILE, token + "\n")
    return token, True


def parse_launch_agent_settings():
    path = launch_agent_path()
    if not path.exists():
        return None
    with path.open("rb") as fh:
        data = plistlib.load(fh)
    args = list(data.get("ProgramArguments", []))
    if args and args[0] == "/bin/zsh" and "-c" in args:
        command = args[-1]
        if command.startswith("exec "):
            command = command[5:]
        args = shlex.split(command)
    settings = {
        "path": str(path),
        "python_path": None,
        "server_path": None,
        "host": DEFAULT_SERVER_HOST,
        "port": DEFAULT_SERVER_PORT,
        "allow_origin": None,
        "enable_opengraph": False,
        "allow_unsafe_sqlite_writes": False,
    }
    server_idx = next((idx for idx, arg in enumerate(args) if Path(arg).name == "remctl-server"), None)
    if server_idx is None:
        server_idx = 0 if args else None
    if server_idx is not None and args:
        settings["server_path"] = args[server_idx]
        if server_idx > 0:
            settings["python_path"] = " ".join(args[:server_idx])
    idx = (server_idx + 1) if server_idx is not None else 0
    while idx < len(args):
        arg = args[idx]
        if arg == "--host" and idx + 1 < len(args):
            settings["host"] = args[idx + 1]
            idx += 2
        elif arg == "--port" and idx + 1 < len(args):
            settings["port"] = int(args[idx + 1])
            idx += 2
        elif arg == "--allow-origin" and idx + 1 < len(args):
            settings["allow_origin"] = args[idx + 1]
            idx += 2
        elif arg == "--enable-opengraph":
            settings["enable_opengraph"] = True
            idx += 1
        elif arg == "--allow-unsafe-sqlite-writes":
            settings["allow_unsafe_sqlite_writes"] = True
            idx += 1
        else:
            idx += 1
    return settings


def launchctl_run(*args):
    return subprocess.run(["launchctl", *args], capture_output=True, text=True)


def wait_for_service_loaded(expected_loaded, timeout=3.0):
    deadline = time.monotonic() + timeout
    status = launch_agent_status()
    while time.monotonic() < deadline:
        if status["loaded"] == expected_loaded:
            return status
        time.sleep(0.1)
        status = launch_agent_status()
    return status


def launch_agent_status():
    path = launch_agent_path()
    status = {
        "installed": path.exists(),
        "loaded": False,
        "running": False,
        "path": str(path),
        "job": launchctl_job_ref(),
        "pid": None,
        "state": None,
        "details": "",
    }
    if sys.platform != "darwin":
        status["details"] = "launchctl is only available on macOS"
        return status
    proc = launchctl_run("print", launchctl_job_ref())
    status["details"] = (proc.stdout or proc.stderr).strip()
    if proc.returncode != 0:
        return status
    status["loaded"] = True
    state_match = re.search(r"^\s*state = (\w+)", proc.stdout, re.MULTILINE)
    if state_match:
        status["state"] = state_match.group(1)
        status["running"] = status["state"] == "running"
    pid_match = re.search(r"^\s*pid = (\d+)", proc.stdout, re.MULTILINE)
    if pid_match:
        status["pid"] = int(pid_match.group(1))
    return status


def local_api_probe(host, port, token=None, timeout=2):
    host = "127.0.0.1" if host in {"0.0.0.0", "::"} else host
    result = {"health": None, "stats": None, "error": None}
    try:
        with urlopen(f"http://{host}:{port}/health", timeout=timeout) as resp:
            result["health"] = json.loads(resp.read().decode("utf-8"))
        if token:
            req = Request(
                f"http://{host}:{port}/api/v1/stats",
                headers={"Authorization": f"Bearer {token}"},
            )
            with urlopen(req, timeout=timeout) as resp:
                result["stats"] = json.loads(resp.read().decode("utf-8"))
    except (HTTPError, URLError, OSError, json.JSONDecodeError) as exc:
        result["error"] = str(exc)
    return result


def assess_local_api_probe(host, port, probe, settings=None):
    host = "127.0.0.1" if host in {"0.0.0.0", "::"} else host
    base_url = f"http://{host}:{port}"
    health = probe.get("health")
    if not health:
        return {
            "status": "warn",
            "detail": probe.get("error") or f"{base_url} unavailable",
            "fix": "\n".join(
                [
                    "Check the launch agent state with:",
                    "  remctl service status",
                    "If it is stopped, run:",
                    "  remctl service restart",
                    f"Logs: {launch_agent_log_path()}",
                ]
            ),
        }

    health_data = health.get("data", {}) if isinstance(health, dict) else {}
    api_status = health_data.get("status", "unknown")
    database_state = health_data.get("database", "unknown")
    detail = f"{base_url} {api_status} (database: {database_state})"
    if api_status == "healthy" and database_state == "connected":
        return {"status": "ok", "detail": detail, "fix": None}
    return {
        "status": "fail",
        "detail": detail,
        "fix": service_full_disk_access_fix_text(settings, rerun_command="remctl doctor"),
    }


def local_api_connection_info():
    settings = parse_launch_agent_settings() or {}
    host = settings.get("host") or DEFAULT_SERVER_HOST
    port = settings.get("port") or DEFAULT_SERVER_PORT
    host = "127.0.0.1" if host in {"0.0.0.0", "::"} else host
    token = TOKEN_FILE.read_text().strip() if TOKEN_FILE.exists() else ""
    if not token:
        raise LocalAPIUnavailable(
            "Local API token not configured. Run remctl setup or remctl service install."
        )
    return host, port, token


def local_api_request(method, path, *, query=None, body=None, timeout=5):
    host, port, token = local_api_connection_info()
    url = f"http://{host}:{port}{path}"
    if query:
        url += "?" + urlencode(query, doseq=True)
    headers = {"Authorization": f"Bearer {token}"}
    data = None
    if body is not None:
        headers["Content-Type"] = "application/json"
        data = json.dumps(body).encode("utf-8")
    req = Request(url, headers=headers, data=data, method=method)
    try:
        with urlopen(req, timeout=timeout) as resp:
            payload = json.loads(resp.read().decode("utf-8"))
    except HTTPError as exc:
        message = str(exc)
        try:
            payload = json.loads(exc.read().decode("utf-8"))
            message = payload.get("error") or payload.get("message") or message
        except Exception:
            pass
        raise LocalAPIRequestError(message) from exc
    except (URLError, OSError, json.JSONDecodeError) as exc:
        raise LocalAPIUnavailable(f"Local API unavailable: {exc}") from exc

    if isinstance(payload, dict) and payload.get("ok") is False:
        raise LocalAPIRequestError(payload.get("error", "Local API request failed"))
    if isinstance(payload, dict) and "data" in payload:
        return payload["data"]
    return payload


def _item_due_datetime(item):
    value = item.get("dueDate")
    if not value:
        return None
    try:
        return datetime.fromisoformat(value)
    except ValueError:
        return None


def _item_is_overdue(item):
    if "overdue" in item:
        return bool(item["overdue"])
    due_dt = _item_due_datetime(item)
    return bool(due_dt and due_dt < start_of_day())


def _print_reminder_json(items):
    print(json.dumps(items, indent=2))


def _print_list_payload(rows, json_mode=False, table_mode=False):
    if json_mode:
        print(json.dumps([{"id": row["id"], "title": row["name"]} for row in rows], indent=2))
        return
    if table_mode:
        data = [{"id": row["id"], "title": row["name"], "list": "", "due": "", "pri": ""} for row in rows]
        print(fmt_table(data))
        return
    print(C.bold("Reminder Lists:"))
    for row in rows:
        list_name = color_list_name(row["name"])
        sec_count = row.get("sectionCount", 0) or 0
        sec_info = C.dim(f" [{sec_count} sections]") if sec_count else ""
        id_dim = C.dim(f"(id: {row['id']})")
        print(f"  {list_name} {id_dim}{sec_info}")
    print(f"\n{len(rows)} list{'s' if len(rows) != 1 else ''}")


def _print_show_payload(list_name, items, args):
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(f"No {'active ' if not args.completed else ''}reminders in '{list_name}'")
        return
    print(f"{C.bold(color_list_name(list_name))}:")
    section_names = [item["section"] for item in items if item.get("section")]
    if section_names:
        sec_items, unsectioned = {}, []
        for item in items:
            section = item.get("section")
            if section:
                sec_items.setdefault(section, []).append(item)
            else:
                unsectioned.append(item)
        for item in unsectioned:
            print(fmt(item, verbose=args.verbose))
        seen = []
        for section in section_names:
            if section not in seen:
                seen.append(section)
        for section in seen:
            print(f"\n  {C.bold(f'[{section}]')}")
            for item in sec_items[section]:
                print(fmt(item, verbose=args.verbose, indent="  "))
    else:
        for item in items:
            print(fmt(item, verbose=args.verbose))
    print(f"\n{len(items)} reminder{'s' if len(items) != 1 else ''}")


def _print_search_payload(query, items, args):
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(f"No reminders matching '{query}'")
        return
    print(f"Search: {C.bold(query)}")
    for item in items:
        print(fmt(item, verbose=args.verbose))
    print(f"\n{len(items)} result{'s' if len(items) != 1 else ''}")


def _print_today_payload(items, args):
    if args.no_overdue:
        items = [item for item in items if not _item_is_overdue(item)]
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(f"Nothing due today ({datetime.now().strftime('%Y-%m-%d')})")
        return
    overdue = [item for item in items if _item_is_overdue(item)]
    due = [item for item in items if not _item_is_overdue(item)]
    if overdue:
        print(C.red(f"Overdue ({len(overdue)}):"))
        for item in overdue:
            print(fmt(item, indent="  "))
        print()
    if due:
        print(C.bold(f"Due Today ({len(due)}):"))
        for item in due:
            print(fmt(item, indent="  "))
    print(f"\n{len(items)} total")


def _print_simple_reminder_list(items, args, *, empty_message, heading, total_label, group_by_day=False):
    if args.json:
        _print_reminder_json(items)
        return
    if getattr(args, "format", None) == "table":
        print(fmt_table(reminders_to_table_data(items)))
        return
    if not items:
        print(empty_message)
        return
    if group_by_day:
        print(C.bold(heading))
        groups = {}
        today = start_of_day()
        for item in items:
            due_dt = _item_due_datetime(item)
            if not due_dt:
                continue
            day_key = due_dt.strftime("%Y-%m-%d")
            day_label = due_dt.strftime("%A, %b %d")
            if due_dt.date() == today.date():
                day_label = "Today"
            elif due_dt.date() == (today + timedelta(days=1)).date():
                day_label = "Tomorrow"
            groups.setdefault((day_key, day_label), []).append(item)
        for (_, day_label), day_items in sorted(groups.items()):
            print(f"\n  {C.bold(day_label)}:")
            for item in day_items:
                print(fmt(item, indent="    "))
        print(f"\n{len(items)} {total_label}")
        return
    print(heading)
    for item in items:
        print(fmt(item, verbose=getattr(args, "verbose", False), indent="  "))
    print(f"\n{len(items)} {total_label}")


def _print_tags_payload(rows, json_mode=False):
    if json_mode:
        print(json.dumps(rows, indent=2))
        return
    if not rows:
        print("No tags found")
        return
    print(C.bold("Tags:"))
    for row in rows:
        print(f"  {C.magenta('#' + row['name'])}")
    print(f"\n{len(rows)} tag{'s' if len(rows) != 1 else ''}")


def _print_sections_payload(grouped, json_mode=False):
    if json_mode:
        print(json.dumps(grouped, indent=2))
        return
    if not grouped:
        print("No sections found")
        return
    count = 0
    for list_name, names in grouped.items():
        print(f"{C.bold(color_list_name(list_name))}:")
        for name in names:
            count += 1
            print(f"  - {name}")
        print()
    print(f"{count} section{'s' if count != 1 else ''}")


def _print_stats_payload(stats, json_mode=False):
    if json_mode:
        print(json.dumps(stats, indent=2))
        return
    print(C.bold("Reminders Stats"))
    print(f"  Total:      {stats['total']}")
    print(f"  Active:     {C.green(str(stats['active']))}")
    print(f"  Completed:  {C.dim(str(stats['completed']))}")
    print(f"  Overdue:    {C.red(str(stats['overdue'])) if stats['overdue'] else '0'}")
    print(f"  Flagged:    {C.yellow(str(stats['flagged'])) if stats['flagged'] else '0'}")
    print(f"  Lists:      {stats['lists']}")
    print(f"  Sections:   {stats['sections']}")


def _print_info_payload(item, args):
    if args.json:
        print(json.dumps(item, indent=2))
        return
    print(C.bold(f"Reminder #{item['id']}"))
    print(f"  Title:     {item.get('title') or '(untitled)'}")
    print(f"  List:      {color_list_name(item.get('list'))}")
    if item.get("section"):
        print(f"  Section:   {C.bold(item['section'])}")
    status_str = C.green("Completed") if item.get("completed") else C.yellow("Active")
    print(f"  Status:    {status_str}")
    pri_display = item.get("priority", "none")
    if pri_display == "high":
        pri_display = C.red(pri_display)
    elif pri_display == "medium":
        pri_display = C.yellow(pri_display)
    elif pri_display == "low":
        pri_display = C.green(pri_display)
    print(f"  Priority:  {pri_display}")
    print(f"  Flagged:   {C.yellow('Yes') if item.get('flagged') else 'No'}")
    if item.get("dueDate"):
        due_dt = _item_due_datetime(item)
        if due_dt:
            print(f"  Due:       {due_dt.strftime('%b %d, %Y at %I:%M %p')}")
    if item.get("createdDate"):
        print(f"  Created:   {datetime.fromisoformat(item['createdDate']).strftime('%b %d, %Y at %I:%M %p')}")
    if item.get("completionDate"):
        print(f"  Completed: {datetime.fromisoformat(item['completionDate']).strftime('%b %d, %Y at %I:%M %p')}")
    if item.get("notes"):
        print(f"  Notes:     {item['notes']}")
    if item.get("url"):
        print(f"  URL:       {item['url']}")
    if item.get("tags"):
        print(f"  Tags:      {', '.join(C.magenta('#' + tag) for tag in item['tags'])}")
    if item.get("parentTitle"):
        print(f"  Parent:    #{item['parentID']} ({item['parentTitle']})")
    elif item.get("parentID"):
        print(f"  Parent:    #{item['parentID']}")
    if item.get("subtasks"):
        print(f"  Subtasks ({len(item['subtasks'])}):")
        for sub in item["subtasks"]:
            print(fmt(sub, indent="    "))
    if item.get("attachments"):
        print(f"  Attachments ({len(item['attachments'])}):")
        for attachment in item["attachments"]:
            print(
                f"    - {attachment.get('filename') or 'untitled'} "
                f"({attachment.get('type') or '?'})"
            )
    if item.get("deepLink"):
        print(f"  Deep link: {C.dim(item['deepLink'])}")


def _normalize_write_result(result, *, status, reminder_id, title=None, include_title=True):
    payload = {"status": status, "id": reminder_id}
    final_title = title if title is not None else result.get("title")
    if include_title and final_title:
        payload["title"] = final_title
    return payload


def handle_local_api_fallback(args):
    cmd = getattr(args, "cmd", None) or "today"
    if cmd == "lists":
        rows = local_api_request("GET", "/api/v1/lists")
        _print_list_payload(rows, json_mode=args.json, table_mode=getattr(args, "format", None) == "table")
        return True
    if cmd == "show":
        items = local_api_request(
            "GET",
            f"/api/v1/lists/{quote(args.list, safe='')}",
            query={"completed": "1"} if args.completed else None,
        )
        _print_show_payload(args.list, items, args)
        return True
    if cmd == "search":
        query = {"q": args.query}
        if args.completed:
            query["completed"] = "1"
        items = local_api_request("GET", "/api/v1/search", query=query)
        _print_search_payload(args.query, items, args)
        return True
    if cmd == "today":
        items = local_api_request("GET", "/api/v1/today")
        _print_today_payload(items, args)
        return True
    if cmd == "upcoming":
        days = args.days if hasattr(args, "days") and args.days else 7
        items = local_api_request("GET", "/api/v1/upcoming", query={"days": str(days)})
        _print_simple_reminder_list(
            items,
            args,
            empty_message=f"Nothing due in the next {days} days",
            heading=f"Upcoming ({days} days):",
            total_label="upcoming",
            group_by_day=True,
        )
        return True
    if cmd == "overdue":
        items = local_api_request("GET", "/api/v1/overdue")
        _print_simple_reminder_list(
            items,
            args,
            empty_message="No overdue reminders",
            heading=C.red(C.bold(f"Overdue ({len(items)}):")),
            total_label="overdue",
        )
        return True
    if cmd == "flagged":
        items = local_api_request("GET", "/api/v1/flagged")
        _print_simple_reminder_list(
            items,
            args,
            empty_message="No flagged reminders",
            heading=C.bold("Flagged:"),
            total_label="flagged",
        )
        return True
    if cmd == "tags":
        rows = local_api_request("GET", "/api/v1/tags")
        _print_tags_payload(rows, json_mode=args.json)
        return True
    if cmd == "sections":
        grouped = local_api_request("GET", "/api/v1/sections")
        _print_sections_payload(grouped, json_mode=args.json)
        return True
    if cmd == "stats":
        stats = local_api_request("GET", "/api/v1/stats")
        _print_stats_payload(stats, json_mode=args.json)
        return True
    if cmd == "info":
        item = local_api_request("GET", f"/api/v1/reminders/{args.id}")
        _print_info_payload(item, args)
        return True
    if cmd == "subtasks":
        item = local_api_request("GET", f"/api/v1/reminders/{args.id}")
        subtasks = item.get("subtasks", [])
        if args.json:
            payload = dict(item)
            payload["subtasks"] = subtasks
            print(json.dumps(payload, indent=2))
            return True
        print(f"Parent: {item.get('title') or '(untitled)'}")
        if not subtasks:
            print("  No subtasks")
        else:
            for sub in subtasks:
                print(fmt(sub, indent="  "))
            print(f"\n{len(subtasks)} subtask{'s' if len(subtasks) != 1 else ''}")
        return True
    if cmd == "link":
        if args.list:
            query = {"completed": "1"} if args.completed else None
            items = local_api_request("GET", f"/api/v1/lists/{quote(args.list, safe='')}", query=query)
        else:
            items = [local_api_request("GET", f"/api/v1/reminders/{rid}") for rid in args.ids]
        results = [
            {"id": item["id"], "title": item["title"], "link": item["deepLink"]}
            for item in items
            if item.get("deepLink")
        ]
        if args.json:
            print(json.dumps(results, indent=2))
        else:
            for item in results:
                print(f"#{item['id']} {item['title']}")
                print(f"  {C.dim(item['link'])}")
        return True
    if cmd == "open":
        if getattr(args, "id", None):
            item = local_api_request("GET", f"/api/v1/reminders/{args.id}")
            if item.get("deepLink"):
                subprocess.run(["open", item["deepLink"]])
                print(f"Opened #{args.id} in Reminders.app")
            else:
                subprocess.run(["open", "-a", "Reminders"])
                print("Opened Reminders.app (no deep link available)")
        else:
            subprocess.run(["open", "-a", "Reminders"])
            print("Opened Reminders.app")
        return True
    if cmd == "done":
        result = local_api_request("POST", f"/api/v1/reminders/{args.id}/complete", body={})
        payload = _normalize_write_result(result, status="completed", reminder_id=args.id)
        print(json.dumps(payload) if args.json else f"Completed: {payload.get('title', args.id)}")
        return True
    if cmd == "undone":
        result = local_api_request("POST", f"/api/v1/reminders/{args.id}/uncomplete", body={})
        payload = _normalize_write_result(result, status="uncompleted", reminder_id=args.id)
        print(json.dumps(payload) if args.json else f"Uncompleted: {payload.get('title', args.id)}")
        return True
    if cmd == "flag":
        result = local_api_request("POST", f"/api/v1/reminders/{args.id}/flag", body={})
        payload = _normalize_write_result(result, status="flagged", reminder_id=args.id)
        print(json.dumps(payload) if args.json else f"Flagged: {payload.get('title', args.id)}")
        return True
    if cmd == "unflag":
        result = local_api_request("POST", f"/api/v1/reminders/{args.id}/unflag", body={})
        payload = _normalize_write_result(result, status="unflagged", reminder_id=args.id)
        print(json.dumps(payload) if args.json else f"Unflagged: {payload.get('title', args.id)}")
        return True
    if cmd == "delete":
        reminder = local_api_request("GET", f"/api/v1/reminders/{args.id}")
        if not args.force:
            ans = input(f"Delete '{reminder.get('title')}' from {reminder.get('list')}? [y/N] ")
            if not ans.lower().startswith("y"):
                print("Cancelled.")
                return True
        local_api_request("DELETE", f"/api/v1/reminders/{args.id}")
        payload = _normalize_write_result({}, status="deleted", reminder_id=args.id, title=reminder.get("title"))
        print(json.dumps(payload) if args.json else f"Deleted: {payload.get('title', args.id)}")
        return True
    if cmd == "edit":
        pm = {"high": 1, "medium": 5, "low": 9, "none": 0}
        dt = None
        if args.due and args.due != "clear":
            dt = parse_due(args.due)
            if dt is None:
                print(
                    f"Error: could not parse due date {args.due!r}. Use ISO "
                    "(YYYY-MM-DD [HH:MM]) or shortcuts like today/tomorrow/eod/+3d.",
                    file=sys.stderr,
                )
                sys.exit(1)
        body = {}
        if args.title:
            body["title"] = args.title
        if args.notes is not None:
            body["notes"] = args.notes
        if args.priority and args.priority.lower() in pm:
            body["priority"] = pm[args.priority.lower()]
        if args.due == "clear":
            body["due"] = None
        elif dt is not None:
            body["due"] = dt.isoformat()
        if getattr(args, "url", None):
            body["url"] = args.url
        if getattr(args, "recurrence", None):
            body["recurrence"] = parse_recurrence(args.recurrence)
        if getattr(args, "alarm", None):
            body["alarm"] = parse_alarm(args.alarm)
        if not body:
            print("Nothing to update.")
            return True
        local_api_request("PATCH", f"/api/v1/reminders/{args.id}", body=body)
        payload = {"status": "updated", "id": args.id}
        print(json.dumps(payload) if args.json else f"Updated #{args.id}")
        return True
    return False


def run_handler_with_fallback(args, handler):
    try:
        handler(args)
    except RemindersDBUnavailable as exc:
        try:
            if handle_local_api_fallback(args):
                return
        except LocalAPIRequestError as api_exc:
            print(f"Error: {api_exc}", file=sys.stderr)
            sys.exit(1)
        except LocalAPIUnavailable:
            pass
        print(f"Error: {exc}", file=sys.stderr)
        sys.exit(1)


def cmd_completion(a):
    shell = a.shell if hasattr(a, 'shell') and a.shell else "zsh"
    try:
        sys.stdout.write(get_completion_script(shell))
    except ValueError as exc:
        print(f"Error: {exc}. Use bash, zsh, or fish.", file=sys.stderr)
        sys.exit(1)


def _service_result(ok, action, **extra):
    data = {"ok": ok, "action": action}
    data.update(extra)
    return data


def install_service(
    *,
    host=DEFAULT_SERVER_HOST,
    port=DEFAULT_SERVER_PORT,
    allow_origin=None,
    enable_opengraph=False,
    start=True,
):
    if sys.platform != "darwin":
        return _service_result(False, "install", error="launchd service management requires macOS")
    server_path = current_server_path()
    if not server_path.exists():
        return _service_result(False, "install", error=f"remctl-server not found at {server_path}")
    path = write_launch_agent_plist(
        server_path,
        python_path=current_python_path(),
        host=host,
        port=port,
        allow_origin=allow_origin,
        enable_opengraph=enable_opengraph,
    )
    service = None
    if start:
        status = launch_agent_status()
        if status["loaded"]:
            stop_result = stop_service()
            if not stop_result["ok"]:
                return _service_result(
                    False,
                    "install",
                    path=str(path),
                    error=stop_result.get("error"),
                    service=stop_result,
                )
        service = start_service()
        if not service["ok"]:
            return _service_result(
                False,
                "install",
                path=str(path),
                error=service.get("error"),
                service=service,
            )
    return _service_result(True, "install", path=str(path), service=service)


def start_service():
    path = launch_agent_path()
    if sys.platform != "darwin":
        return _service_result(False, "start", error="launchd service management requires macOS")
    if not path.exists():
        return _service_result(False, "start", error=f"Launch agent not installed at {path}")
    details = ""
    for _ in range(5):
        proc = launchctl_run("bootstrap", launchctl_domain(), str(path))
        details = (proc.stdout or proc.stderr).strip()
        if proc.returncode == 0:
            wait_for_service_loaded(True)
            return _service_result(True, "start", details=details)
        if "input/output error" not in details.lower():
            break
        time.sleep(0.2)
    if "already" in details.lower():
        return restart_service()
    return _service_result(False, "start", error=details or "launchctl bootstrap failed")


def stop_service():
    if sys.platform != "darwin":
        return _service_result(False, "stop", error="launchd service management requires macOS")
    proc = launchctl_run("bootout", launchctl_job_ref())
    if proc.returncode == 0:
        wait_for_service_loaded(False)
        return _service_result(True, "stop", details=(proc.stdout or proc.stderr).strip())
    details = (proc.stdout or proc.stderr).strip()
    if (
        "could not find service" in details.lower()
        or "not found" in details.lower()
        or "no such process" in details.lower()
    ):
        return _service_result(True, "stop", details="Service was not loaded")
    return _service_result(False, "stop", error=details or "launchctl bootout failed")


def restart_service():
    if sys.platform != "darwin":
        return _service_result(False, "restart", error="launchd service management requires macOS")
    status = launch_agent_status()
    if status["loaded"]:
        proc = launchctl_run("kickstart", "-k", launchctl_job_ref())
        if proc.returncode == 0:
            return _service_result(True, "restart", details=(proc.stdout or proc.stderr).strip())
        details = (proc.stdout or proc.stderr).strip()
        return _service_result(False, "restart", error=details or "launchctl kickstart failed")
    return start_service()


def uninstall_service(remove_file=True):
    stop_result = stop_service()
    path = launch_agent_path()
    if remove_file and path.exists():
        path.unlink()
    if stop_result["ok"]:
        return _service_result(True, "uninstall", path=str(path), service=stop_result)
    if path.exists():
        return _service_result(False, "uninstall", path=str(path), service=stop_result, error=stop_result.get("error"))
    return _service_result(True, "uninstall", path=str(path), service=stop_result)


def cmd_service(a):
    if a.action == "install":
        result = install_service(
            host=a.host,
            port=a.port,
            allow_origin=a.allow_origin,
            enable_opengraph=a.enable_opengraph,
            start=not a.no_start,
        )
    elif a.action == "start":
        result = start_service()
    elif a.action == "stop":
        result = stop_service()
    elif a.action == "restart":
        result = restart_service()
    elif a.action == "uninstall":
        result = uninstall_service(remove_file=not a.keep_file)
    elif a.action == "status":
        status = launch_agent_status()
        settings = parse_launch_agent_settings()
        result = {"ok": status["installed"], "action": "status", "status": status, "settings": settings}
    else:
        print(f"Error: Unsupported service action '{a.action}'", file=sys.stderr)
        sys.exit(1)

    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        if a.action == "status":
            status = result["status"]
            settings = result["settings"] or {}
            state = "running" if status["running"] else ("loaded" if status["loaded"] else "not loaded")
            print(f"Launch agent: {status['path']}")
            print(f"State: {state}")
            if settings:
                host = settings.get("host") or DEFAULT_SERVER_HOST
                port = settings.get("port") or DEFAULT_SERVER_PORT
                display_host = "127.0.0.1" if host in {"0.0.0.0", "::"} else host
                print(f"Server: {settings.get('server_path')} --host {host} --port {port}")
                print(f"URL: http://{display_host}:{port}")
                if settings.get("python_path"):
                    print(f"Python: {settings['python_path']}")
                print(f"Full Disk Access target: {service_full_disk_access_target(settings)}")
            if status["pid"]:
                print(f"PID: {status['pid']}")
            if status["details"] and not status["loaded"]:
                print(f"Details: {status['details']}")
            if status["running"] and settings:
                token = TOKEN_FILE.read_text().strip() if TOKEN_FILE.exists() else None
                probe = local_api_probe(
                    settings.get("host") or DEFAULT_SERVER_HOST,
                    settings.get("port") or DEFAULT_SERVER_PORT,
                    token=token or None,
                )
                api_check = assess_local_api_probe(
                    settings.get("host") or DEFAULT_SERVER_HOST,
                    settings.get("port") or DEFAULT_SERVER_PORT,
                    probe,
                    settings=settings,
                )
                print(f"Health: {api_check['detail']}")
                if api_check["status"] != "ok" and api_check.get("fix"):
                    print("Fix:")
                    for line in str(api_check["fix"]).splitlines():
                        print(f"  {line}")
        elif result["ok"]:
            print(f"Service {result['action']} completed.")
            if result.get("path"):
                print(f"Launch agent: {result['path']}")
        else:
            print(f"Error: {result.get('error', 'Service action failed')}", file=sys.stderr)
    if not result.get("ok", False):
        sys.exit(1)


def gather_doctor_checks():
    checks = []

    def add(name, status, detail, fix=None):
        checks.append({"name": name, "status": status, "detail": detail, "fix": fix})

    is_darwin = sys.platform == "darwin"
    add(
        "platform",
        "ok" if is_darwin else "fail",
        f"{platform.system()} {platform.mac_ver()[0] or platform.release()}",
        None if is_darwin else "RemCTL only supports macOS.",
    )

    py_ok = sys.version_info >= (3, 10)
    add(
        "python",
        "ok" if py_ok else "fail",
        platform.python_version(),
        None if py_ok else "Install Python 3.10 or newer.",
    )

    add(
        "store_dir",
        "ok" if STORE_DIR.exists() else "fail",
        str(STORE_DIR),
        None if STORE_DIR.exists() else "Set REMCTL_STORE_DIR if your Reminders store lives elsewhere.",
    )

    db_access_error = reminders_store_access_error()
    db_path = find_main_db_path()
    if db_access_error:
        add(
            "database",
            "fail",
            db_access_error,
            full_disk_access_fix_text(
                api_healthy=False,
                rerun_command="remctl doctor",
                mention_onboard=True,
            ),
        )
    else:
        add(
            "database",
            "ok" if db_path else "fail",
            str(db_path) if db_path else "No Reminders database found",
            None if db_path else "Enable iCloud Reminders and open Reminders.app once, or run remctl onboard.",
        )

    cli_path = current_cli_path()
    cli_on_path = shutil.which("remctl") is not None
    add(
        "cli",
        "ok" if cli_path.exists() else "fail",
        str(cli_path),
        None if cli_on_path else f"Add {cli_path.parent} to PATH.",
    )

    bridge_path = current_bridge_path()
    bridge_ok = bridge_path.exists() and os.access(bridge_path, os.X_OK)
    bridge_fix = None
    if not bridge_ok:
        bridge_fix = "Run ./install.sh or compile remctl-bridge.swift with swiftc, then run remctl onboard."
    add(
        "bridge",
        "ok" if bridge_ok else "warn",
        str(bridge_path),
        bridge_fix,
    )

    server_ok = current_server_path().exists()
    add(
        "server_binary",
        "ok" if server_ok else "warn",
        str(current_server_path()),
        None if server_ok else "Install remctl-server if you want REST API access.",
    )

    config_ok = CONFIG_DIR.exists()
    add(
        "config_dir",
        "ok" if config_ok else "warn",
        str(CONFIG_DIR),
        None if config_ok else "Run remctl setup to create config files.",
    )

    token = TOKEN_FILE.read_text().strip() if TOKEN_FILE.exists() else ""
    add(
        "api_token",
        "ok" if token else "warn",
        str(TOKEN_FILE),
        None if token else "Run remctl setup to generate an API token.",
    )

    shell = detect_shell_name()
    if shell in {"zsh", "bash", "fish"}:
        completion_path = completion_target_path(shell)
        add(
            "completion",
            "ok" if completion_path.exists() else "warn",
            f"{shell}: {completion_path}",
            None if completion_path.exists() else f"Run remctl setup --shell {shell} to install completion.",
        )
    else:
        add("completion", "warn", f"Unsupported shell '{shell}'", "Run remctl setup --shell zsh|bash|fish.")

    service = launch_agent_status()
    service_status = "ok" if service["running"] else ("warn" if service["installed"] else "warn")
    service_fix = None
    if not service["installed"]:
        service_fix = "Run remctl setup --service install or remctl service install."
    elif not service["running"]:
        service_fix = "Run remctl service restart."
    add("launch_agent", service_status, service["path"], service_fix)

    settings = parse_launch_agent_settings()
    if service["running"]:
        host = settings["host"] if settings else DEFAULT_SERVER_HOST
        port = settings["port"] if settings else DEFAULT_SERVER_PORT
        probe = local_api_probe(host, port, token=token or None)
        api_check = assess_local_api_probe(host, port, probe, settings=settings)
        add("local_api", api_check["status"], api_check["detail"], api_check["fix"])
        if api_check["status"] == "ok":
            for check in checks:
                if check["name"] == "database" and check["status"] == "fail":
                    check["status"] = "warn"
                    check["detail"] = (
                        f"{check['detail']} Direct SQLite reads are blocked in this shell, "
                        "but the local remctl service fallback is healthy."
                    )
                    check["fix"] = full_disk_access_fix_text(
                        api_healthy=True,
                        rerun_command="remctl doctor",
                        mention_onboard=True,
                    )
                    break
    else:
        add("local_api", "warn", "Server not running", "Run remctl service restart to probe the local API.")

    return checks


def cmd_doctor(a):
    checks = gather_doctor_checks()
    fail_count = sum(1 for check in checks if check["status"] == "fail")
    warn_count = sum(1 for check in checks if check["status"] == "warn")
    result = {
        "ok": fail_count == 0,
        "warnings": warn_count,
        "failures": fail_count,
        "checks": checks,
    }
    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print_check_report("RemCTL doctor", checks)
    if fail_count:
        sys.exit(1)


def cmd_onboard(a):
    result = run_onboarding(auto=False)
    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print(C.bold("RemCTL onboard"))
        print(C.dim("Approve any macOS prompts for Reminders or Automation access."))
        print()
        print_check_report(None, result["checks"])
        database_check = next((check for check in result["checks"] if check["name"] == "database"), None)
        api_check = next((check for check in result["checks"] if check["name"] == "local_api"), None)
        if needs_full_disk_access_guidance(database_check):
            print_full_disk_access_guidance(
                api_healthy=bool(api_check and api_check["status"] == "ok"),
                settings_opened=open_full_disk_access_settings(),
                rerun_command="remctl doctor",
            )
    if result["failures"]:
        sys.exit(1)


def cmd_setup(a):
    token, token_created = ensure_api_token()
    selected_shell = resolve_setup_shell(a.shell)
    completion_path = None
    if selected_shell != "skip":
        try:
            completion_path = install_completion(selected_shell)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            sys.exit(1)

    service_result = None
    if a.service == "install":
        service_result = install_service(
            host=a.host,
            port=a.port,
            allow_origin=a.allow_origin,
            enable_opengraph=a.enable_opengraph,
            start=True,
        )
        if not service_result["ok"]:
            if getattr(a, "json", False):
                print(json.dumps(service_result, indent=2))
            else:
                print(f"Error: {service_result.get('error', 'Service setup failed')}", file=sys.stderr)
            sys.exit(1)

    result = {
        "ok": True,
        "config_dir": str(CONFIG_DIR),
        "token_file": str(TOKEN_FILE),
        "token_created": token_created,
        "completion_shell": None if selected_shell == "skip" else selected_shell,
        "completion_path": str(completion_path) if completion_path else None,
        "service": service_result,
    }
    if getattr(a, "doctor", False):
        doctor_checks = gather_doctor_checks()
        result["doctor"] = {
            "ok": sum(1 for check in doctor_checks if check["status"] == "fail") == 0,
            "checks": doctor_checks,
        }

    if getattr(a, "json", False):
        print(json.dumps(result, indent=2))
    else:
        print(C.bold("RemCTL setup"))
        print(f"Config directory: {CONFIG_DIR}")
        print(f"API token: {TOKEN_FILE}" + (" (created)" if token_created else " (already exists)"))
        if completion_path:
            print(f"Shell completion: {completion_path}")
        else:
            print("Shell completion: skipped")
        if service_result:
            settings = parse_launch_agent_settings() or {}
            print("Local API service: installed")
            print(f"Launch agent: {launch_agent_path()}")
            print(f"Full Disk Access target: {service_full_disk_access_target(settings)}")
        else:
            service = launch_agent_status()
            if service["installed"]:
                state = "running" if service["running"] else ("loaded" if service["loaded"] else "stopped")
                settings = parse_launch_agent_settings() or {}
                print(f"Local API service: already installed ({state})")
                print(f"Launch agent: {service['path']}")
                if settings:
                    print(f"Full Disk Access target: {service_full_disk_access_target(settings)}")
            else:
                print("Local API service: not installed (optional; run `remctl service install` if you need the REST API)")
        print()
        print("Next:")
        print("  1. remctl onboard   # grant macOS Reminders, Automation, and Full Disk Access permissions")
        print("  2. remctl doctor    # verify the CLI and optional service")
        if getattr(a, "doctor", False):
            print()
            cmd_doctor(SimpleNamespace(json=False))

